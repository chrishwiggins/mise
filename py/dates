#!/bin/bash
if [ $# -ne 1 ]; then
    echo "Usage: $(basename "$0") <number>" >&2
    exit 1
fi
n=$1
if ! [[ "$n" =~ ^-?[0-9]+$ ]]; then
    echo "Please enter a valid integer." >&2
    exit 1
fi
if [ "$n" -lt 0 ]; then
    sign=-
    abs=$(( -n ))
else
    sign=+
    abs=$n
fi
for ((i=1; i<=abs; i++)); do
    date -v${sign}${i}d "+%a"$'\t'"%Y-%m-%d"
done
