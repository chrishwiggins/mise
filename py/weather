#!/usr/bin/python3

import os

import requests
from datetime import datetime
import argparse


def get_point_data(latitude, longitude):
    url = f"https://api.weather.gov/points/{latitude},{longitude}"
    response = requests.get(url)
    return response.json()


def get_weather_forecast(point_data):
    forecast_url = point_data["properties"]["forecast"]
    forecast_response = requests.get(forecast_url)
    return forecast_response.json()


def get_current_temp(point_data, use_celsius=False):
    stations_url = point_data["properties"]["observationStations"]
    stations = requests.get(stations_url).json()
    station = stations["features"][0]["id"]
    obs = requests.get(f"{station}/observations/latest").json()
    temp_c = obs["properties"]["temperature"]["value"]
    if temp_c is None:
        return None
    if use_celsius:
        return int(round(temp_c))
    return int(round(temp_c * 9.0 / 5.0 + 32))


def format_temperature(temp):
    # Format the temperature to display three digits
    return f"{temp:03d}"


def format_precipitation(prob):
    # Format the precipitation probability to display three digits
    # If the probability is None, return 000
    return f"{prob if prob is not None else 0:03d}"


def get_uv_index(latitude, longitude):
    """Get UV index from CurrentUVIndex.com API (no API key required)"""
    url = f"https://currentuvindex.com/api/v1/uvi?latitude={latitude}&longitude={longitude}"
    try:
        response = requests.get(url, timeout=5)
        if response.status_code == 200:
            data = response.json()
            return data.get("now", {}).get("uvi")
    except requests.RequestException:
        pass
    return None


def format_uv_index(uv_index):
    """Format UV index with descriptive text"""
    if uv_index is None:
        return "UV: N/A"

    uv_val = round(uv_index, 1)

    if uv_val <= 2:
        level = "Low"
    elif uv_val <= 5:
        level = "Moderate"
    elif uv_val <= 7:
        level = "High"
    elif uv_val <= 10:
        level = "Very High"
    else:
        level = "Extreme"

    return f"UV: {uv_val} ({level})"


def get_minutely_tomorrow(latitude, longitude, api_key, use_celsius=False):
    """15-min rows from Tomorrow.io Timelines API (requires API key).

    Returns a list of (label, temp, prob, amount) tuples or None on any
    failure, which triggers the Open-Meteo fallback. Labels are in the
    terminal's local timezone (Tomorrow.io timestamps are UTC)."""
    params = {
        "location": f"{latitude},{longitude}",
        "fields": "temperature,precipitationProbability",
        "timesteps": "15m",
        "startTime": "now",
        "endTime": "nowPlus3h",
        "units": "metric" if use_celsius else "imperial",
        "apikey": api_key,
    }
    try:
        response = requests.get(
            "https://api.tomorrow.io/v4/timelines", params=params, timeout=10
        )
        if response.status_code != 200:
            return None
        intervals = response.json()["data"]["timelines"][0]["intervals"]
    except (requests.RequestException, ValueError, KeyError, IndexError):
        return None
    rows = []
    for interval in intervals[:12]:
        start = interval["startTime"].replace("Z", "+00:00")
        label = datetime.fromisoformat(start).astimezone().strftime("%H:%M")
        values = interval["values"]
        rows.append(
            (
                label,
                values.get("temperature"),
                values.get("precipitationProbability"),
                None,
            )
        )
    return rows


def get_minutely_openmeteo(latitude, longitude, use_celsius=False):
    """15-min rows from Open-Meteo (keyless).

    Temperature and precipitation amount are native 15-min (HRRR in North
    America); rain probability only exists hourly, so each hour's value is
    repeated across its four slots. Labels are location-local via
    timezone=auto."""
    params = {
        "latitude": latitude,
        "longitude": longitude,
        "minutely_15": "temperature_2m,precipitation",
        "hourly": "precipitation_probability",
        "forecast_minutely_15": 12,
        "forecast_hours": 4,
        "temperature_unit": "celsius" if use_celsius else "fahrenheit",
        "timezone": "auto",
    }
    if not use_celsius:
        params["precipitation_unit"] = "inch"
    try:
        response = requests.get(
            "https://api.open-meteo.com/v1/forecast", params=params, timeout=10
        )
        if response.status_code != 200:
            return None
        data = response.json()
        minutely = data["minutely_15"]
    except (requests.RequestException, ValueError, KeyError):
        return None
    hourly = data.get("hourly", {})
    prob_by_hour = dict(
        zip(
            (t[:13] for t in hourly.get("time", [])),
            hourly.get("precipitation_probability", []),
        )
    )
    rows = []
    for t, temp, amount in zip(
        minutely["time"], minutely["temperature_2m"], minutely["precipitation"]
    ):
        rows.append((t[11:16], temp, prob_by_hour.get(t[:13]), amount))
    return rows


def print_minutely_forecast(rows, use_celsius=False):
    if not rows:
        print("15-min forecast unavailable")
        return
    temp_unit = "°C" if use_celsius else "°F"
    precip_unit = "mm" if use_celsius else "in"
    for label, temp, prob, amount in rows:
        temp_str = format_temperature(int(round(temp))) if temp is not None else "N/A"
        prob_str = format_precipitation(int(round(prob)) if prob is not None else None)
        suffix = f" {amount}{precip_unit}" if amount else ""
        print(f"{label} {temp_str}{temp_unit} {prob_str}%{suffix}")


def get_day_of_week(date_str):
    # Convert the date string to a datetime object
    date_obj = datetime.strptime(date_str, "%Y-%m-%d")

    # Return the day of the week as a three-letter abbreviation
    return date_obj.strftime("%a")


def fahrenheit_to_celsius(fahrenheit):
    return int((fahrenheit - 32) * 5.0 / 9.0)


def print_daily_forecast(weather_forecast, num_days, use_celsius=False):
    # Check if the forecast data contains the necessary properties
    if "properties" in weather_forecast and "periods" in weather_forecast["properties"]:
        daily_forecasts = {}

        # Loop through each forecast period
        for period in weather_forecast["properties"]["periods"]:
            date = period["startTime"].split("T")[0]
            day_of_week = get_day_of_week(date)
            temp = period["temperature"]
            precip_prob = format_precipitation(
                period["probabilityOfPrecipitation"]["value"]
            )

            # Store forecast data for each day
            if date not in daily_forecasts:
                daily_forecasts[date] = {
                    "day": day_of_week,
                    "high": temp,
                    "low": temp,
                    "precip": precip_prob,
                    "desc": period["shortForecast"],
                }
            else:
                # Update high and low temperatures
                if period["isDaytime"]:
                    daily_forecasts[date]["high"] = temp
                else:
                    daily_forecasts[date]["low"] = temp

            # Break the loop if the desired number of days is reached
            if len(daily_forecasts) == num_days:
                break

        # Print the forecast for each day
        for date, info in daily_forecasts.items():
            low_temp = info["low"]
            high_temp = info["high"]

            # Convert to Celsius if requested
            if use_celsius:
                low_temp = fahrenheit_to_celsius(low_temp)
                high_temp = fahrenheit_to_celsius(high_temp)
                temp_unit = "°C"
            else:
                temp_unit = "°F"

            print(
                f"{info['day']} {date}: Lo {format_temperature(low_temp)}{temp_unit} ; Hi {format_temperature(high_temp)}{temp_unit} ; Pr {info['precip']}% ; {info['desc']}"
            )

    else:
        print("Forecast data is not available.")


# Function to get latitude and longitude from ZIP code using OpenCage Geocoder
def geocode_zip(zip_code, api_key):
    base_url = "https://api.opencagedata.com/geocode/v1/json"
    params = {"q": zip_code, "key": api_key, "limit": 1}
    response = requests.get(base_url, params=params)
    data = response.json()
    if data["results"]:
        lat = data["results"][0]["geometry"]["lat"]
        lon = data["results"][0]["geometry"]["lng"]
        return lat, lon
    else:
        return None, None


def main():
    parser = argparse.ArgumentParser(
        description="Get the weather forecast for a specific location.",
        epilog=(
            "Example usage:\n"
            "  weather -d 3 -l 40.7421,-74.0018\n"
            "  Outputs 3-day forecast for given latitude and longitude\n\n"
            "  weather -d 5 -z 90210 -k YOUR_API_KEY\n"
            "  Outputs 5-day forecast for ZIP code 90210 using OpenCage Geocoder\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("-z", "--zipcode", help="ZIP code for the forecast", type=str)
    parser.add_argument(
        "-l",
        "--latlon",
        help="Latitude and Longitude for the forecast (format: lat,lon)",
        type=str,
    )
    parser.add_argument(
        "-d",
        "--days",
        help="Number of days to forecast (default 10)",
        default=None,
        type=int,
    )
    parser.add_argument(
        "-k", "--apikey", help="OpenCage API key", default=None, type=str
    )
    parser.add_argument(
        "-c", "--celsius", help="Display temperature in Celsius", action="store_true"
    )
    parser.add_argument(
        "-m",
        "--minutely",
        help="Show 15-minute rain/temperature table for the next 3 hours",
        action="store_true",
    )
    parser.add_argument(
        "--tkey",
        help="Tomorrow.io API key (default: TOMORROW_API_KEY env var)",
        default=None,
        type=str,
    )
    args = parser.parse_args()

    # Default NYC coordinates
    default_latitude = "40.7128"
    default_longitude = "-74.0060"

    if args.latlon:
        latitude, longitude = args.latlon.split(",")
    elif args.apikey and args.zipcode:
        latitude, longitude = geocode_zip(args.zipcode, args.apikey)
        if latitude is None or longitude is None:
            print(f"Could not geocode ZIP code: {args.zipcode}")
            return
    else:
        # Default to NYC coordinates if no arguments are provided
        latitude, longitude = default_latitude, default_longitude

    point_data = get_point_data(latitude, longitude)

    temp_unit = "°C" if args.celsius else "°F"
    # NWS is US-only; point_data lacks "properties" elsewhere
    current = (
        get_current_temp(point_data, args.celsius)
        if "properties" in point_data
        else None
    )

    # Build current conditions output
    current_output = []
    if current is not None:
        current_output.append(f"Now: {format_temperature(current)}{temp_unit}")

    # Always include UV index
    uv_index = get_uv_index(latitude, longitude)
    current_output.append(format_uv_index(uv_index))

    if current_output:
        print(" ; ".join(current_output))

    if args.minutely:
        tkey = args.tkey or os.environ.get("TOMORROW_API_KEY")
        rows = (
            get_minutely_tomorrow(latitude, longitude, tkey, args.celsius)
            if tkey
            else None
        )
        rows = rows or get_minutely_openmeteo(latitude, longitude, args.celsius)
        print_minutely_forecast(rows, args.celsius)

    if not args.minutely or args.days is not None:
        days = args.days if args.days is not None else 10
        if "properties" in point_data:
            weather_forecast = get_weather_forecast(point_data)
            print_daily_forecast(weather_forecast, days, args.celsius)
        else:
            print("Forecast data is not available.")


if __name__ == "__main__":
    main()
