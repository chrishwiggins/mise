  .row .nm small{display:block;color:var(--dim);font-size:10px}
  .track{background:var(--panel2);border-radius:5px;height:22px;overflow:hidden}
  .fill{height:100%;background:linear-gradient(90deg,var(--bar),#4a82c4);border-radius:5px;
    transform-origin:left;animation:grow .9s cubic-bezier(.2,.8,.2,1) both}
