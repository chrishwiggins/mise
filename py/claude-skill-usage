#!/usr/bin/env python3
"""claude-skill-usage - analyze Claude Code slash-command, skill, and hook usage.

Reads ~/.claude/history.jsonl (typed prompts), ~/.claude/settings*.json (hook
wiring), and ~/.claude/hooks/ file mtimes, then writes a self-contained HTML
report. Pure analysis: no Claude / LLM at runtime, fully deterministic and
re-runnable.

Usage:
    claude-skill-usage                      # write /tmp/hot.htm
    claude-skill-usage -o ~/report.html     # custom output
    claude-skill-usage --open               # write and open in browser
    claude-skill-usage --top 25             # show top N commands
    claude-skill-usage --days 14            # "hottest" window (default 30)
    claude-skill-usage --json               # dump raw data as JSON, no HTML

Caveat: history.jsonl records what you *typed*. Skills auto-invoked by the model
(description match, not a /name) are not counted here.
"""
import argparse
import collections
import datetime
import html
import json
import os
import re
import subprocess
import sys

CLAUDE = os.path.expanduser("~/.claude")

# Built-in CLI commands and obvious typos/path-fragments to exclude from the
# "your custom commands" ranking.
BUILTIN = {
    "exit", "compact", "context", "model", "clear", "help", "config", "resume",
    "init", "review", "status", "cost", "login", "logout", "memory", "quit",
    "usage", "effort", "plugin", "plugins", "export", "play", "rate-limit-options",
    "extra-usage", "install-github-app", "reload-plugins", "tasks", "tokens",
    "mobile", "chrome", "upgrade", "settings", "schedule", "whatsnext", "passes",
    "done", "raw", "fix", "send", "vim", "terminal-setup", "bug", "pr-comments",
    "pr_comments", "release-notes", "add-dir", "agents", "mcp", "doctor",
    "permissions", "hooks", "ide", "fast", "websearch",
}
# Path fragments that leak in when a prompt starts with an absolute path.
PATH_JUNK = {"Users", "tmp", "private", "opt", "YYYY-MM-DD", "Test", "th", "exut"}

# Descriptions are read live from the source-of-truth files: a command's
# ~/.claude/commands/<cmd>.md or a skill's ~/.claude/skills/<cmd>/SKILL.md.
# Both may carry a YAML `description:` in frontmatter; failing that we fall back
# to the first `# H1` title or first prose line. Results are cached per run.
_DESC_CACHE = {}


def _extract_desc(path):
    """Pull a one-line description from a command/skill markdown file."""
    try:
        with open(path) as f:
            text = f.read()
    except OSError:
        return ""
    # YAML frontmatter description: (quoted or bare, possibly multi-word).
    fm = re.match(r"^---\s*\n(.*?)\n---", text, re.S)
    if fm:
        m = re.search(r'^description:\s*["\']?(.+?)["\']?\s*$',
                      fm.group(1), re.M)
        if m:
            return m.group(1).strip()
        body = text[fm.end():]
    else:
        body = text
    # Fall back to the first H1 title.
    m = re.search(r"^#\s+(.+?)\s*$", body, re.M)
    if m:
        return m.group(1).strip()
    # Last resort: first non-blank prose line.
    for line in body.splitlines():
        line = line.strip()
        if line and not line.startswith(("#", "-", "*", ">")):
            return line
    return ""


def describe(cmd):
    """One-line description for a command/skill name, '' if unknown."""
    if cmd in _DESC_CACHE:
        return _DESC_CACHE[cmd]
    candidates = [
        os.path.join(CLAUDE, "commands", f"{cmd}.md"),
        os.path.join(CLAUDE, "skills", cmd, "SKILL.md"),
    ]
    desc = ""
    for path in candidates:
        if os.path.exists(path):
            desc = _extract_desc(path)
            if desc:
                break
    # Trim over-long titles so the chart label stays readable.
    if len(desc) > 60:
        desc = desc[:57].rstrip() + "..."
    _DESC_CACHE[cmd] = desc
    return desc

# Classify hooks for the report. Substring match on the script name.
HOOK_KIND = [
    ("email", "safety"), ("eml", "safety"), ("public-repo", "safety"),
    ("home-dir", "safety"), ("send", "safety"),
    ("llm-tells", "style"), ("markdown-bold", "style"), ("finds-you-well", "style"),
    ("rtk", "style"),
]


def load_history():
    """Yield (timestamp_seconds, raw_display) for each prompt in history.jsonl."""
    path = os.path.join(CLAUDE, "history.jsonl")
    if not os.path.exists(path):
        sys.exit(f"no history file at {path}")
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                d = json.loads(line)
            except json.JSONDecodeError:
                continue
            yield d.get("timestamp", 0) / 1000.0, d.get("display", "").strip()


def analyze(days):
    rows = []          # (ts, cmd) for every slash command
    first = last = None
    total = slash = 0
    for ts, disp in load_history():
        total += 1
        if ts:
            first = ts if first is None else min(first, ts)
            last = ts if last is None else max(last, ts)
        m = re.match(r"^/([A-Za-z0-9_:-]+)", disp)
        if m:
            slash += 1
            rows.append((ts, m.group(1)))

    counts = collections.Counter(c for _, c in rows)
    custom = {c: n for c, n in counts.items()
              if c not in BUILTIN and c not in PATH_JUNK}

    firstd, lastd = {}, {}
    for ts, c in rows:
        if c not in firstd or ts < firstd[c]:
            firstd[c] = ts
        if c not in lastd or ts > lastd[c]:
            lastd[c] = ts

    cutoff = (last or 0) - days * 86400
    recent = collections.Counter(
        c for ts, c in rows
        if ts >= cutoff and c not in BUILTIN and c not in PATH_JUNK)

    def dd(ts):
        return datetime.date.fromtimestamp(ts).isoformat() if ts else "?"

    top = sorted(custom.items(), key=lambda x: -x[1])
    return {
        "span": [dd(first), dd(last)],
        "total": total, "slash": slash,
        "distinct": len(custom), "customtotal": sum(custom.values()),
        "days": days,
        "top": [{"cmd": c, "n": n, "first": dd(firstd[c]),
                 "last": dd(lastd[c]), "desc": describe(c)} for c, n in top],
        "recent": [{"cmd": c, "n": n} for c, n in recent.most_common(15)],
        "hooks": analyze_hooks(),
    }


def wired_hooks():
    """Return set of hook script basenames referenced in settings*.json."""
    wired = {}
    for fn in ("settings.json", "settings.local.json"):
        path = os.path.join(CLAUDE, fn)
        if not os.path.exists(path):
            continue
        try:
            s = json.load(open(path))
        except (json.JSONDecodeError, OSError):
            continue
        for event, arr in s.get("hooks", {}).items():
            for entry in arr:
                for hook in entry.get("hooks", []):
                    cmd = hook.get("command", "")
                    for name in re.findall(r"([\w-]+\.(?:sh|py))", cmd):
                        wired.setdefault(name, set()).add(event)
    return {k: ", ".join(sorted(v)) for k, v in wired.items()}


def analyze_hooks():
    hdir = os.path.join(CLAUDE, "hooks")
    if not os.path.isdir(hdir):
        return []
    wired = wired_hooks()
    out = []
    for name in os.listdir(hdir):
        if not name.endswith((".sh", ".py")):
            continue
        mtime = os.path.getmtime(os.path.join(hdir, name))
        kind = "other"
        for frag, k in HOOK_KIND:
            if frag in name:
                kind = k
                break
        out.append({
            "name": name,
            "mtime": datetime.date.fromtimestamp(mtime).isoformat(),
            "kind": kind,
            "event": wired.get(name, ""),
            "wired": name in wired,
        })
    out.sort(key=lambda h: h["mtime"], reverse=True)
    return out


# --- HTML template; data is injected as a JSON blob, rendered client-side. -----
TEMPLATE = r"""<!doctype html>
