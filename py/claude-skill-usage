    <div><h2>Most used &mdash; all time</h2>
      <p class="note" id="alltime-note"></p><div id="alltime"></div></div>
    <div><h2>Hottest now</h2>
      <p class="note" id="recent-note"></p><div id="recent"></div></div>
  </div>
  <h2>Hooks &mdash; what's live</h2>
  <p class="note" id="hooks-note"></p>
  <table id="hooks"><thead><tr><th>Hook</th><th>Last edited</th><th>Kind</th>
    <th>Event</th><th>Active</th></tr></thead><tbody></tbody></table>
  <footer id="foot"></footer>
</div>
<script id="data" type="application/json">__DATA__</script>
<script>
const D=JSON.parse(document.getElementById('data').textContent);
document.getElementById('span').textContent=
  `Typed-command history, ${D.span[0]} → ${D.span[1]} · ${D.total.toLocaleString()} prompts`;
const stats=[[D.slash.toLocaleString(),"slash invocations"],
  [Math.round(100*D.slash/D.total)+"%","of prompts use a command"],
  [D.distinct,"distinct custom commands"],
  [D.customtotal.toLocaleString(),"custom invocations"]];
document.getElementById('stats').innerHTML=stats.map(([n,l])=>
  `<div class="stat"><div class="num">${n}</div><div class="lbl">${l}</div></div>`).join('');
const wired=D.hooks.filter(h=>h.wired).length;
document.getElementById('alltime-note').textContent=
  `Top ${D.topN} custom commands, by times typed`;
document.getElementById('recent-note').textContent=`Last ${D.days} days.`;
document.getElementById('hooks-note').textContent=
  `${D.hooks.length} scripts on disk; ${wired} wired into settings and firing. Sorted by last edit.`;
function bars(el,items,hot){
  if(!items.length){el.innerHTML='<p class="note">No activity in this window.</p>';return;}
  const max=items[0].n||1;
  el.innerHTML=items.map((it,i)=>{
  const pct=(it.n/max*100).toFixed(1);
  const sub=it.desc?`<small>${it.desc}</small>`:'';
  return `<div class="row"><div class="nm">/${it.cmd}${sub}</div>
    <div class="track"><div class="fill ${hot?'hotbar':''}" style="width:${pct}%;animation-delay:${i*40}ms"></div></div>
    <div class="v">${it.n}</div></div>`;}).join('');}
bars(document.getElementById('alltime'),D.top.slice(0,D.topN),false);
bars(document.getElementById('recent'),D.recent,true);
document.querySelector('#hooks tbody').innerHTML=D.hooks.map(h=>
  `<tr><td class="mono">${h.name}</td><td>${h.mtime}</td>
   <td><span class="tag ${h.kind}">${h.kind}</span></td>
   <td>${h.event||'—'}</td>
   <td><span class="dot ${h.wired?'on':'off'}"></span>${h.wired?'live':'idle'}</td></tr>`).join('');
document.getElementById('foot').textContent=
  `Source: ~/.claude/history.jsonl (typed prompts only — model-auto-invoked skills not counted), `+
  `settings.json hook wiring, hook file mtimes. Generated ${D.span[1]}.`;
</script></body></html>
"""


def render(data, top_n):
    data = dict(data, topN=top_n)
    blob = json.dumps(data)
    # Guard against </script> breaking out of the embedding script tag.
    blob = blob.replace("</", "<\\/")
    return TEMPLATE.replace("__DATA__", blob)


def main():
    ap = argparse.ArgumentParser(description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("-o", "--out", default="/tmp/hot.htm", help="output HTML path")
    ap.add_argument("--top", type=int, default=18, help="top N commands to chart")
    ap.add_argument("--days", type=int, default=30, help="'hottest' window in days")
    ap.add_argument("--open", action="store_true", help="open report after writing")
    ap.add_argument("--json", action="store_true", help="print raw JSON, skip HTML")
    args = ap.parse_args()

    data = analyze(args.days)

    if args.json:
        json.dump(data, sys.stdout, indent=1)
        print()
        return

    out = os.path.expanduser(args.out)
    with open(out, "w") as f:
        f.write(render(data, args.top))

    top3 = ", ".join(f"/{t['cmd']} ({t['n']})" for t in data["top"][:3])
    print(f"wrote {out}")
    print(f"  {data['slash']:,} slash invocations across {data['total']:,} prompts "
          f"({data['span'][0]} to {data['span'][1]})")
    print(f"  top: {top3}")
    print(f"  hooks: {sum(h['wired'] for h in data['hooks'])} wired / "
          f"{len(data['hooks'])} on disk")

    if args.open:
        opener = "open" if sys.platform == "darwin" else "xdg-open"
        subprocess.run([opener, out])


if __name__ == "__main__":
    main()
