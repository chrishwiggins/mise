#!/usr/bin/env python3
"""md-ner: deterministic named-entity extractor for Markdown. No AI.

Strategy (rule-based, no models):
  1. Strip Markdown structure (code blocks, links, emphasis, headers) so
     punctuation and formatting don't pollute tokens.
  2. Find candidate entities as runs of Capitalized tokens (optionally joined
     by small connectors like "of", "and", "the", "&") plus all-caps acronyms.
  3. Drop candidates that are merely sentence-initial common words, pure
     stopwords, or known non-entities.
  4. Classify each surviving candidate into PERSON / ORG / PRODUCT / PLACE /
     MISC using gazetteers and lightweight suffix/context cues.

Usage:
    ner.py FILE.md                 # pretty grouped output
    cat FILE.md | ner.py           # read stdin
    ner.py FILE.md --format jsonl  # one JSON object per entity
    ner.py FILE.md --format tsv    # type<TAB>text<TAB>count
    ner.py FILE.md --min-count 2   # only entities seen >=2 times
"""

import argparse
import json
import re
import sys
from collections import Counter

# ----------------------------------------------------------------------------
# 1. Markdown stripping
# ----------------------------------------------------------------------------

def strip_markdown(text):
    """Remove Markdown syntax, keeping human-readable text intact."""
    # Fenced code blocks ```...```
    text = re.sub(r"```.*?```", " ", text, flags=re.DOTALL)
    # Inline code `...`
    text = re.sub(r"`[^`]*`", " ", text)
    # Images ![alt](url) -> drop entirely
    text = re.sub(r"!\[[^\]]*\]\([^)]*\)", " ", text)
    # Links [text](url) -> keep text
    text = re.sub(r"\[([^\]]*)\]\([^)]*\)", r"\1", text)
    # Reference links [text][ref] -> keep text
    text = re.sub(r"\[([^\]]*)\]\[[^\]]*\]", r"\1", text)
    # Bare URLs -> drop
    text = re.sub(r"https?://\S+", " ", text)
    # Headers, blockquote, list markers at line start
    text = re.sub(r"(?m)^\s{0,3}#{1,6}\s*", "", text)
    text = re.sub(r"(?m)^\s*>\s?", "", text)
    text = re.sub(r"(?m)^\s*[-*+]\s+", "", text)
    text = re.sub(r"(?m)^\s*\d+\.\s+", "", text)
    # Emphasis/bold markers (leave the words)
    text = text.replace("**", " ").replace("__", " ")
    text = re.sub(r"(?<!\w)[*_](?=\w)", " ", text)
    text = re.sub(r"(?<=\w)[*_](?!\w)", " ", text)
    # Table pipes
    text = text.replace("|", " ")
    return text


# ----------------------------------------------------------------------------
# 2. Gazetteers and lexicons
# ----------------------------------------------------------------------------

# Lowercase connectors allowed *inside* a multi-word entity.
CONNECTORS = {"of", "and", "the", "for", "de", "la", "le", "van", "von",
              "der", "den", "di", "da", "el", "al", "&"}

# Months / days / date-ish words: not entities.
TEMPORAL = {
    "January", "February", "March", "April", "May", "June", "July", "August",
    "September", "October", "November", "December",
    "Jan", "Feb", "Mar", "Apr", "Jun", "Jul", "Aug", "Sep", "Sept", "Oct",
    "Nov", "Dec",
    "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday",
}

# Words that look capitalized at sentence start but are not entities.
COMMON_WORDS = {
    "The", "This", "That", "These", "Those", "There", "Their", "They", "Them",
    "It", "Its", "He", "She", "His", "Her", "We", "Our", "You", "Your", "I",
    "A", "An", "As", "At", "By", "But", "And", "Or", "Nor", "For", "So", "Yet",
    "If", "When", "While", "Where", "Why", "How", "What", "Which", "Who", "Whom",
    "In", "On", "Of", "To", "From", "With", "Without", "Into", "Onto", "Over",
    "Under", "After", "Before", "During", "Between", "Among", "Through",
    "Detection", "Provenance", "Tools", "Tool", "Vendor", "Real", "Neither",
    "Forensic", "Adopted", "Reports", "Offers", "Most", "Some", "Many", "All",
    "Each", "Every", "Both", "Either", "Such", "No", "Not", "Yes", "Here",
