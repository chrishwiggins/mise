    "Case Western", "Coalition", "Adobe", "Google", "Microsoft", "OpenAI",
    "Meta", "Anthropic",
}

# Org-name suffix cues: if a candidate ends in one of these, call it ORG.
ORG_SUFFIXES = {
    "Inc", "Inc.", "LLC", "Ltd", "Ltd.", "Corp", "Corp.", "Co", "Co.",
    "Company", "Foundation", "Institute", "University", "College", "School",
    "Lab", "Labs", "Laboratory", "Agency", "Bureau", "Department", "Group",
