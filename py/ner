ORGS = {
    "Reuters", "Reuters Institute", "WITNESS", "Stanford", "FBI", "AFP",
    "AP", "Associated Press", "Snopes", "PolitiFact", "Full Fact",
    "The Dispatch", "Sports Illustrated", "Cody Enterprise", "Nikon",
