PLACES = {
    "Baltimore", "Slovak", "Slovakia", "Pikesville", "Stanford", "Hollywood",
    "America", "American", "U.S.", "US", "USA", "United States", "Europe",
    "European", "China", "Chinese", "Russia", "Russian", "Ukraine", "London",
    "Paris", "Berlin", "Washington", "California", "New York", "Texas",
    "Cody", "Wyoming", "Helene",
