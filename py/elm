# Main
# ---------------------------------------------------------------------------

def main():
    import argparse
    parser = argparse.ArgumentParser(
        description="elm - Gmail TUI with classic elm 2.5 aesthetics",
    )
    parser.add_argument("-e", "--email", default=None,
                        help="Account email or alias (same as gmails -e)")
    parser.add_argument("-n", "--count", type=int, default=20,
                        help="Number of messages to load (default: 20)")
    parser.add_argument("-q", "--query", default=None,
                        help="Initial Gmail search query (e.g., 'is:unread')")
    args = parser.parse_args()

    app = ElmApp(account=args.email, count=args.count, query=args.query)
    try:
        curses.wrapper(app.run)
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
