#!/usr/bin/python3

import os
import shutil
import re
import sys
from datetime import datetime


def backup_and_replace_tex_files(directory):
    # Generate a timestamp (datestr)
    datestr = datetime.now().strftime("%Y_%m_%dT%Hh%Mm%Ss")
    backup_dir = f"/tmp/{datestr}"
    os.makedirs(backup_dir, exist_ok=True)
    print(f"Backup directory created: {backup_dir}")

    # Process each .tex file in the given directory
    for root, _, files in os.walk(directory):
        for file in files:
            if file.endswith(".tex"):
                file_path = os.path.join(root, file)
                print(f"Processing: {file_path}")

                # Backup the original file
                backup_path = os.path.join(
                    backup_dir, os.path.relpath(file_path, directory)
                )
                os.makedirs(os.path.dirname(backup_path), exist_ok=True)
                shutil.copy(file_path, backup_path)
                print(f"Backup created: {backup_path}")

                # Read the file, perform replacement, and write back
                with open(file_path, "r") as f:
                    content = f.read()

                # Replace all double-quoted strings with LaTeX-style quotes
                updated_content = re.sub(r'"(.*?)"', r"``\1\"", content)

                with open(file_path, "w") as f:
                    f.write(updated_content)
                print(f"Updated: {file_path}")


if __name__ == "__main__":
    # Check for directory argument, default to current working directory
    directory_to_process = sys.argv[1] if len(sys.argv) > 1 else "."
    if os.path.isdir(directory_to_process):
        print(f"Processing .tex files in: {directory_to_process}")
        backup_and_replace_tex_files(directory_to_process)
    else:
        print("Invalid directory. Please provide a valid path.")
