#!/usr/bin/python3

import pickle
import os
from google_auth_oauthlib.flow import InstalledAppFlow
from googleapiclient.discovery import build
from google.auth.transport.requests import Request
import sys
import argparse
import platform
import webbrowser
import re

# Setup argument parser
parser = argparse.ArgumentParser(
    description="Download Google Doc and save as Markdown."
)
parser.add_argument("-i", "--id", required=True, help="Google Document ID or full URL")
parser.add_argument("-f", "--file", required=True, help="Path to credentials.json file")
parser.add_argument("-o", "--output", required=True, help="Output markdown filename")

args = parser.parse_args()

# Extract document ID from URL if full URL is provided
doc_input = args.id
if "docs.google.com" in doc_input:
    match = re.search(r"/d/([a-zA-Z0-9-_]+)", doc_input)
    if match:
        document_id = match.group(1)
    else:
        print("Error: Could not extract document ID from URL")
        sys.exit(1)
else:
    document_id = doc_input

credentials_file = args.file
output_file = args.output

google_credentials_url = "https://console.cloud.google.com/apis/credentials"

# Check if credentials file exists
if not os.path.exists(credentials_file):
    print(
        f"Error: '{credentials_file}' not found. Please download it from {google_credentials_url}"
    )
    print(f"Visit: {google_credentials_url}")

    if platform.system() == "Darwin":
        print("Opening the URL on macOS...")
        webbrowser.open(google_credentials_url)
    else:
        print("Please manually open the URL in your browser.")

    sys.exit(1)

# Load credentials
creds = None

if os.path.exists("token.pickle"):
    with open("token.pickle", "rb") as token:
        creds = pickle.load(token)

if not creds or not creds.valid:
    if creds and creds.expired and creds.refresh_token:
        creds.refresh(Request())
    else:
        flow = InstalledAppFlow.from_client_secrets_file(
            credentials_file, ["https://www.googleapis.com/auth/documents.readonly"]
        )
        creds = flow.run_local_server(port=8080)

        with open("token.pickle", "wb") as token:
            pickle.dump(creds, token)

# Build the Google Docs API service
service = build("docs", "v1", credentials=creds)

# Get the document
document = service.documents().get(documentId=document_id).execute()


# Extract text content and convert to markdown
def convert_to_markdown(document):
    """Convert Google Docs document structure to markdown"""
    content = document.get("body").get("content")
    markdown_lines = []

    for element in content:
        if "paragraph" in element:
            paragraph = element.get("paragraph")
            elements = paragraph.get("elements", [])

            # Get paragraph style
            para_style = paragraph.get("paragraphStyle", {})
            named_style = para_style.get("namedStyleType", "NORMAL_TEXT")

            # Build the text from elements
            text_parts = []
            for elem in elements:
                if "textRun" in elem:
                    text_run = elem.get("textRun")
                    content_text = text_run.get("content", "")
                    text_style = text_run.get("textStyle", {})

                    # Apply text formatting
                    if text_style.get("bold"):
                        content_text = f"**{content_text}**"
                    if text_style.get("italic"):
                        content_text = f"*{content_text}*"

                    text_parts.append(content_text)

            line_text = "".join(text_parts)

            # Apply paragraph-level formatting
            if named_style == "TITLE":
                line_text = f"# {line_text}"
            elif named_style == "HEADING_1":
                line_text = f"# {line_text}"
            elif named_style == "HEADING_2":
                line_text = f"## {line_text}"
            elif named_style == "HEADING_3":
                line_text = f"### {line_text}"
            elif named_style == "HEADING_4":
                line_text = f"#### {line_text}"
            elif named_style == "HEADING_5":
                line_text = f"##### {line_text}"
            elif named_style == "HEADING_6":
                line_text = f"###### {line_text}"

            markdown_lines.append(line_text)

        elif "table" in element:
            # Simple table handling
            table = element.get("table")
            for row in table.get("tableRows", []):
                cells = []
                for cell in row.get("tableCells", []):
                    cell_content = []
                    for cell_elem in cell.get("content", []):
                        if "paragraph" in cell_elem:
                            para_elements = cell_elem.get("paragraph", {}).get(
                                "elements", []
                            )
                            for elem in para_elements:
                                if "textRun" in elem:
                                    cell_content.append(
                                        elem.get("textRun", {}).get("content", "")
                                    )
                    cells.append("".join(cell_content).strip())
                markdown_lines.append("| " + " | ".join(cells) + " |")

    return "".join(markdown_lines)


markdown_content = convert_to_markdown(document)

# Save to file
with open(output_file, "w") as f:
    f.write(markdown_content)

print(f"Document downloaded as {output_file}")
