_contacts_path = _config_get("contacts_file", env_var="GMAILS_CONTACTS_FILE")
CONTACTS_FILE = Path(_contacts_path).expanduser() if _contacts_path else None


def resolve_recipient(addr):
    """Resolve a partial name/email to a full email address via contacts file.

    If addr already contains '@' and a '.', return it as-is.
    Otherwise search the contacts file (semicolon-delimited) for a matching field.
    """
    if "@" in addr and "." in addr.split("@", 1)[1]:
        return addr
    if not CONTACTS_FILE or not CONTACTS_FILE.exists():
        return addr
    matches = []
    needle = addr.lower()
    with open(CONTACTS_FILE) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            fields = [fld.strip() for fld in line.split(";")]
            # Find email fields (contain @)
            emails = [fld for fld in fields if "@" in fld]
            if not emails:
                continue
            # Check if needle matches any field (substring)
            if any(needle in fld.lower() for fld in fields):
                matches.append((fields, emails))
    if len(matches) == 0:
        print(f"Warning: '{addr}' not found in contacts, using as-is", file=sys.stderr)
        return addr
    if len(matches) == 1:
        chosen = matches[0][1][0]  # first email of the single match
        name_parts = [f for f in matches[0][0] if "@" not in f]
        display = " ".join(name_parts) if name_parts else chosen
        print(f"Resolved: {addr} -> {chosen} ({display})", file=sys.stderr)
        return chosen
    # Multiple matches: try exact field match to disambiguate
    exact = [(fields, emails) for fields, emails in matches
             if any(needle == fld.lower() for fld in fields)]
    if len(exact) == 1:
        chosen = exact[0][1][0]
        name_parts = [f for f in exact[0][0] if "@" not in f]
        display = " ".join(name_parts) if name_parts else chosen
        print(f"Resolved: {addr} -> {chosen} ({display})", file=sys.stderr)
        return chosen
    print(f"Ambiguous: '{addr}' matches {len(matches)} contacts:", file=sys.stderr)
    for fields, emails in matches[:5]:
        print(f"  {';'.join(fields)}", file=sys.stderr)
    print(f"Use a full email address instead.", file=sys.stderr)
    sys.exit(1)


def _resolve_address_list(addrs):
    """Resolve each address in a comma-separated list through contacts.

    Uses getaddresses so quoted display names with commas (e.g.
    '"Ghani, Tarek" <t@ex.com>') parse correctly. Entries already
    carrying a full email pass through; bare names go through contacts.
    """
    if not addrs:
        return addrs
    result = []
    for name, addr in getaddresses([addrs]):
        if not name and not addr:
            continue
        if addr and "@" in addr and "." in addr.split("@", 1)[1]:
            result.append(formataddr((name, addr)) if name else addr)
        else:
            result.append(resolve_recipient(addr or name))
    return ", ".join(result)


