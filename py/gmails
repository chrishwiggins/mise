def _resolve_message_id(service, index, count, query, account=None,
                        verify=False):
    """Resolve a 1-based index to a Gmail message ID, using cache when safe.

    If verify=True, confirm the cached ID is accessible via messages.get
    before returning it. Falls back to a fresh list on 404.
    """
    # Try cache first (!! workflow: same count+query+account means same list)
    cached = _load_cached_ids(count, query, account=account)
    if cached and 1 <= index <= len(cached):
        msg_id = cached[index - 1]["id"]
        if verify:
            try:
                service.users().messages().get(
                    userId="me", id=msg_id, format="minimal"
                ).execute()
            except Exception:
                print(f"Cached message {msg_id} not accessible, refreshing list...",
                      file=sys.stderr)
                cached = None  # fall through to fresh list
        if cached:
            return msg_id

    # Cache miss or stale: fetch fresh
    if _cache_path(account).exists():
        print(f"Cache miss (query={query!r}); re-fetching message list", file=sys.stderr)
    kwargs = {"userId": "me", "maxResults": count}
    if query:
        kwargs["q"] = query
    result = service.users().messages().list(**kwargs).execute()
    messages = result.get("messages", [])

    if not messages:
        print("No messages found.", file=sys.stderr)
        sys.exit(1)

    if index < 1 or index > len(messages):
        print(f"Index {index} out of range (1-{len(messages)}).", file=sys.stderr)
        sys.exit(1)

    # Update cache
    _cache_message_ids(messages, count, query, account=account)
    return messages[index - 1]["id"]


def do_get(service, index, count, query, output, stdout=False, text_view=False, account=None, grab=False):
    """Download a message by its 1-based index."""
    msg_id = _resolve_message_id(service, index, count, query, account=account)

    raw_msg = service.users().messages().get(
        userId="me", id=msg_id, format="raw"
    ).execute()
    raw_bytes = base64.urlsafe_b64decode(raw_msg["raw"])

    # -t flag: extract and print text body (with HTML fallback)
    if text_view:
        msg = email.message_from_bytes(raw_bytes, policy=email.policy.default)
        sender = msg.get("From", "unknown")
        to = msg.get("To", "")
        cc = msg.get("Cc", "")
        subject = msg.get("Subject", "(no subject)")
        date = msg.get("Date", "")
        print(f"From: {sender}", file=sys.stderr)
        if to:
            print(f"To: {to}", file=sys.stderr)
        if cc:
            print(f"Cc: {cc}", file=sys.stderr)
        print(f"Date: {date}", file=sys.stderr)
        print(f"Subject: {subject}", file=sys.stderr)
        print("---", file=sys.stderr)
        body_text = extract_text_body(raw_bytes)
        print(body_text)
        if grab:
            # -peek -t: save .eml and copy /peek path (so Claude can ingest it)
            spool = Path("/tmp/spool")
            spool.mkdir(exist_ok=True)
            output_path = versioned_path(spool / generate_filename(raw_bytes))
            output_path.write_bytes(raw_bytes)
            peek_cmd = f"/peek {output_path}"
            subprocess.run(["pbcopy"], input=peek_cmd.encode(), check=True)
            print(f"Saved: {output_path}", file=sys.stderr)
            print(f"Copied to clipboard: {peek_cmd}", file=sys.stderr)
        return

    # -S flag: raw to stdout for piping
    if stdout:
        sys.stdout.buffer.write(raw_bytes)
        return

    # Determine output path
    if output is None:
        # No output arg: save to /tmp/spool (a la /var/spool/mail)
        spool = Path("/tmp/spool")
        spool.mkdir(exist_ok=True)
        output_path = spool / generate_filename(raw_bytes)
    else:
        output_path = Path(output)
        if output_path.is_dir():
            output_path = output_path / generate_filename(raw_bytes)

    # Version existing file instead of erroring
    output_path = versioned_path(output_path)

    output_path.write_bytes(raw_bytes)

    msg = email.message_from_bytes(raw_bytes, policy=email.policy.default)
    sender = msg.get("From", "unknown")
    subject = msg.get("Subject", "(no subject)")

    attachments = save_attachments(raw_bytes, output_path.parent)

    att_note = f" + {len(attachments)} attachment(s)" if attachments else ""
    print(f"Saved: {output_path} (From: {sender}, Subject: {subject}){att_note}", file=sys.stderr)

    if grab:
        peek_cmd = f"/peek {output_path}"
        subprocess.run(["pbcopy"], input=peek_cmd.encode(), check=True)
        print(f"Copied to clipboard: {peek_cmd}", file=sys.stderr)


# ---------------------------------------------------------------------------
# Reply mode
# ---------------------------------------------------------------------------

def do_reply(service, index, count, query, args, as_draft=False, account=None,
             sent=False):
    """Download message by index, extract headers, open $EDITOR for reply."""
    msg_id = _resolve_message_id(service, index, count, query, account=account,
                                 verify=True)
    raw_msg = service.users().messages().get(
        userId="me", id=msg_id, format="raw"
    ).execute()
    raw_bytes = base64.urlsafe_b64decode(raw_msg["raw"])
    msg = email.message_from_bytes(raw_bytes, policy=email.policy.default)

    # Extract headers for reply
    orig_from = msg.get("From", "")
    orig_to = msg.get("To", "")
    orig_subject = msg.get("Subject", "")
    orig_msg_id = msg.get("Message-ID", "")
    orig_references = msg.get("References", "")
    orig_date = msg.get("Date", "")

    # Replying to our own sent message: reply target is the original To:, not From:
    is_sent = sent
    if is_sent:
        # First To: recipient becomes the reply target
        to_addrs = getaddresses([orig_to]) if orig_to else []
        reply_addr = to_addrs[0][1] if to_addrs else ""
        if not reply_addr:
            print("Cannot reply to sent message: no To: address found", file=sys.stderr)
            sys.exit(1)
    else:
        # Reply-To takes precedence over From
        reply_to = msg.get("Reply-To", orig_from)
        _, reply_addr = parseaddr(reply_to)

    # Collect all known self-addresses for exclusion from Cc
    self_addrs = set()
    if account:
        self_addrs.add(account.lower())
    # Also load all configured account emails
    if ACCOUNTS_FILE.exists():
        with open(ACCOUNTS_FILE) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                acct_email = line.split(None, 1)[0]
                if "@" in acct_email:
                    self_addrs.add(acct_email.lower())

    # Reply-all: collect To and Cc, excluding self and reply_addr
    reply_all = getattr(args, 'all', False)
    cc_addrs = ""
    if reply_all:
        all_recipients = set()
        for hdr_name in ("To", "Cc"):
            hdr_val = msg.get(hdr_name, "")
            if hdr_val:
                for _, addr in getaddresses([hdr_val]):
                    if not addr:
                        continue
                    addr_lower = addr.lower()
                    if addr_lower == reply_addr.lower():
                        continue
                    if addr_lower in self_addrs:
                        continue
                    all_recipients.add(addr)
        if all_recipients:
            cc_addrs = ", ".join(sorted(all_recipients))

    # Build Re: subject
    re_subject = orig_subject
    if not re_subject.lower().startswith("re:"):
        re_subject = f"Re: {orig_subject}"

    # Build References chain
    refs = orig_references
    if orig_msg_id:
        refs = f"{refs} {orig_msg_id}".strip()

    # Quote original body (uses extract_text_body which handles HTML fallback)
    orig_body = extract_text_body(raw_bytes)

    _, orig_name = parseaddr(orig_from)
    quoted = "\n".join(f"> {line}" for line in orig_body.splitlines())
    template = f"\n\nOn {orig_date}, {orig_name} wrote:\n{quoted}\n"

    # Stdin body or interactive editor
    if not sys.stdin.isatty():
        stdin_body = sys.stdin.read().strip()
        if not stdin_body:
            # No actual reply content piped in; save as draft to prevent accidental sends
            print("No body on stdin, saving as draft instead of sending.", file=sys.stderr)
            as_draft = True
        body = (stdin_body + "\n" if stdin_body else "") + template
    else:
        editor = os.environ.get("EDITOR", "vim")
        with tempfile.NamedTemporaryFile(suffix=".txt", mode="w", delete=False) as f:
            f.write(template)
            tmpfile = f.name
        try:
            subprocess.call([editor, tmpfile])
            body = Path(tmpfile).read_text()
        finally:
            os.unlink(tmpfile)

    if not body.strip():
        print("Empty body, aborting.", file=sys.stderr)
        sys.exit(1)

    # Confirm before sending (skip for drafts)
    if not as_draft and sys.stdin.isatty():
        if account:
            print(f"\nFrom: {account}", file=sys.stderr)
        print(f"To: {reply_addr}", file=sys.stderr)
        if cc_addrs:
            print(f"Cc: {cc_addrs}", file=sys.stderr)
        print(f"Subject: {re_subject}", file=sys.stderr)
        print(f"Body length: {len(body.strip())} chars", file=sys.stderr)
        try:
            answer = input("Send this reply? [y/N] ")
        except (EOFError, KeyboardInterrupt):
            answer = ""
        if answer.strip().lower() != "y":
            print("Aborted.", file=sys.stderr)
            sys.exit(1)

    # Build reply message
    reply = MIMEText(body, "plain", "utf-8")
    reply["To"] = reply_addr
    if cc_addrs:
        reply["Cc"] = cc_addrs
    reply["Subject"] = re_subject
    if orig_msg_id:
        reply["In-Reply-To"] = orig_msg_id
    if refs:
        reply["References"] = refs

    reply = _attach_files(reply, getattr(args, 'attach', None))
    raw_reply = base64.urlsafe_b64encode(reply.as_bytes()).decode()

    if as_draft:
        result = service.users().drafts().create(
            userId="me", body={"message": {"raw": raw_reply}}
        ).execute()
        print(f"Draft reply saved: To={reply_addr} Subject={re_subject} id={result.get('id', '?')}", file=sys.stderr)
    else:
        result = service.users().messages().send(
            userId="me", body={"raw": raw_reply}
        ).execute()
        print(f"Sent reply: To={reply_addr} Subject={re_subject} id={result.get('id', '?')}", file=sys.stderr)


