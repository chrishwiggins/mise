def main():
    # Strip -peek / --peek (and legacy -grab / --grab) from argv before any parsing
    peek_flags = {"-peek", "--peek", "-grab", "--grab"}
    grab_mode = bool(peek_flags & set(sys.argv))
    sys.argv = [a for a in sys.argv if a not in peek_flags]

    # Detect "sent" modifier: strip from argv, set flag for query building.
    # Skips flag values so -q "from:sent" doesn't false-match.
    sent_mode = False
    filtered = [sys.argv[0]]
    _skip = False
    for _a in sys.argv[1:]:
        if _skip:
            filtered.append(_a)
            _skip = False
            continue
        if _a in ("-F", "--config", "-e", "--email", "-n", "--count", "-q", "--query"):
            filtered.append(_a)
            _skip = True
            continue
        if _a == "sent":
            sent_mode = True
            continue
        filtered.append(_a)
    sys.argv = filtered

    # Top-level help: show comprehensive usage for all modes
    if len(sys.argv) < 2 or (
        sys.argv[1] in ("-h", "--help") and
        not (len(sys.argv) > 2 and sys.argv[2] in ("send", "draft", "reply"))
    ):
        if "-h" in sys.argv or "--help" in sys.argv:
            print(FULL_HELP)
            sys.exit(0)

    # -E: list configured accounts and exit
    if "-E" in sys.argv or "--list-accounts" in sys.argv:
        do_list_accounts()

    # Detect mode: find "send", "draft", or "reply" anywhere in argv (skipping flag values)
    mode = None
    rest = sys.argv[1:]
    mode_index = None
    skip_next = False
    for i, arg in enumerate(rest):
        if skip_next:
            skip_next = False
            continue
        if arg in ("-F", "--config", "-e", "--email", "-n", "--count", "-q", "--query"):
            skip_next = True  # next arg is the flag's value
            continue
        if arg in ("send", "draft", "reply", "fwd", "trash", "archive", "open", "thread", "read", "unread"):
            mode = arg
            mode_index = i
            break
        if arg.startswith("-"):
            continue
        break  # hit a positional arg that isn't send/draft/reply

    if mode:
        # Rearrange so parse_send_draft_args sees: [mode, ...flags..., ...args...]
        # Move common flags from before the mode into the post-mode args
        pre = rest[:mode_index]
        post = rest[mode_index:]  # starts with "send"/"draft"
        rest = [post[0]] + pre + post[1:]

    if mode in ("send", "draft"):
        args = parse_send_draft_args(rest)
        token_name, login_hint = resolve_account(args.config, args.email, "gmail-send")
        if args.show_account:
            print(login_hint or "(default account)")
            sys.exit(0)
        creds = get_credentials(service="gmail", scopes="gmail-send",
                                token_name=token_name, login_hint=login_hint)
        service = build("gmail", "v1", credentials=creds)
        if mode == "send":
            do_send(service, args, from_addr=login_hint)
        else:
            do_draft(service, args, from_addr=login_hint)
    elif mode == "reply":
        # reply needs both readonly (to fetch) and compose (to send)
        reply_rest = [a for a in rest if a != "reply"]
        args = parse_list_get_args(reply_rest)
        if args.index is None:
            print("Usage: gmails reply INDEX (e.g., gmails reply 3)", file=sys.stderr)
            sys.exit(1)
        indices = parse_index_token(args.index)
        if len(indices) > 1:
            print("reply only works with a single message, got "
                  f"{len(indices)} indices: {indices}", file=sys.stderr)
            sys.exit(1)
        reply_idx = indices[0]
        # Apply same query defaults as listing, so cache keys match
        query = args.query
        if sent_mode:
            query = f"in:sent {query}" if query else "in:sent"
        elif not query:
            query = "in:inbox"
        token_name, login_hint = resolve_account(args.config, args.email, "gmail-send")
        if args.show_account:
            print(login_hint or "(default account)")
            sys.exit(0)
        creds = get_credentials(service="gmail", scopes="gmail-send",
                                token_name=token_name, login_hint=login_hint)
        service = build("gmail", "v1", credentials=creds)
        do_reply(service, reply_idx, args.count, query, args,
                 as_draft=args.draft, account=login_hint, sent=sent_mode)
    elif mode == "fwd":
        fwd_rest = [a for a in rest if a != "fwd"]
        args = parse_list_get_args(fwd_rest)
        if args.index is None or args.output is None:
            print("Usage: gmails fwd INDEX RECIPIENT (e.g., gmails fwd 3 user@example.com)", file=sys.stderr)
            sys.exit(1)
        indices = parse_index_token(args.index)
        if len(indices) > 1:
            print("fwd only works with a single message, got "
                  f"{len(indices)} indices: {indices}", file=sys.stderr)
            sys.exit(1)
        fwd_idx = indices[0]
        recipient = args.output  # the "output" positional is the recipient for fwd
        token_name, login_hint = resolve_account(args.config, args.email, "gmail-send")
        if args.show_account:
            print(login_hint or "(default account)")
            sys.exit(0)
        creds = get_credentials(service="gmail", scopes="gmail-send",
                                token_name=token_name, login_hint=login_hint)
        service = build("gmail", "v1", credentials=creds)
        # Apply same query defaults as listing, so cache keys match
        query = args.query
        if sent_mode:
            query = f"in:sent {query}" if query else "in:sent"
        elif not query:
            query = "in:inbox"
        do_forward(service, fwd_idx, args.count, query, recipient,
                   as_draft=args.draft, account=login_hint)
    elif mode in ("trash", "archive", "open", "thread", "read", "unread"):
        mode_rest = [a for a in rest if a != mode]
        indices, filtered_rest = collect_indices(mode_rest)
        args = parse_list_get_args(filtered_rest)
        if not indices:
            print(f"Usage: gmails {mode} INDEX [INDEX ...] (e.g., gmails {mode} 3 or gmails {mode} 1,3-5)",
                  file=sys.stderr)
            sys.exit(1)
        if mode in ("open", "thread") and len(indices) > 1:
            print(f"{mode} only works with a single message, got "
                  f"{len(indices)} indices: {indices}", file=sys.stderr)
            sys.exit(1)
        # trash/archive/read/unread need write access; open and thread only need read
        scope = "gmail-send" if mode in ("trash", "archive", "read", "unread") else "gmail-readonly"
        token_name, login_hint = resolve_account(args.config, args.email, scope)
        if args.show_account:
            print(login_hint or "(default account)")
            sys.exit(0)
        creds = get_credentials(service="gmail", scopes=scope,
                                token_name=token_name, login_hint=login_hint)
        service = build("gmail", "v1", credentials=creds)
        # Apply same query defaults as listing, so cache keys match
        query = args.query
        if sent_mode:
            query = f"in:sent {query}" if query else "in:sent"
        elif not query:
            query = "in:inbox"
        if mode == "trash":
            do_trash(service, indices, args.count, query, account=login_hint)
        elif mode == "archive":
            do_archive(service, indices, args.count, query, account=login_hint)
        elif mode == "read":
            do_mark_read(service, indices, args.count, query, account=login_hint)
        elif mode == "unread":
            do_mark_unread(service, indices, args.count, query, account=login_hint)
        elif mode == "open":
            do_open(service, indices[0], args.count, query, account=login_hint)
        else:
            do_thread(service, indices[0], args.count, query, account=login_hint)
    else:
        args = parse_list_get_args(rest)
        scope = "gmail-readonly"
        token_name, login_hint = resolve_account(args.config, args.email, scope)
        if args.show_account:
            print(login_hint or "(default account)")
            sys.exit(0)
        creds = get_credentials(service="gmail", scopes=scope,
                                token_name=token_name, login_hint=login_hint)
        service = build("gmail", "v1", credentials=creds)
        query = args.query
        if sent_mode:
            query = f"in:sent {query}" if query else "in:sent"
        elif not query:
            query = "in:inbox"
        
        # -peek implies -t (text view) and requires an index
        if grab_mode:
            args.text = True
            if args.index is None:
                print("Warning: -peek requires a message index or range (e.g., gmails 3 -peek)", file=sys.stderr)
                # Fall through to listing, but text_view/grab won't be used
        
        if args.just_count:
            kwargs = {"userId": "me", "maxResults": args.count}
            if query:
                kwargs["q"] = query
            result = service.users().messages().list(**kwargs).execute()
            print(result.get("resultSizeEstimate", 0))
            sys.exit(0)
        if args.index is None:
            do_list(service, args.count, query, account=login_hint,
                    sent=sent_mode, verbose=args.verbose,
                    summary=args.summary,
                    json_output=getattr(args, 'json', False))
        else:
            indices = parse_index_token(args.index)
            for idx in indices:
                do_get(service, idx, args.count, query, args.output,
                       stdout=args.stdout, text_view=args.text, account=login_hint,
                       grab=grab_mode)


if __name__ == "__main__":
    main()
