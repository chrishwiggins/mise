def do_open(service, index, count, query, account=None):
    """Open a message in Gmail web UI, using gmail_web for Chrome profile routing."""
    msg_id = _resolve_message_id(service, index, count, query, account=account)

    chrome_profile = os.environ.get("GMAILS_CHROME_PROFILE")
    if chrome_profile is not None:
        # Route through gmail_web for correct Chrome profile
        import shutil
        gmail_web = shutil.which("gmail_web")
        if gmail_web:
            url = f"https://mail.google.com/mail/u/0/#all/{msg_id}"
            print(f"Opening: {url}", file=sys.stderr)
            subprocess.run([gmail_web, chrome_profile, f"all/{msg_id}"])
            return

    # Fallback: webbrowser.open with authuser (#all works for any folder)
    if account:
        url = f"https://mail.google.com/mail/?authuser={account}#all/{msg_id}"
    else:
        url = f"https://mail.google.com/mail/u/0/#all/{msg_id}"
    print(f"Opening: {url}", file=sys.stderr)
    webbrowser.open(url)


