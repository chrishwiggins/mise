CLAUDE_BIN = os.environ.get("CLAUDE_BIN") or shutil.which("claude")


def _summarize_snippets(snippets):
    """Send snippets to Claude CLI, return list of keyword strings."""
    if not CLAUDE_BIN:
        return None
    numbered = "\n".join(f"{i}. {s}" for i, s in enumerate(snippets, 1))
    prompt = (
        "For each numbered email snippet below, extract 3-5 keywords or a short phrase "
        "(under 10 words) that captures what the email is about. "
        "Return ONLY numbered lines like:\n"
        "1. [keyword, keyword, keyword]\n"
        "2. [keyword, keyword]\n"
        "No other text.\n\n" + numbered
    )
    try:
        env = {k: v for k, v in os.environ.items() if k != "CLAUDECODE"}
        result = subprocess.run(
            [CLAUDE_BIN, "-p", "--model", "haiku", prompt],
            capture_output=True, text=True, timeout=30, env=env,
        )
        if result.returncode != 0:
            return None
        lines = result.stdout.strip().splitlines()
        out = {}
        for line in lines:
            m = re.match(r"(\d+)\.\s*(.*)", line.strip())
            if m:
                out[int(m.group(1))] = m.group(2).strip()
        return out
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return None


def do_list(service, count, query, account=None, sent=False, verbose=False,
            summary=False, json_output=False):
    """List recent messages as a numbered table."""
    kwargs = {"userId": "me", "maxResults": count}
    if query:
        kwargs["q"] = query
    result = service.users().messages().list(**kwargs).execute()
    messages = result.get("messages", [])

    if not messages:
        print("No messages found.", file=sys.stderr)
        sys.exit(0)

    # Cache message IDs for !! workflow safety
    _cache_message_ids(messages, count, query, account=account)

    try:
        term_width = os.get_terminal_size().columns
    except OSError:
        term_width = 80

    # Batch-fetch metadata for all messages (1 HTTP round-trip instead of N)
    fetched = [None] * len(messages)

    def _make_callback(idx):
        def _cb(req_id, response, exception):
            if exception is None:
                fetched[idx] = response
        return _cb

    batch = service.new_batch_http_request()
    for i, msg_stub in enumerate(messages):
        batch.add(
            service.users().messages().get(
                userId="me",
                id=msg_stub["id"],
                format="metadata",
                metadataHeaders=["From", "To", "Subject", "Date"] if sent else ["From", "Subject", "Date"],
            ),
            callback=_make_callback(i),
        )
    batch.execute()

    # --json: structured output for TUI/scripting consumers
    if json_output:
        out = []
        for i, msg in enumerate(fetched, 1):
            if msg is None:
                out.append({"index": i, "error": True})
                continue
            headers = msg.get("payload", {}).get("headers", [])
            unread = "UNREAD" in msg.get("labelIds", [])
            if sent:
                person = parse_recipient(get_header(headers, "To"))
            else:
                person = parse_sender(get_header(headers, "From"))
            att_count = _count_attachments_payload(msg.get("payload", {}))
            out.append({
                "index": i,
                "id": msg["id"],
                "threadId": msg.get("threadId", ""),
                "unread": unread,
                "date": parse_date(get_header(headers, "Date")),
                "from": person,
                "from_full": get_header(headers, "From") if not sent else get_header(headers, "To"),
                "subject": get_header(headers, "Subject") or "(no subject)",
                "hasAttachment": att_count > 0,
                "attachmentCount": att_count,
            })
        print(json.dumps(out))
        return

    idx_width = len(str(len(messages)))
    from_width = 25
    # +2 for unread marker "* " or "  "
    fixed_width = idx_width + 1 + 2 + 10 + 2 + from_width + 2
    subj_width = max(term_width - fixed_width, 10)

    # If --summary, collect snippets and call Claude before printing
    keywords = None
    if summary:
        raw_snippets = []
        for msg in fetched:
            if msg is None:
                raw_snippets.append("")
            else:
                raw_snippets.append(
                    html_mod.unescape(msg.get("snippet", ""))
                    + " [Subject: "
                    + (get_header(msg.get("payload", {}).get("headers", []), "Subject") or "")
                    + "]"
                )
        print("  (summarizing...)", file=sys.stderr, end="\r")
        keywords = _summarize_snippets(raw_snippets)
        print("                  ", file=sys.stderr, end="\r")

    # Tee printed output to a buffer so we can cache the rendered listing.
    # Only the default inbox shape is cached (see condition below).
    cache_buf = []
    def emit(line=""):
        print(line)
        cache_buf.append(line)

    unread_count = 0
    for i, msg in enumerate(fetched, 1):
        if msg is None:
            emit(f"{i:>{idx_width}}.  (fetch error)")
            continue

        headers = msg.get("payload", {}).get("headers", [])
        date_str = parse_date(get_header(headers, "Date"))
        if sent:
            person = parse_recipient(get_header(headers, "To"))
        else:
            person = parse_sender(get_header(headers, "From"))
        subject = get_header(headers, "Subject") or "(no subject)"
        unread = "UNREAD" in msg.get("labelIds", [])
        if unread:
            unread_count += 1

        if len(person) > from_width:
            person = person[: from_width - 1] + "\u2026"
        if len(subject) > subj_width:
            subject = subject[: subj_width - 1] + "\u2026"

        marker = "*" if unread else " "
        emit(f"{i:>{idx_width}}.{marker}{date_str}  {person:<{from_width}}  {subject}")

        if summary and keywords and i in keywords:
            emit(f"{'':{idx_width + 3}}{keywords[i]}")
        elif verbose:
            snippet = html_mod.unescape(msg.get("snippet", ""))
            if snippet:
                snippet_width = term_width - idx_width - 3
                if len(snippet) > snippet_width:
                    snippet = snippet[: snippet_width - 3] + "..."
                emit(f"{'':{idx_width + 3}}{snippet}")

    # Enhancement 5: summary line (stderr; not cached so warm replays don't lie)
    if unread_count:
        print(f"  ({unread_count} unread / {len(messages)} shown)", file=sys.stderr)

    # Cache the rendered listing for the default inbox shape only.
    # m's bash dispatcher reads this and skips the round-trip when fresh.
    is_default_shape = (
        not sent
        and not verbose
        and not summary
        and not json_output
        and count == 20
        and (query is None or query == "in:inbox")
    )
    if is_default_shape:
        try:
            CACHE_DIR.mkdir(exist_ok=True)
            path = _listing_cache_path(account)
            tmp = path.with_suffix(path.suffix + ".tmp")
            tmp.write_text("\n".join(cache_buf) + ("\n" if cache_buf else ""))
            os.replace(tmp, path)
        except OSError:
            pass


