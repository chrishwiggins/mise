def _attach_files(msg, attachments):
    """Add file attachments to an email message, converting to multipart if needed."""
    if not attachments:
        return msg
    # Always wrap in multipart/mixed for attachments.
    # If msg is already multipart/alternative (text+html), nest it inside mixed.
    if msg.is_multipart():
        mixed = MIMEMultipart("mixed")
        for key in ("To", "From", "Subject", "Cc", "Bcc", "Reply-To",
                     "In-Reply-To", "References", "Date", "Message-ID"):
            val = msg.get(key)
            if val:
                mixed[key] = val
                del msg[key]
        mixed.attach(msg)
        msg = mixed
    else:
        original = msg
        msg = MIMEMultipart("mixed")
        # Preserve headers from the original
        for key in ("To", "From", "Subject", "Cc", "Bcc", "Reply-To",
                     "In-Reply-To", "References", "Date", "Message-ID"):
            val = original.get(key)
            if val:
                msg[key] = val
        # Move body to a text part
        body = original.get_payload(decode=True)
        charset = original.get_content_charset() or "utf-8"
        msg.attach(MIMEText(body.decode(charset), original.get_content_subtype(), charset))
    for att_path in attachments:
        p = Path(att_path)
        ctype, _ = mimetypes.guess_type(str(p))
        if ctype is None:
            ctype = "application/octet-stream"
        maintype, subtype = ctype.split("/", 1)
        with open(p, "rb") as f:
            part = MIMEBase(maintype, subtype)
            part.set_payload(f.read())
        email.encoders.encode_base64(part)
        part.add_header("Content-Disposition", "attachment", filename=p.name)
        msg.attach(part)
    return msg


def _build_raw_bytes(args, from_addr=None):
    """Build raw email bytes from send/draft args. Shared by do_send and do_draft."""
    if args.attach:
        for att in args.attach:
            if not Path(att).exists():
                print(f"Attachment not found: {att}", file=sys.stderr)
                sys.exit(1)
    if args.header_file:
        if not Path(args.header_file).exists():
            print(f"Header file not found: {args.header_file}", file=sys.stderr)
            sys.exit(1)
        if args.subject:
            print(f"Warning: -s '{args.subject}' ignored (-H .eml file has its own Subject)",
                  file=sys.stderr)
        raw_bytes = Path(args.header_file).read_bytes()
        if not sys.stdin.isatty():
            body = sys.stdin.read()
            if body.strip():
                raw_bytes = raw_bytes.rstrip() + b"\n\n" + body.encode()
        if args.attach:
            msg = email.message_from_bytes(raw_bytes, policy=email.policy.compat32)
            msg = _attach_files(msg, args.attach)
            raw_bytes = msg.as_bytes()
    else:
        if not args.recipient:
            print("Recipient required (or use -H with an .eml file).", file=sys.stderr)
            sys.exit(1)
        if "/" in args.recipient or args.recipient.endswith(".eml"):
            print(f"Warning: '{args.recipient}' looks like a file path, not an email address.",
                  file=sys.stderr)
            print("Did you mean: gmails send -H <file.eml> ?", file=sys.stderr)
            if sys.stdin.isatty():
                try:
                    answer = input("Continue anyway? [y/N] ")
                except (EOFError, KeyboardInterrupt):
                    answer = ""
                if answer.strip().lower() != "y":
                    sys.exit(1)
        args.recipient = resolve_recipient(args.recipient)
        cc = _resolve_address_list(args.cc)
        bcc = _resolve_address_list(args.bcc)
        if sys.stdin.isatty():
            body = get_body_interactive(args.recipient, args.subject)
        else:
            body = sys.stdin.read()
        raw_bytes = build_mime_message(
            args.recipient, args.subject, body,
            cc=cc, bcc=bcc, attachments=args.attach,
            from_addr=from_addr,
        )
    return raw_bytes


def do_send(service, args, from_addr=None):
    """Send a message via Gmail API."""
    is_preview = getattr(args, 'text', False)
    if not is_preview and not getattr(args, 'via_send', False):
        print("gmails send is disabled. Use send instead.", file=sys.stderr)
        sys.exit(1)
    raw_bytes = _build_raw_bytes(args, from_addr=from_addr)
    if is_preview:
        print_message_preview(raw_bytes)
        return
    encoded = base64.urlsafe_b64encode(raw_bytes).decode()
    result = service.users().messages().send(
        userId="me", body={"raw": encoded}
    ).execute()

    msg = email.message_from_bytes(raw_bytes, policy=email.policy.default)
    frm = msg.get("From") or from_addr or _default_from_email() or "(unknown)"
    to = msg.get("To", "(unknown)")
    cc = msg.get("Cc", "")
    bcc = msg.get("Bcc", "")
    subj = msg.get("Subject", "(no subject)")
    parts = [f"Sent: From={frm} To={to}"]
    if cc:
        parts.append(f"CC={cc}")
    if bcc:
        parts.append(f"Bcc={bcc}")
    parts.append(f"Subject={subj}")
    parts.append(f"id={result.get('id', '?')}")
    print(" ".join(parts), file=sys.stderr)

    if getattr(args, "done", False) and args.header_file:
        abspath = str(Path(args.header_file).resolve())
        clip = f"/sent {abspath}"
        subprocess.run(["pbcopy"], input=clip.encode(), check=True)
        print(f"Copied to clipboard: {clip}", file=sys.stderr)


