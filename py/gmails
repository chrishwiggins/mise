CONFIG_FILE = Path("~/.config/gmails/config").expanduser()


def _load_config():
    """Load optional INI config from ~/.config/gmails/config."""
    cp = configparser.ConfigParser()
    if CONFIG_FILE.exists():
        cp.read(CONFIG_FILE)
    return cp


_CONFIG = _load_config()


def _config_get(key, env_var=None, default=None):
    """Read a config value: env var > config file > default."""
    if env_var:
        val = os.environ.get(env_var)
        if val:
            return val
    try:
        return _CONFIG.get("gmails", key)
    except (configparser.NoSectionError, configparser.NoOptionError):
        return default


