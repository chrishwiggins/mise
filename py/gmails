def parse_team_file(path):
    """Parse a TEAM.md file and return list of (name, email) tuples.

    Looks for H2 headings as names and '- Email:' lines as addresses.
    Also catches bare email-shaped strings on any line as fallback.
    Validates email format and provides clear error messages.
    """
    team = []
    current_name = None
    seen_emails = set()
    email_re = re.compile(r"[\w.+-]+@[\w.-]+\.\w+")
    errors = []
    line_num = 0

    def _validate_email(addr, line_num, context=""):
        """Validate email address and return True if valid."""
        if not addr:
            errors.append(f"Line {line_num}: Empty email address{context}")
            return False
        if not re.match(r"^[\w.+-]+@[\w.-]+\.\w+$", addr):
            errors.append(f"Line {line_num}: Invalid email format '{addr}'{context}")
            return False
        if "@" not in addr or addr.count("@") != 1:
            errors.append(f"Line {line_num}: Email must contain exactly one '@' symbol '{addr}'{context}")
            return False
        local, domain = addr.split("@")
        if not local or not domain:
            errors.append(f"Line {line_num}: Email missing local part or domain '{addr}'{context}")
            return False
        if "." not in domain:
            errors.append(f"Line {line_num}: Email domain must contain a dot '{addr}'{context}")
            return False
        return True

    with open(path) as f:
        for line in f:
            line_num += 1
            line = line.strip()
            if line.startswith("## "):
                current_name = line[3:].strip()
            elif line.lower().startswith("- email:"):
                addr = line.split(":", 1)[1].strip()
                context = f" (under '{current_name}')" if current_name else ""
                if _validate_email(addr, line_num, context) and addr.lower() not in seen_emails:
                    seen_emails.add(addr.lower())
                    team.append((current_name or addr.split("@")[0], addr))
            else:
                # Fallback: bare email on any line
                for m in email_re.finditer(line):
                    addr = m.group()
                    context = f" (under '{current_name}')" if current_name else ""
                    if _validate_email(addr, line_num, context) and addr.lower() not in seen_emails:
                        seen_emails.add(addr.lower())
                        team.append((current_name or addr.split("@")[0], addr))

    if errors:
        print(f"Team file validation errors in {path}:", file=sys.stderr)
        for error in errors:
            print(f"  {error}", file=sys.stderr)
        sys.exit(1)

    return team


def _existing_message_ids(directory):
    """Scan .eml files in a directory and return set of Message-ID values."""
    msg_ids = set()
    dirpath = Path(directory)
    if not dirpath.is_dir():
        return msg_ids
    for eml in dirpath.glob("*.eml"):
        try:
            with open(eml, "rb") as f:
                # Read only first 8KB for Message-ID header (avoid parsing huge emails)
                header_bytes = f.read(8192)
            msg = email.message_from_bytes(header_bytes, policy=email.policy.default)
            mid = msg.get("Message-ID", "").strip()
            if mid:
                msg_ids.add(mid)
        except Exception:
            continue
    return msg_ids


def parse_inbox_args(argv):
    """Parse arguments for inbox mode."""
    parser = argparse.ArgumentParser(
        prog="gmails inbox",
        description="Batch-fetch emails for team members listed in a TEAM.md file.",
    )
    parser.add_argument("team_file", help="Path to TEAM.md (or any file with email addresses)")
    parser.add_argument("-d", "--days", type=int, default=7, help="Days to look back (default: 7)")
    parser.add_argument("-o", "--output", default="eml/inbox", help="Output directory (default: eml/inbox)")
    parser.add_argument("--dry-run", action="store_true", help="List what would be fetched without downloading")
    parser.add_argument("-F", "--config", default=None, help="Muttrc config for account isolation")
    parser.add_argument("-e", "--email", default=None, help="Account email (alternative to -F)")
    parser.add_argument("-Q", "--show-account", action="store_true", help="Show active account and exit")
    parser.add_argument("--resume", action="store_true", help="Resume interrupted download from checkpoint")
    return parser.parse_args(argv)


def _save_inbox_checkpoint(output_path, completed_gmail_ids, team, days):
    """Save progress checkpoint for inbox download."""
    checkpoint_file = output_path / ".inbox_checkpoint.json"
    checkpoint = {
        "completed_gmail_ids": list(completed_gmail_ids),
        "team": team,
        "days": days,
        "timestamp": time.time()
    }
    with open(checkpoint_file, "w") as f:
        json.dump(checkpoint, f)


def _load_inbox_checkpoint(output_path):
    """Load progress checkpoint for inbox download."""
    checkpoint_file = output_path / ".inbox_checkpoint.json"
    if not checkpoint_file.exists():
        return None
    try:
        with open(checkpoint_file) as f:
            checkpoint = json.load(f)
        # Checkpoint expires after 24 hours
        if time.time() - checkpoint["timestamp"] > 86400:
            checkpoint_file.unlink()
            return None
        return checkpoint
    except Exception:
        # Invalid checkpoint, remove it
        try:
            checkpoint_file.unlink()
        except Exception:
            pass
        return None


def _cleanup_inbox_checkpoint(output_path):
    """Remove checkpoint file after successful completion."""
    checkpoint_file = output_path / ".inbox_checkpoint.json"
    try:
        checkpoint_file.unlink()
    except Exception:
        pass


def do_inbox(service, team, days, output_dir, dry_run=False, account=None, resume=False):
    """Batch-fetch emails for team members. Returns manifest dict."""
    output_path = Path(output_dir)
    if not dry_run:
        output_path.mkdir(parents=True, exist_ok=True)

    # Check for existing checkpoint
    checkpoint = None
    completed_gmail_ids = set()
    if resume:
        checkpoint = _load_inbox_checkpoint(output_path)
        if checkpoint:
            print(f"Resuming from checkpoint with {len(checkpoint['completed_gmail_ids'])} completed downloads", file=sys.stderr)
            completed_gmail_ids = set(checkpoint['completed_gmail_ids'])

    # Collect existing Message-IDs for dedup
    existing_ids = _existing_message_ids(output_path)
    print(f"Scanning {len(existing_ids)} existing messages in {output_path}/", file=sys.stderr)

    # Phase 1: Search for each team member, collect unique Gmail message IDs
    all_gmail_ids = {}  # gmail_id -> {metadata, team_members: []}
    total_members = len(team)
    for member_idx, (name, addr) in enumerate(team, 1):
        query = f"(from:{addr} OR to:{addr}) newer_than:{days}d -from:chris.wiggins@gmail.com -from:chris.wiggins.code@gmail.com"
        print(f"[{member_idx}/{total_members}] Searching: {name} <{addr}> ...", file=sys.stderr, end=" ")
        try:
            result = _retry_api_call(lambda: service.users().messages().list(
                userId="me", maxResults=100, q=query
            ).execute())
        except Exception as e:
            print(f"error: {e}", file=sys.stderr)
            continue
        messages = result.get("messages", [])
        print(f"{len(messages)} result(s)", file=sys.stderr)
        for msg_stub in messages:
            gid = msg_stub["id"]
            if gid in all_gmail_ids:
                all_gmail_ids[gid]["team_members"].append(name)
            else:
                all_gmail_ids[gid] = {"id": gid, "team_members": [name]}

    if not all_gmail_ids:
        manifest = {"fetched": 0, "skipped_duplicate": 0, "skipped_existing": 0,
                     "date_range": [], "messages": []}
        print(json.dumps(manifest))
        print("No messages found for any team member.", file=sys.stderr)
        return manifest

    print(f"\n{len(all_gmail_ids)} unique message(s) across all team members", file=sys.stderr)

    # Phase 2: Batch-fetch metadata for all unique messages
    gmail_ids = list(all_gmail_ids.keys())
    fetched_meta = [None] * len(gmail_ids)

    def _make_cb(idx):
        def _cb(req_id, response, exception):
            if exception is None:
                fetched_meta[idx] = response
        return _cb

    # Batch in chunks of 100 (Gmail API limit)
    total_chunks = (len(gmail_ids) + 99) // 100  # ceiling division
    for chunk_idx, chunk_start in enumerate(range(0, len(gmail_ids), 100), 1):
        print(f"Fetching metadata batch {chunk_idx}/{total_chunks} ({chunk_start + 1}-{min(chunk_start + 100, len(gmail_ids))} of {len(gmail_ids)})", file=sys.stderr)
        batch = service.new_batch_http_request()
        chunk = gmail_ids[chunk_start:chunk_start + 100]
        for i, gid in enumerate(chunk):
            batch.add(
                service.users().messages().get(
                    userId="me", id=gid, format="metadata",
                    metadataHeaders=["From", "To", "Cc", "Subject", "Date", "Message-ID"],
                ),
                callback=_make_cb(chunk_start + i),
            )
        _retry_api_call(lambda: batch.execute())

    # Phase 3: Filter out already-downloaded messages, build manifest
    manifest_messages = []
    skipped_existing = 0
    for i, gid in enumerate(gmail_ids):
        meta = fetched_meta[i]
        if meta is None:
            continue
        headers = meta.get("payload", {}).get("headers", [])
        msg_id_header = get_header(headers, "Message-ID").strip()
        if msg_id_header in existing_ids:
            skipped_existing += 1
            continue

        from_hdr = get_header(headers, "From")
        to_hdr = get_header(headers, "To")
        cc_hdr = get_header(headers, "Cc")
        subject = get_header(headers, "Subject") or "(no subject)"
        date_str = parse_date(get_header(headers, "Date"))
        snippet = meta.get("snippet", "")
        att_count = _count_attachments_payload(meta.get("payload", {}))
        team_members = all_gmail_ids[gid]["team_members"]

        entry = {
            "gmail_id": gid,
            "message_id": msg_id_header,
            "from": parse_sender(from_hdr),
            "from_full": from_hdr,
            "to": to_hdr,
            "cc": cc_hdr,
            "date": date_str,
            "subject": subject,
            "snippet": snippet[:200],
            "team_members": sorted(set(team_members)),
            "has_attachment": att_count > 0,
            "attachment_count": att_count,
            "is_new": True,
        }
        manifest_messages.append(entry)

    # Sort by date descending
    manifest_messages.sort(key=lambda m: m["date"], reverse=True)

    print(f"{len(manifest_messages)} new message(s), {skipped_existing} already in {output_path}/",
          file=sys.stderr)

    if dry_run:
        # In dry-run, fill in path as what would be used, but don't download
        for entry in manifest_messages:
            entry["path"] = str(output_path / "(not downloaded)")
        manifest = {
            "fetched": 0,
            "skipped_duplicate": 0,
            "skipped_existing": skipped_existing,
            "dry_run": True,
            "date_range": _date_range(manifest_messages),
            "messages": manifest_messages,
        }
        print(json.dumps(manifest))
        return manifest

    # Phase 4: Download new messages
    total_downloads = len(manifest_messages)
    for download_idx, entry in enumerate(manifest_messages, 1):
        gid = entry["gmail_id"]

        # Skip if already completed in previous run
        if gid in completed_gmail_ids:
            print(f"  [{download_idx}/{total_downloads}] Skipping completed: {entry['subject'][:50]}...", file=sys.stderr)
            entry["path"] = "(already downloaded)"
            continue

        try:
            raw_msg = _retry_api_call(lambda: service.users().messages().get(
                userId="me", id=gid, format="raw"
            ).execute())
            raw_bytes = base64.urlsafe_b64decode(raw_msg["raw"])
            fname = generate_filename(raw_bytes)
            out_file = versioned_path(output_path / fname)
            out_file.write_bytes(raw_bytes)
            entry["path"] = str(out_file)
            save_attachments(raw_bytes, output_path)
            completed_gmail_ids.add(gid)

            # Save checkpoint every 5 downloads
            if download_idx % 5 == 0:
                _save_inbox_checkpoint(output_path, completed_gmail_ids, team, days)

            print(f"  [{download_idx}/{total_downloads}] Saved: {out_file}", file=sys.stderr)
        except Exception as e:
            entry["path"] = None
            entry["error"] = str(e)
            print(f"  Error downloading {entry['subject']}: {e}", file=sys.stderr)

    # Clean up checkpoint on successful completion
    if not dry_run:
        _cleanup_inbox_checkpoint(output_path)

    manifest = {
        "fetched": sum(1 for m in manifest_messages if m.get("path")),
        "skipped_duplicate": 0,
        "skipped_existing": skipped_existing,
        "date_range": _date_range(manifest_messages),
        "messages": manifest_messages,
    }
    print(json.dumps(manifest))
    return manifest


def _date_range(messages):
    """Extract [earliest, latest] date strings from manifest messages."""
    dates = [m["date"] for m in messages if m.get("date", "").strip()]
    if not dates:
        return []
    return [min(dates), max(dates)]


def main():
    # Strip -peek / --peek (and legacy -grab / --grab) from argv before any parsing
    peek_flags = {"-p", "-peek", "--peek", "-grab", "--grab"}
    grab_mode = bool(peek_flags & set(sys.argv))
    sys.argv = [a for a in sys.argv if a not in peek_flags]

    # Strip -w / --web: open Gmail in browser and exit
    web_flags = {"-w", "--web"}
    web_mode = bool(web_flags & set(sys.argv))
    sys.argv = [a for a in sys.argv if a not in web_flags]

    # Detect "sent" modifier: strip from argv, set flag for query building.
    # Skips flag values so -q "from:sent" doesn't false-match.
    sent_mode = False
    filtered = [sys.argv[0]]
    _skip = False
    for _a in sys.argv[1:]:
        if _skip:
            filtered.append(_a)
            _skip = False
            continue
        if _a in ("-F", "--config", "-e", "--email", "-n", "--count", "-q", "--query"):
            filtered.append(_a)
            _skip = True
            continue
        if _a == "sent":
            sent_mode = True
            continue
        filtered.append(_a)
    sys.argv = filtered

    # Top-level help: show comprehensive usage for all modes
    if len(sys.argv) < 2 or (
        sys.argv[1] in ("-h", "--help") and
        not (len(sys.argv) > 2 and sys.argv[2] in ("send", "draft", "reply"))
    ):
        if "-h" in sys.argv or "--help" in sys.argv:
            print(FULL_HELP)
            sys.exit(0)

    # -E: list configured accounts and exit
    if "-E" in sys.argv or "--list-accounts" in sys.argv:
        do_list_accounts()

    # -w: open Gmail in browser and exit (no API call needed)
    if web_mode:
        # Parse just -e from remaining argv to resolve account
        _web_email = None
        _web_argv = sys.argv[1:]
        for _wi, _wa in enumerate(_web_argv):
            if _wa in ("-e", "--email") and _wi + 1 < len(_web_argv):
                _web_email = _web_argv[_wi + 1]
                break
        # Look up chrome profile from config: [chrome] account = profile_number
        chrome_profile = None
        if _web_email:
            for section_key in _CONFIG.sections():
                if section_key.lower() == "chrome":
                    for acct, prof in _CONFIG.items(section_key):
                        if _web_email.lower() in acct.lower():
                            chrome_profile = prof
                            break
        if chrome_profile is None:
            chrome_profile = _config_get("chrome_profile", "GMAILS_CHROME_PROFILE", "0")
        opener = shutil.which("chrome-profile-open")
        url = "https://mail.google.com"
        if opener:
            subprocess.run([opener, chrome_profile, url])
        else:
            webbrowser.open(url)
        sys.exit(0)

    # Detect mode: find "send", "draft", or "reply" anywhere in argv (skipping flag values)
    mode = None
    rest = sys.argv[1:]
    mode_index = None
    skip_next = False
    for i, arg in enumerate(rest):
        if skip_next:
            skip_next = False
            continue
        if arg in ("-F", "--config", "-e", "--email", "-n", "--count", "-q", "--query"):
            skip_next = True  # next arg is the flag's value
            continue
        if arg in ("send", "draft", "reply", "reply-all", "fwd", "trash", "archive", "open", "thread", "read", "unread", "inbox"):
            mode = arg
            mode_index = i
            break
        if arg.startswith("-"):
            continue
        # Skip positional args that look like indices (digits, commas, dashes)
        # so we can find mode keywords like "fwd" after "1" in: gmails sent -q FYI 1 fwd bob@x.com
        if re.fullmatch(r'[\d,\-]+', arg):
            continue
        break  # hit a positional arg that isn't a mode keyword or index

    if mode:
        # Rearrange so parse_send_draft_args sees: [mode, ...flags..., ...args...]
        # Move common flags from before the mode into the post-mode args
        pre = rest[:mode_index]
        post = rest[mode_index:]  # starts with "send"/"draft"
        rest = [post[0]] + pre + post[1:]

    if mode in ("send", "draft"):
        args = parse_send_draft_args(rest)
        # -t preview: just build bytes locally, no Gmail API call needed
        token_name, login_hint = resolve_account(args.config, args.email, "gmail-send")
        if args.show_account:
            print(login_hint or "(default account)")
            sys.exit(0)
        if args.text:
            service = None
        else:
            creds = get_credentials(service="gmail", scopes="gmail-send",
                                    token_name=token_name, login_hint=login_hint)
            service = build("gmail", "v1", credentials=creds)
        if mode == "send":
            do_send(service, args, from_addr=login_hint)
        else:
            do_draft(service, args, from_addr=login_hint)
    elif mode in ("reply", "reply-all"):
        # reply needs compose scope to send, but -t preview only needs readonly
        reply_rest = [a for a in rest if a not in ("reply", "reply-all")]
        if mode == "reply-all":
            reply_rest.append("--all")
        args = parse_list_get_args(reply_rest)
        if args.index is None:
            print("Usage: gmails reply INDEX (e.g., gmails reply 3)", file=sys.stderr)
            sys.exit(1)
        indices = parse_index_token(args.index)
        if len(indices) > 1:
            print("reply only works with a single message, got "
                  f"{len(indices)} indices: {indices}", file=sys.stderr)
            sys.exit(1)
        reply_idx = indices[0]
        # Apply same query defaults as listing, so cache keys match
        query = args.query
        if sent_mode:
            query = f"in:sent {query}" if query else "in:sent"
        elif not query:
            query = "in:inbox"
        reply_scope = "gmail-readonly" if args.text else "gmail-send"
        token_name, login_hint = resolve_account(args.config, args.email, reply_scope)
        if args.show_account:
            print(login_hint or "(default account)")
            sys.exit(0)
        creds = get_credentials(service="gmail", scopes=reply_scope,
                                token_name=token_name, login_hint=login_hint)
        service = build("gmail", "v1", credentials=creds)
        do_reply(service, reply_idx, args.count, query, args,
                 as_draft=args.draft, account=login_hint, sent=sent_mode)
    elif mode == "fwd":
        fwd_rest = [a for a in rest if a != "fwd"]
        args = parse_list_get_args(fwd_rest)
        if args.index is None or (args.output is None and not args.text):
            print("Usage: gmails fwd INDEX RECIPIENT (e.g., gmails fwd 3 user@example.com)", file=sys.stderr)
            sys.exit(1)
        indices = parse_index_token(args.index)
        if len(indices) > 1:
            print("fwd only works with a single message, got "
                  f"{len(indices)} indices: {indices}", file=sys.stderr)
            sys.exit(1)
        fwd_idx = indices[0]
        recipient = args.output  # the "output" positional is the recipient for fwd
        fwd_scope = "gmail-readonly" if args.text else "gmail-send"
        token_name, login_hint = resolve_account(args.config, args.email, fwd_scope)
        if args.show_account:
            print(login_hint or "(default account)")
            sys.exit(0)
        creds = get_credentials(service="gmail", scopes=fwd_scope,
                                token_name=token_name, login_hint=login_hint)
        service = build("gmail", "v1", credentials=creds)
        # Apply same query defaults as listing, so cache keys match
        query = args.query
        if sent_mode:
            query = f"in:sent {query}" if query else "in:sent"
        elif not query:
            query = "in:inbox"
        do_forward(service, fwd_idx, args.count, query, recipient,
                   as_draft=args.draft, account=login_hint,
                   text_view=args.text)
    elif mode == "inbox":
        inbox_rest = [a for a in rest if a != "inbox"]
        # Prepend common flags that were before "inbox" in argv
        args = parse_inbox_args(inbox_rest)
        token_name, login_hint = resolve_account(args.config, args.email, "gmail-readonly")
        if args.show_account:
            print(login_hint or "(default account)")
            sys.exit(0)
        team_file = args.team_file
        if not os.path.exists(team_file):
            print(f"Team file not found: {team_file}", file=sys.stderr)
            sys.exit(1)
        team = parse_team_file(team_file)
        if not team:
            print(f"No email addresses found in {team_file}", file=sys.stderr)
            sys.exit(1)
        print(f"Found {len(team)} team member(s) in {team_file}", file=sys.stderr)
        for name, addr in team:
            print(f"  {name} <{addr}>", file=sys.stderr)
        print(file=sys.stderr)
        creds = get_credentials(service="gmail", scopes="gmail-readonly",
                                token_name=token_name, login_hint=login_hint)
        service = build("gmail", "v1", credentials=creds)
        do_inbox(service, team, args.days, args.output, dry_run=args.dry_run,
                 account=login_hint, resume=args.resume)
    elif mode in ("trash", "archive", "open", "thread", "read", "unread"):
        mode_rest = [a for a in rest if a != mode]
        indices, filtered_rest = collect_indices(mode_rest)
        args = parse_list_get_args(filtered_rest)
        if not indices:
            print(f"Usage: gmails {mode} INDEX [INDEX ...] (e.g., gmails {mode} 3 or gmails {mode} 1,3-5)",
                  file=sys.stderr)
            sys.exit(1)
        if mode in ("open", "thread") and len(indices) > 1:
            print(f"{mode} only works with a single message, got "
                  f"{len(indices)} indices: {indices}", file=sys.stderr)
            sys.exit(1)
        # trash/archive/read/unread need write access; open and thread only need read
        scope = "gmail-send" if mode in ("trash", "archive", "read", "unread") else "gmail-readonly"
        token_name, login_hint = resolve_account(args.config, args.email, scope)
        if args.show_account:
            print(login_hint or "(default account)")
            sys.exit(0)
        creds = get_credentials(service="gmail", scopes=scope,
                                token_name=token_name, login_hint=login_hint)
        service = build("gmail", "v1", credentials=creds)
        # Apply same query defaults as listing, so cache keys match
        query = args.query
        if sent_mode:
            query = f"in:sent {query}" if query else "in:sent"
        elif not query:
            query = "in:inbox"
        if mode == "trash":
            do_trash(service, indices, args.count, query, account=login_hint)
        elif mode == "archive":
            do_archive(service, indices, args.count, query, account=login_hint)
        elif mode == "read":
            do_mark_read(service, indices, args.count, query, account=login_hint)
        elif mode == "unread":
            do_mark_unread(service, indices, args.count, query, account=login_hint)
        elif mode == "open":
            do_open(service, indices[0], args.count, query, account=login_hint)
        else:
            do_thread(service, indices[0], args.count, query, account=login_hint)
    else:
        args = parse_list_get_args(rest)
        scope = "gmail-readonly"
        token_name, login_hint = resolve_account(args.config, args.email, scope)
        if args.show_account:
            print(login_hint or "(default account)")
            sys.exit(0)
        creds = get_credentials(service="gmail", scopes=scope,
                                token_name=token_name, login_hint=login_hint)
        service = build("gmail", "v1", credentials=creds)
        query = args.query
        if sent_mode:
            query = f"in:sent {query}" if query else "in:sent"
        elif not query:
            query = "in:inbox"

        # -peek requires an index but no longer implies -t
        if grab_mode:
            if args.index is None:
                print("Warning: -p requires a message index or range (e.g., gmails 3 -p)", file=sys.stderr)
                # Fall through to listing, but text_view/grab won't be used

        if args.just_count:
            kwargs = {"userId": "me", "maxResults": args.count}
            if query:
                kwargs["q"] = query
            result = service.users().messages().list(**kwargs).execute()
            print(result.get("resultSizeEstimate", 0))
            sys.exit(0)
        if args.index is None:
            do_list(service, args.count, query, account=login_hint,
                    sent=sent_mode, verbose=args.verbose,
                    summary=args.summary,
                    json_output=getattr(args, 'json', False))
        else:
            indices = parse_index_token(args.index)
            peek_paths = []
            for idx in indices:
                result = do_get(service, idx, args.count, query, args.output,
                                stdout=args.stdout, text_view=args.text,
                                account=login_hint, grab=grab_mode,
                                headers_only=args.headers)
                if result:
                    peek_paths.append(result)
            if peek_paths:
                peek_cmd = "/peek " + " ".join(peek_paths)
                subprocess.run(["pbcopy"], input=peek_cmd.encode(), check=True)
                print(f"Copied to clipboard: {peek_cmd}", file=sys.stderr)


if __name__ == "__main__":
    main()
