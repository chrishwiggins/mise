def _retry_api_call(func, max_retries=3, base_delay=1.0):
    """Execute API call with exponential backoff on quota/rate limit errors."""
    for attempt in range(max_retries + 1):
        try:
            return func()
        except HttpError as e:
            if e.resp.status in (403, 429, 500, 502, 503, 504):
                if attempt == max_retries:
                    print(f"API call failed after {max_retries + 1} attempts: {e}", file=sys.stderr)
                    raise
                delay = base_delay * (2 ** attempt) + random.uniform(0, 1)
                print(f"API quota/rate limit hit, retrying in {delay:.1f}s (attempt {attempt + 1}/{max_retries + 1})", file=sys.stderr)
                time.sleep(delay)
            else:
                raise
        except Exception as e:
            if attempt == max_retries:
                print(f"API call failed after {max_retries + 1} attempts: {e}", file=sys.stderr)
                raise
            delay = base_delay * (2 ** attempt) + random.uniform(0, 1)
            print(f"API error, retrying in {delay:.1f}s (attempt {attempt + 1}/{max_retries + 1}): {e}", file=sys.stderr)
            time.sleep(delay)


