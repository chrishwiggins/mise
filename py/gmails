def parse_sender(from_header):
    """Extract a display-friendly sender from a From header."""
    if not from_header:
        return "(unknown)"
    name, addr = parseaddr(from_header)
    return name if name else addr


def parse_recipient(to_header):
    """Extract a display-friendly recipient from a To header."""
    if not to_header:
        return "(unknown)"
    # To header can have multiple addresses separated by commas
    addrs = [a.strip() for a in to_header.split(",") if a.strip()]
    if not addrs:
        return "(unknown)"
    name, addr = parseaddr(addrs[0])
    first = name if name else addr
    if len(addrs) > 1:
        first += f" +{len(addrs) - 1}"
    return first


def parse_date(date_header):
    """Parse email Date header to YYYY-MM-DD string."""
    if not date_header:
        return "          "
    try:
        dt = parsedate_to_datetime(date_header)
        return dt.strftime("%Y-%m-%d")
    except Exception:
        return date_header[:10]


def get_header(headers, name):
    """Extract a header value from Gmail metadata headers list."""
    for h in headers:
        if h["name"].lower() == name.lower():
            return h["value"]
    return ""


def _count_attachments_payload(payload):
    """Count file attachments in a Gmail API payload structure."""
    count = 0
    for part in payload.get("parts", []):
        if part.get("filename"):
            count += 1
        if "parts" in part:
            count += _count_attachments_payload(part)
    return count


def sanitize_filename(s, max_len=60):
    """Sanitize a string for use as a filename component."""
    s = re.sub(r"[^\w\s.-]", "", s)
    s = re.sub(r"\s+", "-", s.strip())
    s = re.sub(r"-+", "-", s)
    return s[:max_len].rstrip("-")


def parse_index_token(token):
    """Parse an index token like '3', '2,5', '2-5', or '1,3-5,8' into a sorted list of ints."""
    indices = []
    for part in token.split(","):
        part = part.strip()
        if not part:
            continue
        if "-" in part:
            pieces = part.split("-", 1)
            try:
                start, end = int(pieces[0]), int(pieces[1])
            except ValueError:
                print(f"Invalid index range: {part!r}", file=sys.stderr)
                sys.exit(1)
            if start > end:
                print(f"Invalid index range (start > end): {part!r}", file=sys.stderr)
                sys.exit(1)
            indices.extend(range(start, end + 1))
        else:
            try:
                indices.append(int(part))
            except ValueError:
                print(f"Invalid index: {part!r}", file=sys.stderr)
                sys.exit(1)
    if not indices:
        print(f"No valid indices in: {token!r}", file=sys.stderr)
        sys.exit(1)
    return sorted(set(indices))


def collect_indices(args):
    """Extract index tokens from an arg list, return (indices, remaining_args).

    Scans args for tokens that look like index specs (digits, commas, hyphens).
    Skips flag values. Returns combined sorted/deduped indices and the
    remaining non-index args.
    """
    indices = []
    remaining = []
    skip_next = False
    for arg in args:
        if skip_next:
            remaining.append(arg)
            skip_next = False
            continue
        if arg in ("-n", "--count", "-q", "--query", "-F", "--config", "-e", "--email"):
            remaining.append(arg)
            skip_next = True
            continue
        if arg.startswith("-"):
            remaining.append(arg)
            continue
        # Check if it looks like an index token: digits, commas, hyphens
        if re.match(r"^\d[\d,-]*$", arg):
            indices.extend(parse_index_token(arg))
        else:
            remaining.append(arg)
    return sorted(set(indices)), remaining


def generate_filename(raw_bytes):
    """Generate a filename from the email's Date, From, and Subject headers."""
    msg = email.message_from_bytes(raw_bytes, policy=email.policy.default)

    date_str = "unknown-date"
    date_hdr = msg.get("Date", "")
    if date_hdr:
        try:
            dt = parsedate_to_datetime(date_hdr)
            date_str = dt.strftime("%Y-%m-%d")
        except Exception:
            pass

    _, addr = parseaddr(msg.get("From", ""))
    from_part = sanitize_filename(addr.split("@")[0] if addr else "unknown", 20)

    subj = msg.get("Subject", "no-subject")
    subj_part = sanitize_filename(subj, 30)

    return f"{date_str}-{from_part}-{subj_part}.eml"


def versioned_path(path):
    """If path exists, return path-v{N}.ext with next available version (don't move existing)."""
    if not path.exists():
        return path
    stem = path.stem
    suffix = path.suffix
    parent = path.parent

    # Find the highest existing version; unversioned original counts as v1
    max_v = 1
    for sibling in parent.iterdir():
        m = re.match(re.escape(stem) + r"-v(\d+)" + re.escape(suffix) + "$", sibling.name)
        if m:
            max_v = max(max_v, int(m.group(1)))

    new_v = max_v + 1
    return parent / f"{stem}-v{new_v}{suffix}"


def save_attachments(raw_bytes, output_dir):
    """Extract and save attachments alongside the .eml file."""
    msg = email.message_from_bytes(raw_bytes, policy=email.policy.default)
    saved = []

    for part in msg.walk():
        disp = part.get("Content-Disposition", "")
        if "attachment" not in disp:
            continue

        filename = part.get_filename()
        if not filename:
            filename = f"attachment-{len(saved) + 1}.bin"

        att_path = output_dir / filename
        if att_path.exists():
            print(f"Attachment already exists, skipping: {att_path}", file=sys.stderr)
            continue

        payload = part.get_payload(decode=True)
        if payload:
            att_path.write_bytes(payload)
            saved.append(att_path)

    return saved


