def resolve_account(config_path, email_addr, scope_prefix):
    """Resolve account from -F config file or -e email address.

    Returns (token_name, login_hint) tuple, or (None, None) if neither given.
    """
    # Fall back to GMAILS_ACCOUNT env var if neither -F nor -e given
    if not email_addr and not config_path:
        email_addr = os.environ.get("GMAILS_ACCOUNT")
    if email_addr:
        # -e flag: look up config path from accounts file, derive token name
        full_email, config_path = _lookup_config_for_email(email_addr)
        acct = full_email.replace("@", "-at-").replace(".", "-")
        return f"{scope_prefix}-{acct}", full_email
    if config_path:
        # -F flag: extract email from muttrc
        with open(config_path) as f:
            for line in f:
                m = re.match(r'^set\s+imap_user\s*=\s*"(.+?)"', line)
                if m:
                    found_email = m.group(1)
                    acct = found_email.replace("@", "-at-").replace(".", "-")
                    return f"{scope_prefix}-{acct}", found_email
        print(f"No imap_user found in {config_path}", file=sys.stderr)
        sys.exit(1)
    return None, None


def _lookup_config_for_email(email_addr):
    """Find muttrc config path for an email address from ~/.config/gmails/accounts.

    Supports partial matching (e.g., 'work' matches 'alice@work.example.com')
    and bare aliases (e.g., 'personal' -> 'alice@example.com').
    Returns (full_email, config_path) tuple.  full_email always contains '@'.
    """
    if not ACCOUNTS_FILE.exists():
        print(f"No accounts file at {ACCOUNTS_FILE}", file=sys.stderr)
        print("Create it with lines like: user@example.com /path/to/muttrc", file=sys.stderr)
        sys.exit(1)

    # Parse all entries, separating real emails from bare aliases
    all_entries = []
    with open(ACCOUNTS_FILE) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            parts = line.split(None, 1)
            if len(parts) != 2:
                continue
            all_entries.append((parts[0], parts[1]))

    matches = [(e, p) for e, p in all_entries if email_addr.lower() in e.lower()]

    if len(matches) == 0:
        print(f"No account matching '{email_addr}' in {ACCOUNTS_FILE}", file=sys.stderr)
        sys.exit(1)
    if len(matches) > 2:
        # Filter: prefer real email matches over bare aliases
        real = [(e, p) for e, p in matches if "@" in e]
        if len(real) == 1:
            matches = real

    # If we matched a bare alias (no @), resolve to the real email that shares
    # the same config path.  e.g., "work /dev/null" -> "alice@work.example.com /dev/null"
    chosen_email, chosen_path = matches[0]
    if "@" not in chosen_email:
        for entry_email, entry_path in all_entries:
            if "@" in entry_email and entry_path == chosen_path:
                chosen_email = entry_email
                break
        if "@" not in chosen_email:
            # Still no real email found; warn but continue
            print(f"Warning: alias '{chosen_email}' has no corresponding email "
                  f"entry in {ACCOUNTS_FILE}", file=sys.stderr)

    if len(matches) > 1 and all("@" not in e for e, _ in matches):
        # Multiple bare aliases, ambiguous
        print(f"Ambiguous: '{email_addr}' matches multiple accounts:", file=sys.stderr)
        for acct_email, _ in matches:
            print(f"  {acct_email}", file=sys.stderr)
        sys.exit(1)

    return chosen_email, chosen_path


def _save_draft_recovery(src_path, kind):
    """Copy an editor tmpfile to /tmp/spool/last-draft-<kind>.eml before unlink."""
    spool = Path("/tmp/spool")
    spool.mkdir(exist_ok=True)
    shutil.copy(src_path, spool / f"last-draft-{kind}.eml")


def get_body_interactive(recipient, subject):
    """Open $EDITOR and return the body text."""
    editor = os.environ.get("EDITOR", "vim")
    with tempfile.NamedTemporaryFile(suffix=".txt", mode="w", delete=False) as f:
        tmpfile = f.name
    try:
        subprocess.call([editor, tmpfile])
        body = Path(tmpfile).read_text()
    finally:
        try:
            _save_draft_recovery(tmpfile, "body")
        except OSError:
            pass
        os.unlink(tmpfile)
    if not body.strip():
        print("Empty body, aborting.", file=sys.stderr)
        sys.exit(1)
    return body


def build_mime_message(recipient, subject, body, cc=None, bcc=None, attachments=None,
                       from_addr=None):
    """Build a MIME message from parts. Returns bytes."""
    plain_part = MIMEText(body, "plain", "utf-8")
    html_body = "<pre style=\"font-family:sans-serif;white-space:pre-wrap\">" + html_mod.escape(body) + "</pre>"
    html_part = MIMEText(html_body, "html", "utf-8")
    msg = MIMEMultipart("alternative")
    msg.attach(plain_part)
    msg.attach(html_part)
    msg["From"] = from_addr or _default_from_addr() or "user@example.com"
    msg["To"] = recipient
    if subject:
        msg["Subject"] = subject
    msg["Date"] = formatdate(localtime=True)
    msg["Message-ID"] = make_msgid(domain="gmail.com")
    if cc:
        msg["Cc"] = cc
    if bcc:
        msg["Bcc"] = bcc
    msg = _attach_files(msg, attachments)
    return msg.as_bytes()


