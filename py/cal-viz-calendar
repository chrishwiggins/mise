def main():
    parser = argparse.ArgumentParser(description="Generate calendar-style HTML from schedule files")
    parser.add_argument('file', nargs='?', default='-', help="Schedule file (or - for stdin)")
    parser.add_argument('--start', help="Start date (YYYY-MM-DD)")
    parser.add_argument('--end', help="End date (YYYY-MM-DD)")
    parser.add_argument('--person', help="Filter by person name")
    args = parser.parse_args()

    text = sys.stdin.read() if args.file == '-' else open(args.file).read()
    sched = parse_schedule(text.splitlines())

    # Compute date range
    start = parse_date(args.start) if args.start else sched.range_start
    end = parse_date(args.end) if args.end else sched.range_end

    if not start or not end:
        all_dates = []
        for b in sched.breaks:
            all_dates.extend([b.start, b.end])
        for s in sched.specials:
            all_dates.append(s.day)
        if not all_dates:
            print("cal-viz-calendar: no dates found in schedule", file=sys.stderr)
            sys.exit(1)
        start = start or min(all_dates)
        end = end or max(all_dates)

    html = generate_calendar_html(sched, start, end, args.person)
    sys.stdout.write(html)

if __name__ == '__main__':
    main()