#!/usr/bin/env python3
import json
import urllib.request
import argparse
import csv
import random
import sys

parser = argparse.ArgumentParser(description="Generate a random US name")
parser.add_argument("prefix", nargs='?', type=str, help="First letter(s) of first name (shorthand for -l)")
parser.add_argument("-m", "--male", action="store_true", help="Generate a male name")
parser.add_argument("-f", "--female", action="store_true", help="Generate a female name")
parser.add_argument("-l", "--letter", type=str, help="First letter(s) of first name (e.g., 'j' for James, 'ja' for names starting with Ja)")
parser.add_argument("-L", "--letter-caps", type=str, dest="letter_caps", help="Like -l but output matched prefix in CAPS (e.g., '-L ju' -> JUlie)")
parser.add_argument("-i", "--initials", type=str, help="Two initials: first and last name (e.g., 'JD' for John Doe)")
parser.add_argument("--first", action="store_true", help="Output only the first name")
parser.add_argument("--file", type=str, help="CSV file with columns: gender,first,last")
parser.add_argument("-N", type=int, default=1, help="Number of names to generate (default: 1)")
args = parser.parse_args()

# Positional prefix is shorthand for -l
if args.prefix and not args.letter:
    args.letter = args.prefix

if args.initials and len(args.initials) != 2:
    parser.error("-i/--initials requires exactly 2 characters (first and last initial)")

def format_output(first_name, last_name, caps_prefix=None):
    """Format name for output, optionally capitalizing a prefix."""
    if caps_prefix:
        first_name = first_name[:len(caps_prefix)].upper() + first_name[len(caps_prefix):]
    if args.first:
        return first_name
    return f"{first_name} {last_name}"

def matches_filters(first_name, last_name, gender):
    """Check if a name matches all active filters. gender=None skips gender check (API filters it)."""
    if gender is not None:
        if args.male and gender != 'male':
            return False
        if args.female and gender != 'female':
            return False

    prefix = (args.letter or args.letter_caps or "").lower()
    if prefix and not first_name.lower().startswith(prefix):
        return False

    if args.initials:
        fi, li = args.initials[0].lower(), args.initials[1].lower()
        if first_name[0].lower() != fi or last_name[0].lower() != li:
            return False

    return True

# ========== LOCAL FILE MODE ==========
if args.file:
    with open(args.file, 'r') as f:
        # Skip comment lines (# prefix, python/bash style)
        lines = [line for line in f if not line.startswith('#')]
        reader = csv.DictReader(lines)
        all_names = [(row['gender'], row['first'], row['last']) for row in reader]

    filtered = [(g, fn, ln) for g, fn, ln in all_names if matches_filters(fn, ln, g)]

    if not filtered:
        print("No names match the specified filters", file=sys.stderr)
        sys.exit(1)

    selected = random.sample(filtered, min(args.N, len(filtered)))
    for gender, first_name, last_name in selected:
        print(format_output(first_name, last_name, caps_prefix=args.letter_caps))

# ========== API MODE ==========
else:
    url = "https://randomuser.me/api/?nat=us&inc=name"
    if args.male:
        url += "&gender=male"
    elif args.female:
        url += "&gender=female"

    count = 0
    max_attempts = 200
    attempts = 0

    while count < args.N and attempts < max_attempts:
        attempts += 1
        try:
            response = urllib.request.urlopen(url)
            d = json.load(response)
            if not d.get("results"):
                continue  # API returned empty results, retry
            first_name = d["results"][0]["name"]["first"]
            last_name = d["results"][0]["name"]["last"]
        except (urllib.error.URLError, json.JSONDecodeError, KeyError, IndexError):
            continue  # Network or parsing error, retry

        # Gender already filtered via URL, so pass None
        if matches_filters(first_name, last_name, None):
            print(format_output(first_name, last_name, caps_prefix=args.letter_caps))
            count += 1
            attempts = 0  # Reset attempts after each success

    if count < args.N:
        print(f"Only found {count}/{args.N} names after {max_attempts} attempts", file=sys.stderr)
