         --- Weizenbaum, 1966 ---
"""


def main():
    eliza = Eliza()
    print(BANNER)
    print(INITIAL)
    try:
        while True:
            try:
                user_input = input("> ")
            except EOFError:
                print(FAREWELL)
                break
            if not user_input.strip():
                continue
            response = eliza.respond(user_input)
            print(response)
            if response == FAREWELL:
                break
    except KeyboardInterrupt:
        print("\n" + FAREWELL)


if __name__ == "__main__":
    main()
