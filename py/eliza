# ---------------------------------------------------------------------------
# Synonym classes (Weizenbaum called these "equivalence classes").
# A @tag in a decomposition pattern matches any word in the class.
# ---------------------------------------------------------------------------
SYNONYMS = {
    "belief":  ["believe", "feel", "think", "wish"],
    "family":  ["mother", "mom", "father", "dad", "sister", "brother",
                "wife", "husband", "children", "child", "son", "daughter"],
    "desire":  ["want", "need"],
    "sad":     ["sad", "unhappy", "depressed", "sick", "miserable"],
    "happy":   ["happy", "elated", "glad", "better"],
    "everyone":["everyone", "everybody", "nobody", "noone", "no one"],
}


def _syn_pattern(tag):
    """Return a regex alternation for a synonym class."""
    return "(?:" + "|".join(re.escape(w) for w in SYNONYMS[tag]) + ")"


