# ===================================================================
# Engine
# ===================================================================

class Eliza:
    def __init__(self):
        self.memory = deque()
        self.none_idx = 0

        # Compile rules: for each keyword, pre-compile decomposition
        # regexes and set up cycling indices.
        self.keywords = []  # (keyword, rank, compiled_rules)
        for kw, rank, decomps in RULES:
            compiled = []
            for pattern, resps in decomps:
                mem_flag = False
                if pattern.startswith("$ "):
                    mem_flag = True
                    pattern = pattern[2:]
                regex = self._compile_pattern(pattern)
                compiled.append((regex, resps, [0], mem_flag))
            self.keywords.append((kw, rank, compiled))

        # Build a lookup by keyword for goto resolution.
        self.kw_map = {}
        for kw, rank, compiled in self.keywords:
            self.kw_map[kw] = compiled

    def _compile_pattern(self, pattern):
        """Convert a Weizenbaum decomposition pattern to a regex.

        Patterns use * for zero-or-more-word wildcards and @tag for
        synonym classes.  We build a regex that matches the full input.
        """
        if pattern == "*":
            return re.compile(r"^(.*)$", re.IGNORECASE)

        parts = pattern.split()
        # Build regex pieces, tracking which are wildcards so we can
        # use the right glue between them.
        pieces = []   # (regex_fragment, is_wildcard)
        for part in parts:
            if part == "*":
                pieces.append(("(.*?)", True))
            elif part.startswith("@"):
                tag = part[1:]
                pieces.append(("(" + _syn_pattern(tag) + ")", False))
            else:
                pieces.append((re.escape(part), False))

        # Make the last wildcard greedy.
        for i in range(len(pieces) - 1, -1, -1):
            if pieces[i][1]:
                pieces[i] = ("(.*)", True)
                break

        # Join pieces: between two non-wildcards use \s+;
        # between a wildcard and anything use \s* (wildcard may be empty).
        regex_str = pieces[0][0]
        for i in range(1, len(pieces)):
            prev_wc = pieces[i - 1][1]
            curr_wc = pieces[i][1]
            if prev_wc or curr_wc:
                regex_str += r"\s*"
            else:
                regex_str += r"\s+"
            regex_str += pieces[i][0]

        return re.compile("^" + regex_str + "$", re.IGNORECASE)

    def _post_substitute(self, text):
        """Apply post-substitution (perspective swap) to a captured group."""
        words = text.split()
        result = []
        for w in words:
            low = w.lower()
            if low in POST_SUB:
                result.append(POST_SUB[low])
            else:
                result.append(w)
        return " ".join(result)

    def _pre_substitute(self, text):
        """Apply pre-substitution to user input."""
        words = text.split()
        result = []
        for w in words:
            low = w.lower()
            if low in PRE_SUB:
                result.append(PRE_SUB[low])
            else:
                result.append(low)
        return " ".join(result)

    def _try_rules(self, rules, text, depth=0):
        """Try decomposition rules, return response or None."""
        if depth > 10:
            return None
        for regex, resps, idx_ref, mem_flag in rules:
            m = regex.match(text)
            if m:
                groups = list(m.groups())
                # Post-substitute all captured groups.
                groups = [self._post_substitute(g.strip()) for g in groups]

                # Cycle through reassembly rules.
                resp = resps[idx_ref[0] % len(resps)]
                idx_ref[0] = (idx_ref[0] + 1) % len(resps)

                # Handle goto.
                if resp.startswith("goto:"):
                    target = resp[5:]
                    if target in self.kw_map:
                        return self._try_rules(self.kw_map[target], text,
                                               depth + 1)
                    return None

                # Handle memory: stash a transformation for later.
                if mem_flag:
                    assembled = self._assemble(resp, groups)
                    self.memory.append(assembled)
                    return None  # Don't use it now; continue searching.

                return self._assemble(resp, groups)
        return None

    def _assemble(self, template, groups):
        """Fill in {1}, {2}, ... placeholders with captured groups."""
        result = template
        for i, g in enumerate(groups, 1):
            result = result.replace("{" + str(i) + "}", g)
        return result

    def respond(self, user_input):
        """Generate ELIZA's response to user input."""
        # Strip punctuation, normalize whitespace.
        text = re.sub(r"[.!?;,]", " ", user_input)
        text = " ".join(text.split())
        if not text:
            return "Please say something."

        # Check for quit.
        if text.strip().lower() in QUIT_WORDS:
            return FAREWELL

        # Pre-substitute.
        text = self._pre_substitute(text)

        # Find all matching keywords and sort by rank (highest first).
        found = []
        text_lower = text.lower()
        text_words = set(text_lower.split())
        for kw, rank, compiled in self.keywords:
            if kw in text_words:
                found.append((rank, kw, compiled))

        # Also do substring match for multi-word or partial matches.
        if not found:
            for kw, rank, compiled in self.keywords:
                if kw in text_lower:
                    found.append((rank, kw, compiled))

        found.sort(key=lambda x: -x[0])

        # Try each keyword's rules in rank order.
        for rank, kw, compiled in found:
            resp = self._try_rules(compiled, text)
            if resp:
                return resp

        # No keyword matched: try memory.
        if self.memory:
            return self.memory.popleft()

        # Fall back to NONE responses (cycling).
        resp = NONE_RESPONSES[self.none_idx % len(NONE_RESPONSES)]
        self.none_idx = (self.none_idx + 1) % len(NONE_RESPONSES)
        return resp


