#!/usr/bin/env python3
"""
Countdown Timer - Counts down minutes until 12:55 PM

This application shows a countdown timer that displays the time remaining
until 12:55 PM (12:55) today, or 12:55 PM tomorrow if it's already past
that time today.
"""

import tkinter as tk
from tkinter import ttk
import datetime
import time


class CountdownTimer:
    def __init__(self, root):
        self.root = root
        self.root.title("Countdown to 12:55 PM")
        self.root.geometry("400x300")
        self.root.resizable(True, True)
        self.root.configure(bg="white")  # White background for window

        # Configure the main frame with white background
        self.main_frame = tk.Frame(root, bg="white")
        self.main_frame.grid(row=0, column=0, sticky=(tk.W, tk.E, tk.N, tk.S), padx=20, pady=20)

        # Configure grid weights for resizing
        root.columnconfigure(0, weight=1)
        root.rowconfigure(0, weight=1)
        self.main_frame.columnconfigure(0, weight=1)

        # Font size control
        self.font_size = 48  # Start with much larger font (was 24)

        # Title label
        self.title_label = tk.Label(
            self.main_frame,
            text="Countdown to 12:55 PM",
            font=("Arial", 16, "bold"),
            anchor="center",
            bg="white",
            fg="black"
        )
        self.title_label.grid(row=0, column=0, pady=10)

        # Current time display
        self.current_time_label = tk.Label(
            self.main_frame,
            text="",
            font=("Courier", 14),
            anchor="center",
            bg="white",
            fg="black"
        )
        self.current_time_label.grid(row=1, column=0, pady=5)

        # Target time display
        self.target_time_label = tk.Label(
            self.main_frame,
            text="",
            font=("Arial", 12),
            anchor="center",
            bg="white",
            fg="black"
        )
        self.target_time_label.grid(row=2, column=0, pady=5)

        # Countdown display (large) - RED text for better visibility
        self.countdown_label = tk.Label(
            self.main_frame,
            text="",
            font=("Courier", self.font_size, "bold"),
            anchor="center",
            bg="white",
            fg="red"
        )
        self.countdown_label.grid(row=3, column=0, pady=20)

        # Status message
        self.status_label = tk.Label(
            self.main_frame,
            text="",
            font=("Arial", 10),
            anchor="center",
            bg="white",
            fg="black"
        )
        self.status_label.grid(row=4, column=0, pady=5)

        # Progress bar
        self.progress = ttk.Progressbar(
            self.main_frame,
            length=300,
            mode='determinate'
        )
        self.progress.grid(row=5, column=0, pady=10)

        # Font size controls
        self.font_frame = tk.Frame(self.main_frame, bg="white")
        self.font_frame.grid(row=6, column=0, pady=10)

        tk.Label(self.font_frame, text="Font Size:", bg="white", fg="black").pack(side=tk.LEFT, padx=5)

        self.font_smaller_button = tk.Button(
            self.font_frame,
            text="−",
            command=self.decrease_font,
            width=3
        )
        self.font_smaller_button.pack(side=tk.LEFT, padx=2)

        self.font_size_label = tk.Label(
            self.font_frame,
            text=str(self.font_size),
            bg="white", fg="black",
            width=3
        )
        self.font_size_label.pack(side=tk.LEFT, padx=5)

        self.font_larger_button = tk.Button(
            self.font_frame,
            text="+",
            command=self.increase_font,
            width=3
        )
        self.font_larger_button.pack(side=tk.LEFT, padx=2)

        # Control buttons frame
        self.button_frame = tk.Frame(self.main_frame, bg="white")
        self.button_frame.grid(row=7, column=0, pady=20)

        # Pause/Resume button
        self.pause_resume_button = ttk.Button(
            self.button_frame,
            text="Pause",
            command=self.toggle_pause
        )
        self.pause_resume_button.pack(side=tk.LEFT, padx=5)

        # Reset button
        self.reset_button = ttk.Button(
            self.button_frame,
            text="Reset",
            command=self.reset_timer
        )
        self.reset_button.pack(side=tk.LEFT, padx=5)

        # Quit button
        self.quit_button = ttk.Button(
            self.button_frame,
            text="Quit",
            command=self.root.quit
        )
        self.quit_button.pack(side=tk.LEFT, padx=5)

        # Initialize state
        self.running = True
        self.paused = False
        self.target_time = None
        self.total_seconds = 0
        self.calculate_target_time()
        self.update_timer()

    def calculate_target_time(self):
        """Calculate the target time (12:55 PM today or tomorrow)"""
        now = datetime.datetime.now()

        # Create target time for today at 12:55 PM
        target_today = now.replace(hour=12, minute=55, second=0, microsecond=0)

        # If it's already past 12:55 PM today, target tomorrow
        if now >= target_today:
            target_today += datetime.timedelta(days=1)

        self.target_time = target_today

        # Calculate total seconds for progress bar
        time_diff = self.target_time - now
        self.total_seconds = time_diff.total_seconds()

        # Update target time display
        target_str = self.target_time.strftime("%A, %B %d, %Y at 12:55 PM")
        self.target_time_label.config(text=f"Target: {target_str}")

    def format_time_remaining(self, seconds):
        """Format seconds into a readable countdown string"""
        if seconds <= 0:
            return "00:00:00"

        hours = int(seconds // 3600)
        minutes = int((seconds % 3600) // 60)
        secs = int(seconds % 60)

        if hours > 0:
            return f"{hours:02d}:{minutes:02d}:{secs:02d}"
        else:
            return f"{minutes:02d}:{secs:02d}"

    def update_timer(self):
        """Update the countdown display"""
        if not self.running or self.paused:
            if not self.running:
                return
            # If paused, schedule next update but don't change display
            self.root.after(1000, self.update_timer)
            return

        now = datetime.datetime.now()

        # Update current time display
        current_time_str = now.strftime("%H:%M:%S")
        current_date_str = now.strftime("%A, %B %d, %Y")
        self.current_time_label.config(text=f"{current_time_str}\n{current_date_str}")

        # Calculate time remaining
        time_diff = self.target_time - now
        seconds_remaining = time_diff.total_seconds()

        if seconds_remaining <= 0:
            # Time reached!
            self.countdown_label.config(
                text="TIME'S UP!",
                fg="red"
            )
            self.status_label.config(text="It's 12:55 PM!")
            self.progress['value'] = 100

            # Flash the display
            self.flash_display()

            # Auto-reset for next occurrence
            self.root.after(5000, self.reset_timer)  # Reset after 5 seconds
            return

        # Update countdown display
        countdown_text = self.format_time_remaining(seconds_remaining)
        self.countdown_label.config(
            text=countdown_text,
            fg="red"
        )

        # Update status
        if seconds_remaining > 86400:  # More than 24 hours
            days = int(seconds_remaining // 86400)
            self.status_label.config(text=f"{days} day(s) and counting...")
        elif seconds_remaining > 3600:  # More than 1 hour
            hours = int(seconds_remaining // 3600)
            minutes = int((seconds_remaining % 3600) // 60)
            self.status_label.config(text=f"{hours}h {minutes}m remaining")
        else:
            minutes = int(seconds_remaining // 60)
            self.status_label.config(text=f"{minutes} minute(s) remaining")

        # Update progress bar
        if self.total_seconds > 0:
            progress_percent = ((self.total_seconds - seconds_remaining) / self.total_seconds) * 100
            self.progress['value'] = min(progress_percent, 100)

        # Schedule next update
        self.root.after(1000, self.update_timer)

    def flash_display(self):
        """Flash the display when time is up"""
        current_color = self.countdown_label.cget("fg")
        new_color = "orange" if current_color == "red" else "red"
        self.countdown_label.config(fg=new_color)

        # Continue flashing for a few seconds
        if self.countdown_label.cget("text") == "TIME'S UP!":
            self.root.after(500, self.flash_display)

    def toggle_pause(self):
        """Pause or resume the countdown"""
        self.paused = not self.paused
        if self.paused:
            self.pause_resume_button.config(text="Resume")
            self.status_label.config(text="Timer paused")
        else:
            self.pause_resume_button.config(text="Pause")

    def reset_timer(self):
        """Reset the timer to recalculate target time"""
        self.paused = False
        self.pause_resume_button.config(text="Pause")
        self.countdown_label.config(fg="red")
        self.progress['value'] = 0
        self.calculate_target_time()

    def increase_font(self):
        """Increase countdown font size"""
        if self.font_size < 120:  # Set reasonable maximum
            self.font_size += 6
            self.update_font_size()

    def decrease_font(self):
        """Decrease countdown font size"""
        if self.font_size > 12:  # Set reasonable minimum
            self.font_size -= 6
            self.update_font_size()

    def update_font_size(self):
        """Update the countdown label font size"""
        self.countdown_label.config(font=("Courier", self.font_size, "bold"))
        self.font_size_label.config(text=str(self.font_size))

    def stop(self):
        """Stop the timer updates"""
        self.running = False


def main():
    """Main function to run the countdown timer"""
    root = tk.Tk()

    # Set minimum window size
    root.minsize(350, 250)

    try:
        app = CountdownTimer(root)

        # Handle window close event
        def on_closing():
            app.stop()
            root.quit()
            root.destroy()

        root.protocol("WM_DELETE_WINDOW", on_closing)

        # Start the GUI event loop
        root.mainloop()

    except KeyboardInterrupt:
        print("\nExiting...")
        root.quit()


if __name__ == "__main__":
    main()