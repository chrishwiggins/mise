# ========================================================================
# § PARSING & DISPATCH — top-level argv → (account, action, rest[])
# ========================================================================
# This walks $@ once. The order of the elif chain matters:
#   1. Boolean flags (-w, --dry-run, etc.) — consumed in place
#   2. Value-taking flags (--outbox <alias>) — consume next arg too
#      (CRUCIAL: must come BEFORE the account-resolution branch, or the
#      flag's value will be stolen as an account alias)
#   3. The first matching action keyword sets $action
#   4. The first single-letter that matches a known account alias
#      sets $account
#   5. Anything else accumulates in `rest`
# After the loop, the action router (case "$action") consumes `rest`.
web=0; dry_run=0; no_cache=0; important_filter=0
action=""; account=""; rest=()
i=0; args=("$@")

# `open` is both a top-level action (open msg in web UI) and a trailing
# modifier for `-A` (open the just-saved attachment). When `-A`/
# `--save-attachments-only` is present, `open` must NOT be grabbed as the
# top-level action — it has to fall through to the inbox handler where the
# `-A open` special-case lives. Detect the attachment-save flag up front.
attach_save_in_args=0
for _a in "${args[@]+"${args[@]}"}"; do
    if [[ "$_a" == "-A" || "$_a" == "--save-attachments-only" ]]; then
        attach_save_in_args=1
        break
    fi
done

while (( i < ${#args[@]} )); do
    arg="${args[i]}"
    if [[ "$arg" == "-w" || "$arg" == "--web" ]]; then
        web=1
    elif [[ "$arg" == "--dry-run" ]]; then
        dry_run=1
    elif [[ "$arg" == "--urls" ]]; then
        # `--urls` is an alias for the `urls` action word. Push it into rest so
        # the inbox and sent handlers route it through parse_action_args exactly
        # like a bare `urls` (both list `urls` as an action word). A standalone
        # flag here was dead: nothing downstream ever read it, so `m ... --urls`
        # silently dumped the body instead of extracting URLs.
        rest+=("urls")
    elif [[ "$arg" == "--cal" ]]; then
        # `--cal` is advertised in the usage banner but was never implemented:
        # there is no `cal` mode in gmail-api-rw and no handler here, so the old
        # `cal_flag=1` was a dead no-op that silently dumped the message body.
        # Fail loudly rather than mislead. (If a calendar/.ics extractor is ever
        # added, route this through `rest` like `--urls` does.)
        log_error "--cal is not implemented (no calendar/.ics extraction exists yet)"
        exit 1
    elif [[ "$arg" == "-N" || "$arg" == "--no-cache" ]]; then
        no_cache=1
    elif [[ "$arg" == "-i" || "$arg" == "--important" ]]; then
        # View-only filter: prepend Gmail -from: exclusions (noisy automated
        # senders) to the listing/query. Non-destructive; nothing is muted,
        # marked read, or trashed. Applied below where query_string is finalized.
        important_filter=1
    elif [[ "$arg" == "--quiet" ]]; then
        M_QUIET_MODE=1
    elif [[ "$arg" == "-h" || "$arg" == "--help" || "$arg" == "?" ]]; then
        usage "${args[i+1]:-}"
    elif [[ "$arg" == "--version" ]]; then
        # Show last modification timestamp of this script
        if [[ -f "/Users/wiggins/mise/bash/m" ]]; then
            last_modified=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M:%S" "/Users/wiggins/mise/bash/m" 2>/dev/null || date -r "/Users/wiggins/mise/bash/m" "+%Y-%m-%d %H:%M:%S" 2>/dev/null)
            echo "m - email dispatcher"
            echo "Last modified: ${last_modified:-unknown}"
        else
            echo "m - email dispatcher (version info unavailable)"
        fi
        exit 0
    elif [[ "$arg" =~ ^--help= ]]; then
        usage "${arg#--help=}"
    elif [[ "$arg" == "-q" ]]; then
        log_error "Don't use -q flag directly. Use: m q <search-term>"
        echo "Example: m q ramon  (not m -q ramon)" >&2
        exit 1
    elif [[ "$arg" == "--outbox" ]]; then
        # --outbox <alias>: read uses main account, send uses outbox account.
        # Both args pass through to gmail-api-rw via rest.
        # CRITICAL: this branch must consume the value (the alias) here.
        # If we let the next loop iteration handle it, the alias gets eaten
        # by the account-resolution branch below (because 'h' looks like a
        # valid account alias). That bug bit us before this branch existed.
        rest+=("--outbox")
        if (( i + 1 < ${#args[@]} )); then
            i=$((i + 1))
            rest+=("${args[i]}")
        fi
    elif [[ "$arg" == "--after" ]]; then
        # --after <time>: schedule send after specified time
        # CRITICAL: this branch must consume the value (the time) here.
        # Same pattern as --outbox to prevent account-resolution conflicts.
        rest+=("--after")
        if (( i + 1 < ${#args[@]} )); then
            i=$((i + 1))
            rest+=("${args[i]}")
        else
            log_error "--after requires a time argument"
            echo "Examples: --after '5m', --after 'tomorrow 9am', --after '2024-05-24 14:30'" >&2
            exit 1
        fi
    elif [[ -z "$action" ]] && [[ "$arg" == "open" ]] && (( attach_save_in_args )); then
        # `-A open`: 'open' is a trailing modifier, not the top-level action.
        # Let it fall through to rest so the inbox handler's -A open path fires.
        rest+=("$arg")
    elif [[ -z "$action" ]] && [[ " $ACTIONS_SHORT $ACTIONS_SEND $ACTIONS_PASSTHRU " == *" $arg "* ]]; then
        action="$arg"
    elif [[ "$arg" == "m" ]] && [[ -z "$action" ]]; then
        action="archive"
    elif [[ -z "$account" ]] && [[ -n "${ACCTS[$arg]:-}" ]]; then
        account="$arg"
    else
        rest+=("$arg")
    fi
    i=$((i + 1))
done

# Check for "sent" typo: if action is "sent" but rest contains email recipients
# or .eml files, likely meant "send". Prompt for confirmation before proceeding.
# Exception: a .eml right after -S/--save is a SAVE TARGET (m sent 3 -S out.eml),
# not a send payload — don't nag about it.
if [[ "$action" == "sent" ]] && (( ${#rest[@]} > 0 )); then
    _prev=""
    for _r in "${rest[@]}"; do
        if [[ "$_r" =~ \.eml$ ]] && [[ "$_prev" == "-S" || "$_prev" == "--save" ]]; then
            _prev="$_r"
            continue
        fi
        _prev="$_r"
        if [[ "$_r" =~ ^[^[:space:]]+@[^[:space:]]+\.[^[:space:]]+$ ]] || [[ "$_r" =~ \.eml$ ]]; then
            echo "🛑 did you mean send? y/N"
            read -r typo_response
            case "$typo_response" in
                [yY]|[yY][eE][sS])
                    action="send"
                    if [[ "$_r" =~ \.eml$ ]]; then
                        log_warn "'sent' corrected to 'send' for file '$_r'"
                    else
                        log_warn "'sent' corrected to 'send' for recipient '$_r'"
                    fi
                    break 2
                    ;;
                *)
                    # User said no, continue with 'sent' action
                    break
                    ;;
            esac
        fi
    done
fi

# Infer 'send' if no action was given but rest contains an email recipient.
# This is the m-is-forgiving layer doing its job: `m foo@bar.com -c baz@qux.com`
# is unambiguously a send (no other action takes a bare email positional), so
# we save the user typing 'send' and announce the inference with a yellow ⚠️.
if [[ -z "$action" ]] && (( ${#rest[@]} > 0 )); then
    for _r in "${rest[@]}"; do
        if [[ "$_r" =~ ^[^[:space:]]+@[^[:space:]]+\.[^[:space:]]+$ ]]; then
            action="send"
            log_warn "no action given; inferring 'send' from recipient '$_r'"
            break
        fi
    done
fi

# defaults
action="${action:-i}"

# Set default account from config file, fallback to environment variable, then 'g'
if [[ -z "$account" ]]; then
    config_default=$(jq -r '.default_account // empty' "$MAIL_TOOLS_CONFIG" 2>/dev/null)
    account="${config_default:-${M_DEFAULT_ACCOUNT:-g}}"
fi

# pagination
page_offset=""; page_size=10; filtered_rest=()
for r in "${rest[@]+"${rest[@]}"}"; do
    if [[ "$r" =~ ^pp([0-9]+)$ ]]; then
        page_num="${BASH_REMATCH[1]}"
        if (( page_num > 1 )); then
            page_offset="$((( page_num - 1 ) * page_size))"
        fi
    else
        filtered_rest+=("$r")
    fi
done
rest=("${filtered_rest[@]+"${filtered_rest[@]}"}")

# look up account
IFS=: read -r gmail_flag chrome_profile <<< "${ACCTS[$account]}"
if [[ "$gmail_flag" == "!" ]]; then web=1; gmail_flag=""; fi

# build gmail-api-rw -e flag
# gmail_acct is the per-call account flag passed to gmail-api-rw.
# Stays empty when no account is selected (gmail-api-rw then uses its own
# default). When set, expands to (-e "<flag>"). Callers reference it as
# "${gmail_acct[@]+"${gmail_acct[@]}"}" — that idiom expands to nothing
# when the array is empty AND prevents `set -u` from screaming. Don't
# replace with a plain "${gmail_acct[@]}"; under `set -u` an unbound
# array reference fails, and on macOS bash 3 the empty-vs-unset
# distinction is fragile.
gmail_acct=()
if [[ -n "$gmail_flag" ]]; then
    # Pass the email address instead of the alias so gmail-api-rw can resolve it
    account_email="${EMAILS[$account]:-}"
    if [[ -n "$account_email" ]]; then
        gmail_acct=(-e "$account_email")
    else
        # Fallback to the gmail_flag (for backward compatibility)
        gmail_acct=(-e "$gmail_flag")
    fi
fi

# ========================================================================
# § ACTION ROUTER — dispatch on $action
# ========================================================================
# Each branch handles one action verb. Branches that route to gmail-api-rw
# do so via `exec`, so anything after the exec call in that branch is dead.
# Branches that may fall through to listing logic must NOT exec early.
case "$action" in
    i|q)
        if (( web )); then
            open_web inbox "${rest[@]+"${rest[@]}"}"
        else
            # ================================================
            # INBOX/QUERY ACTION: List messages with optional peek
            # ================================================
            # Check for -A open combination first (special case)
            has_attachment_save=0
            has_trailing_open=0
            for arg in "${rest[@]+"${rest[@]}"}"; do
                if [[ "$arg" == "-A" || "$arg" == "--save-attachments-only" ]]; then
                    has_attachment_save=1
                elif [[ "$arg" == "open" && "$has_attachment_save" == "1" ]]; then
                    has_trailing_open=1
                fi
            done

            # If we have -A open, remove 'open' from the action words list
            action_words="reply reply-all fwd draft open trash archive thread read unread sfwd sreply sreply-all urls grep"
            if [[ "$has_trailing_open" == "1" ]]; then
                action_words="reply reply-all fwd draft trash archive thread read unread sfwd sreply sreply-all urls grep"
            fi

            # Delegate arg parsing to the shared helper; q-action treats rest[0] as query.
            # Inbox/query handler accepts the full action set (excluding "peek"
            # and "forward" which only the sent handler treats as standalone).
            parse_action_args "positional-q" "$action" \
                "$action_words" \
                "${rest[@]+"${rest[@]}"}"
            query_string="$PA_QUERY"
            # -i/--important: prepend view-filter exclusions to the query so
            # noisy automated senders drop out of the listing (view-only). Skip
            # when an action word is in play (e.g. trash/archive): the filter is
            # for SCANNING, not for selecting messages to act on.
            if (( important_filter )) && [[ -z "$PA_ACTION_WORD" ]]; then
                _vf_excludes="$(_view_filter_excludes)"
                if [[ -n "$query_string" ]]; then
                    query_string="${_vf_excludes} ${query_string}"
                else
                    query_string="in:inbox ${_vf_excludes}"
                fi
            fi
            peek_flag=0
            message_numbers=("${PA_MESSAGE_NUMBERS[@]+"${PA_MESSAGE_NUMBERS[@]}"}")
            filtered_args=()
            action_word="$PA_ACTION_WORD"

            # If we found an action word, route to gmail-api-rw immediately
            if [[ -n "$action_word" ]]; then
                # Special handling for grep action
                if [[ "$action_word" == "grep" ]]; then
                    # Extract context lines (default to 5)
                    context_lines="${PA_TRAILING_ARGS[0]:-5}"
                    if [[ ! "$context_lines" =~ ^[0-9]+$ ]]; then
                        context_lines=5
                    fi

                    log_info "🔍 Searching for '$query_string' with $context_lines lines of context..."

                    # Get the message content and grep it (use -S for raw output to stdout)
                    gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]+"${message_numbers[@]}"}" -S | \
                        grep -A "$context_lines" -B "$context_lines" -i --color=always "$query_string" | \
                        less -R
                    exit $?
                fi

                exec gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]+"${message_numbers[@]}"}" "$action_word" "${PA_TRAILING_ARGS[@]+"${PA_TRAILING_ARGS[@]}"}"
            fi

            # Parse remaining arguments to find peek flags, verbose flags, meta flag, and message numbers
            verbose_flag=0
            meta_flag=0
            open_attachments_flag=0
            save_attachments_only_flag=0
            open_after_save_flag=0
            save_file=""
            raw_save_flag=0
            for i in "${!rest[@]}"; do
                arg="${rest[i]}"
                case "$arg" in
                    --raw)
                        raw_save_flag=1
                        ;;
                    -S|--save)
                        # -S FILE saves the raw .eml to FILE (backend OUTPUT
                        # positional). Bare -S keeps its legacy meaning (raw to
                        # stdout, relied on by the grep pipeline) by falling
                        # through to filtered_args.
                        next_idx=$(( i + 1 ))
                        if [[ -n "${rest[next_idx]:-}" && "${rest[next_idx]}" != -* ]]; then
                            save_file="${rest[next_idx]}"
                            rest[next_idx]="__M_CONSUMED__"
                        else
                            filtered_args+=("$arg")
                        fi
                        ;;
                    __M_CONSUMED__)
                        # filename already eaten by a preceding -S/--save
                        ;;
                    -p|--peek)
                        peek_flag=1
                        ;;
                    -v|--verbose)
                        verbose_flag=1
                        ;;
                    --meta)
                        meta_flag=1
                        ;;
                    --open-attachments)
                        open_attachments_flag=1
                        ;;
                    -A|--save-attachments-only)
                        save_attachments_only_flag=1
                        ;;
                    open)
                        if (( save_attachments_only_flag )); then
                            open_after_save_flag=1
                        fi
                        ;;
                    [0-9]|[0-9][0-9]|[0-9][0-9][0-9])
                        # Single message number — but if action is 'q' and this
                        # is rest[0], it's the query string (e.g. 'm q 31'), not an index.
                        if [[ "$action" == "q" && "$i" == "0" ]]; then
                            continue
                        fi
                        message_numbers+=("$arg")
                        ;;
                    [0-9]*-[0-9]* | [0-9]*,[0-9]*)
                        # Message range (e.g. 1-5, 45-120) or comma-list (1,3,8).
                        # Validate the full shape so we don't swallow stray tokens
                        # that merely contain a digit and a dash.
                        if [[ ! "$arg" =~ ^[0-9]+([,-][0-9]+)*$ ]]; then
                            filtered_args+=("$arg")
                            continue
                        fi
                        # Same q-action exception: rest[0] is the query, not an index.
                        if [[ "$action" == "q" && "$i" == "0" ]]; then
                            continue
                        fi
                        message_numbers+=("$arg")
                        ;;
                    *)
                        # Skip the query string argument for 'q' action (it's already in query_string)
                        if [[ "$action" == "q" && "$i" == "0" ]]; then
                            continue
                        fi
                        # Skip action words and flags that are handled separately
                        if [[ "$arg" == "$action_word" ]] || [[ "$arg" =~ ^(-v|--verbose|-A|--save-attachments-only|-p|--peek|--meta|--open-attachments|open)$ ]]; then
                            continue
                        fi
                        # Pass through other flags to gmail-api-rw (-x, -S, -t, etc.)
                        filtered_args+=("$arg")
                        ;;
                esac
            done

            # Default the index to 1 (most recent) when the user clearly meant
            # to act on a single message but left the number off. A read-intent
            # flag (-x/--headers, -p/--peek, -S FILE/--save, -A, --open-attachments,
            # or a bare -t/-S in filtered_args) signals "read one", so
            # `m q 'from:j2' -x` behaves like `m q 'from:j2' -x 1`. A bare query
            # with NO such flag still LISTS (and ranges still list), preserving
            # the deliberate listing default.
            if [[ ${#message_numbers[@]} -eq 0 ]]; then
                if (( peek_flag )) || (( save_attachments_only_flag )) \
                   || (( open_attachments_flag )) || [[ -n "$save_file" ]] \
                   || [[ " ${filtered_args[*]} " =~ " -x " ]] \
                   || [[ " ${filtered_args[*]} " =~ " --headers " ]] \
                   || [[ " ${filtered_args[*]} " =~ " -t " ]] \
                   || [[ " ${filtered_args[*]} " =~ " -S " ]]; then
                    message_numbers=(1)
                fi
            fi

            if [[ ${#message_numbers[@]} -gt 0 ]]; then
                if (( peek_flag )); then
                    # ============================================
                    # PEEK MODE: Save messages and invoke /peek
                    # ============================================
                echo "m: saving messages for peek..." >&2

                # Build and execute gmail-api-rw command with -peek flag
                # For pagination with peek, we need to fetch enough messages and let pagination filter later
                if [[ -n "$page_offset" ]]; then
                    page_num=$(( page_offset / page_size + 1 ))
                    total_needed=$(( page_num * page_size ))
                    peek_cmd=(gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" -n "$total_needed" ${query_string:+-q "$query_string"} "${message_numbers[@]}" -peek)
                else
                    peek_cmd=(gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]}" -peek)
                fi

                # Execute command - it will save files and copy "/peek {path}" to clipboard
                # Redirect output to suppress message display during peek
                if "${peek_cmd[@]}" >/dev/null 2>&1; then
                    # Get the "/peek {path}" command from clipboard
                    peek_command=$(pbpaste)

                    if [[ "$peek_command" =~ ^/peek ]]; then
                        echo "✅ $peek_command is on your clipboard" >&2
                    else
                        echo "✅ Messages saved, but clipboard doesn't contain peek command" >&2
                        echo "Clipboard: $peek_command" >&2
                    fi
                else
                    echo "❌ Failed to save messages for peek" >&2
                    exit 1
                fi
                else
                    # ============================================
                    # READ MODE: Open/read specific message numbers
                    # ============================================
                    # A bare range (e.g. 45-67) means "show the index rows for
                    # those messages", NOT open each body. Single numbers and
                    # comma-lists still open the message(s). Trigger only when
                    # every message-number token is a range and no attachment
                    # flags are in play.
                    all_ranges=1
                    max_index=0
                    for mn in "${message_numbers[@]}"; do
                        if [[ "$mn" != *-* ]]; then
                            all_ranges=0
                            break
                        fi
                        # Track the highest endpoint so we fetch enough rows.
                        end_idx="${mn##*-}"
                        [[ "$end_idx" =~ ^[0-9]+$ ]] && (( end_idx > max_index )) && max_index="$end_idx"
                    done
                    if (( all_ranges )) && (( ! save_attachments_only_flag )) \
                        && (( ! open_attachments_flag )) \
                        && [[ -z "$save_file" ]] \
                        && [[ ! " ${filtered_args[*]} " =~ " -S " ]]; then
                        # Build the sed program: one "Ns,Mp" clause per range.
                        sed_prog=""
                        for mn in "${message_numbers[@]}"; do
                            r_start="${mn%%-*}"
                            r_end="${mn##*-}"
                            sed_prog+="${r_start},${r_end}p;"
                        done
                        list_cmd=(gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" -n "$max_index" ${query_string:+-q "$query_string"})
                        (( meta_flag )) && list_cmd+=(--meta)
                        (( verbose_flag )) && list_cmd+=(-v)
                        list_cmd+=(-t)
                        if ! "${list_cmd[@]}" | sed -n "$sed_prog"; then
                            exit 1
                        fi
                        exit 0
                    fi

                    # Last-index-wins for !!-augmented single-message reads.
                    # `m q j2 2 5 -x` arrives here as message_numbers=(2 5): the
                    # user recalled `... 2` with !! and appended `5`, meaning
                    # "now show 5". For a single-message READ, a trailing bare
                    # index REPLACES the earlier one. Only collapse when EVERY
                    # token is a bare single integer (no ranges, no comma-lists);
                    # `2-5` or `1,3` stays multi (those are intentional). Bulk
                    # actions (trash/archive/...) never reach this block.
                    if (( ${#message_numbers[@]} > 1 )); then
                        _all_bare_single=1
                        for _mn in "${message_numbers[@]}"; do
                            if [[ "$_mn" != [0-9] && "$_mn" != [0-9][0-9] && "$_mn" != [0-9][0-9][0-9] ]]; then
                                _all_bare_single=0
                                break
                            fi
                        done
                        if (( _all_bare_single )); then
                            message_numbers=("${message_numbers[-1]}")
                        fi
                    fi

                    # When message numbers are specified without peek, read the messages
                    # Build command with optional attachment flag
                    # For pagination, fetch enough messages to cover the page
                    if [[ -n "$page_offset" ]]; then
                        page_num=$(( page_offset / page_size + 1 ))
                        total_needed=$(( page_num * page_size ))
                        read_cmd=(gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" -n "$total_needed" ${query_string:+-q "$query_string"} "${message_numbers[@]}")
                    else
                        read_cmd=(gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]}")
                    fi

                    # Add filtered flags
                    if [[ ${#filtered_args[@]} -gt 0 ]]; then
                        read_cmd+=("${filtered_args[@]}")
                    fi

                    if (( open_attachments_flag )); then
                        read_cmd+=(--open-attachments)
                    fi

                    if (( save_attachments_only_flag )); then
                        read_cmd+=(-A)
                        # For -A flag, just run the command without piping to less
                        if ! "${read_cmd[@]}"; then
                            exit 1
                        fi

                        # Check if 'open' was requested after -A
                        if (( open_after_save_flag )); then
                            _open_newest_attachment
                        fi
                    elif [[ -n "$save_file" ]]; then
                        # Save mode. Default: human-readable decoded text (-t
                        # render: headers + decoded body), so the file is ASCII
                        # not raw base64 MIME. --raw keeps the original bytes.
                        if (( raw_save_flag )); then
                            read_cmd+=("$save_file")
                            if ! "${read_cmd[@]}"; then
                                exit 1
                            fi
                        else
                            read_cmd+=(-t)
                            save_file="$(_versioned_path "$save_file")"
                            if "${read_cmd[@]}" > "$save_file"; then
                                echo "✅ Saved (decoded): $save_file" >&2
                            else
                                echo "⚠️ Failed to save $save_file" >&2
                                exit 1
                            fi
                        fi
                    else
                        # Check if -S flag is in filtered_args (raw output to stdout)
                        if [[ " ${filtered_args[*]} " =~ " -S " ]]; then
                            # Don't add -t or pipe to less for raw output
                            if ! "${read_cmd[@]}"; then
                                exit 1
                            fi
                        elif [[ " ${filtered_args[*]} " =~ " -x " || " ${filtered_args[*]} " =~ " --headers " ]]; then
                            # Headers-only: dump straight to stdout, no pager
                            read_cmd+=(-t)
                            if ! "${read_cmd[@]}"; then
                                exit 1
                            fi
                        else
                            read_cmd+=(-t)
                            if ! "${read_cmd[@]}" 2>&1 | less; then
                                exit 1
                            fi
                        fi
                    fi
                fi
            else
                # ============================================
                # NORMAL MODE: Show message list
                # ============================================
                # Build command with optional flags
                # For pagination, we need to fetch enough messages to show the requested page
                if [[ -n "$page_offset" ]]; then
                    # For page 2+, fetch (page_num * page_size) messages and filter later
                    page_num=$(( page_offset / page_size + 1 ))
                    total_needed=$(( page_num * page_size ))
                    gmail_cmd=(gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" -n "$total_needed" ${query_string:+-q "$query_string"} "${filtered_args[@]+"${filtered_args[@]}"}")
                else
                    # Page 1: just show page_size messages
                    gmail_cmd=(gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" -n "$page_size" ${query_string:+-q "$query_string"} "${filtered_args[@]+"${filtered_args[@]}"}")
                fi

                # Add flags based on what user requested
                if (( meta_flag )); then
                    gmail_cmd+=(--meta)
                fi
                if (( verbose_flag )); then
                    gmail_cmd+=(-v)
                fi
                if (( no_cache )); then
                    gmail_cmd+=(-N)
                fi
                gmail_cmd+=(-t)

                if [[ -n "$page_offset" ]]; then
                    # For page 2+, filter output to show only the desired page
                    start_line=$(( page_offset + 1 ))
                    end_line=$(( page_offset + page_size ))
                    if ! "${gmail_cmd[@]}" | sed -n "${start_line},${end_line}p"; then
                        exit 1
                    fi
                else
                    # Page 1: show normally
                    if ! "${gmail_cmd[@]}"; then
                        exit 1
                    fi
                fi
            fi
        fi
        ;;
    sent)
        if (( web )); then
            open_web sent "${rest[@]+"${rest[@]}"}"
        else
            # Delegate arg parsing to shared helper; sent uses literal "q <query>" form
            # Sent handler historically supports compose actions plus "peek".
            parse_action_args "literal-q" "$action" \
                "reply reply-all fwd forward draft peek urls" \
                "${rest[@]+"${rest[@]}"}"
            query_string="$PA_QUERY"
            action_word="$PA_ACTION_WORD"
            message_numbers=("${PA_MESSAGE_NUMBERS[@]+"${PA_MESSAGE_NUMBERS[@]}"}")
            rest=("${PA_REMAINING[@]+"${PA_REMAINING[@]}"}")
            peek_flag=0
            save_flag=0
            save_file=""
            raw_save_flag=0

            # If we found an action word, route to gmail-api-rw immediately
            if [[ -n "$action_word" ]]; then
                exec gmail-api-rw sent "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]+"${message_numbers[@]}"}" "$action_word" "${PA_TRAILING_ARGS[@]+"${PA_TRAILING_ARGS[@]}"}"
            fi

            # Parse remaining arguments to find peek flags, verbose flags, meta flag, and message numbers
            verbose_flag=0
            meta_flag=0
            headers_flag=0
            save_attachments_only_flag=0
            open_attachments_flag=0
            open_after_save_flag=0
            for i in "${!rest[@]}"; do
                arg="${rest[i]}"
                case "$arg" in
                    -p|--peek)
                        peek_flag=1
                        ;;
                    -v|--verbose)
                        verbose_flag=1
                        ;;
                    --meta)
                        meta_flag=1
                        ;;
                    -x|--headers)
                        headers_flag=1
                        ;;
                    --raw)
                        raw_save_flag=1
                        ;;
                    -A|--save-attachments-only)
                        save_attachments_only_flag=1
                        ;;
                    --open-attachments)
                        open_attachments_flag=1
                        ;;
                    open)
                        if (( save_attachments_only_flag )); then
                            open_after_save_flag=1
                        fi
                        ;;
                    -S|--save|-save)
                        # Save .eml to a file. A following non-flag token is the
                        # destination path. Default saves decoded/ASCII text;
                        # add --raw for original MIME bytes.
                        save_flag=1
                        next_idx=$(( i + 1 ))
                        if [[ -n "${rest[next_idx]:-}" && "${rest[next_idx]}" != -* ]]; then
                            save_file="${rest[next_idx]}"
                            rest[next_idx]="__M_CONSUMED__"
                        fi
                        ;;
                    __M_CONSUMED__)
                        # filename already eaten by a preceding -S/--save
                        ;;
                    [0-9]|[0-9][0-9]|[0-9][0-9][0-9])
                        # Single message number — but if action is 'q' and this
                        # is rest[0], it's the query string (e.g. 'm q 31'), not an index.
                        if [[ "$action" == "q" && "$i" == "0" ]]; then
                            continue
                        fi
                        message_numbers+=("$arg")
                        ;;
                    [0-9]*-[0-9]* | [0-9]*,[0-9]*)
                        # Message range (e.g. 1-5, 45-120) or comma-list (1,3,8).
                        # Validate the full shape so we don't swallow stray tokens
                        # that merely contain a digit and a dash.
                        if [[ ! "$arg" =~ ^[0-9]+([,-][0-9]+)*$ ]]; then
                            filtered_args+=("$arg")
                            continue
                        fi
                        # Same q-action exception: rest[0] is the query, not an index.
                        if [[ "$action" == "q" && "$i" == "0" ]]; then
                            continue
                        fi
                        message_numbers+=("$arg")
                        ;;
                esac
            done

            # Default the index to 1 (most recent sent) when a read-intent flag
            # is given without a number, mirroring the inbox/query branch:
            # `m sent -x` behaves like `m sent 1 -x`. A bare `m sent` still LISTS.
            if [[ ${#message_numbers[@]} -eq 0 ]]; then
                if (( peek_flag )) || (( headers_flag )) \
                   || (( save_attachments_only_flag )) \
                   || (( open_attachments_flag )) || [[ -n "$save_file" ]]; then
                    message_numbers=(1)
                fi
            fi

            # Last-index-wins for !!-augmented single-message reads, mirroring the
            # inbox/query branch: `m sent 2 5 -x` means "now show 5" (the 5 was
            # appended via !!). Collapse only when EVERY token is a bare single
            # integer; ranges/comma-lists stay multi. Sent action verbs
            # (sfwd/sreply/...) exec earlier, so they never reach this block.
            if (( ${#message_numbers[@]} > 1 )); then
                _all_bare_single=1
                for _mn in "${message_numbers[@]}"; do
                    if [[ "$_mn" != [0-9] && "$_mn" != [0-9][0-9] && "$_mn" != [0-9][0-9][0-9] ]]; then
                        _all_bare_single=0
                        break
                    fi
                done
                if (( _all_bare_single )); then
                    message_numbers=("${message_numbers[-1]}")
                fi
            fi

            # Execute based on flags
            if [[ ${#message_numbers[@]} -gt 0 ]]; then
                if (( save_attachments_only_flag )); then
                    # Save attachments from the sent message(s). Mirrors the
                    # inbox -A path: extract to /tmp/spool/attachments, and if
                    # 'open' trailed -A, open the newest extracted file.
                    attach_cmd=(gmail-api-rw sent "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]}" -A)
                    if ! "${attach_cmd[@]}"; then
                        exit 1
                    fi
                    if (( open_after_save_flag )); then
                        _open_newest_attachment
                    fi
                elif (( open_attachments_flag )); then
                    # Extract attachments and open them all (backend handles it).
                    gmail-api-rw sent "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]}" --open-attachments
                elif (( peek_flag )); then
                    # ============================================
                    # PEEK MODE: Save messages and invoke /peek
                    # ============================================
                    echo "m: saving messages for peek..." >&2

                    # Build and execute gmail-api-rw command with -peek flag
                    peek_cmd=(gmail-api-rw sent "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]}" -peek)

                    # Execute command - it will save files and copy "/peek {path}" to clipboard
                    # Redirect output to suppress message display during peek
                    if "${peek_cmd[@]}" >/dev/null 2>&1; then
                        # Get the "/peek {path}" command from clipboard
                        peek_command=$(pbpaste)

                        if [[ "$peek_command" =~ ^/peek ]]; then
                            echo "✅ $peek_command is on your clipboard" >&2
                        else
                            echo "⚠️ Expected /peek command in clipboard, got: $peek_command" >&2
                        fi
                    else
                        echo "⚠️ Failed to save messages for peek" >&2
                        exit 1
                    fi
                elif (( save_flag )); then
                    # Save mode. Default: human-readable (decoded headers + body,
                    # what -t renders) so the saved file is ASCII, not raw MIME
                    # with base64 chunks. Use --raw to keep the original bytes.
                    if (( raw_save_flag )); then
                        # Raw bytes via the backend OUTPUT positional. Bare -S
                        # (no file) omits it, so the backend saves to /tmp/spool.
                        gmail-api-rw sent "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]}" ${save_file:+"$save_file"}
                    elif [[ -n "$save_file" ]]; then
                        save_file="$(_versioned_path "$save_file")"
                        if gmail-api-rw sent "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]}" -t > "$save_file"; then
                            echo "✅ Saved (decoded): $save_file" >&2
                        else
                            echo "⚠️ Failed to save $save_file" >&2
                            exit 1
                        fi
                    else
                        # Bare -S, no file: decoded text to a spool file.
                        mkdir -p /tmp/spool
                        _m_spool="$(_versioned_path "/tmp/spool/$(date +%Y-%m-%d)-sent-msg.txt")"
                        if gmail-api-rw sent "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]}" -t > "$_m_spool"; then
                            echo "✅ Saved (decoded): $_m_spool" >&2
                        else
                            exit 1
                        fi
                    fi
                elif (( verbose_flag )); then
                    # Verbose mode (no paging)
                    gmail-api-rw sent "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]}" -v
                else
                    # Default: view with paging
                    gmail_cmd=(gmail-api-rw sent "${gmail_acct[@]+"${gmail_acct[@]}"}" ${query_string:+-q "$query_string"} "${message_numbers[@]}")
                    if (( meta_flag )); then
                        gmail_cmd+=(--meta)
                    fi
                    if (( headers_flag )); then
                        gmail_cmd+=(-x)
                    fi
                    gmail_cmd+=(-t)
                    if (( headers_flag )); then
                        # Headers-only: dump straight to stdout, no pager
                        "${gmail_cmd[@]}"
                    else
                        "${gmail_cmd[@]}" | less
                    fi
                fi
            else
                # No message numbers: show listing
                # For pagination, we need to fetch enough messages to show the requested page
                if [[ -n "$page_offset" ]]; then
                    # For page 2+, fetch (page_num * page_size) messages and filter later
                    page_num=$(( page_offset / page_size + 1 ))
                    total_needed=$(( page_num * page_size ))
                    gmail_cmd=(gmail-api-rw sent "${gmail_acct[@]+"${gmail_acct[@]}"}" -n "$total_needed" ${query_string:+-q "$query_string"})
                else
                    # Page 1: just show page_size messages
                    gmail_cmd=(gmail-api-rw sent "${gmail_acct[@]+"${gmail_acct[@]}"}" -n "$page_size" ${query_string:+-q "$query_string"})
                fi

                if (( meta_flag )); then
                    gmail_cmd+=(--meta)
                fi
                gmail_cmd+=(-t)

                if [[ -n "$page_offset" ]]; then
                    # For page 2+, filter output to show only the desired page
                    start_line=$(( page_offset + 1 ))
                    end_line=$(( page_offset + page_size ))
                    if ! "${gmail_cmd[@]}" | sed -n "${start_line},${end_line}p"; then
                        exit 1
                    fi
                else
                    # Page 1: show normally
                    if ! "${gmail_cmd[@]}"; then
                        exit 1
                    fi
                fi
            fi
        fi
        ;;
    send|c)
        # ================================================================
        # SEND ACTION: Universal email sending with smart routing
        # ================================================================
        #
        # SPECIAL HANDLING: Direct 'send' command compatibility
        # When called as 'send -e account [args]', we need to extract
        # the account from the -e flag since external aliases use this format
        #
        #
        # PURPOSE:
        # - Route emails to correct backend (SMTP vs Gmail API) per account
        # - Handle attachments, .eml files, compose mode automatically
        # - Preserve user interface simplicity ("m u send file.eml -a att.pdf")
        #
        # CURRENT ROUTING STRATEGY:
        # 1. Detect advanced features (-a, -c, -b, --summary, --draft, -H, -t)
        # 2. If advanced features → gmail-api-rw (supports attachments/headers)
        # 3. If simple send → smart_send() → send script → account-specific routing
        #
        # ACCOUNT CONSTRAINTS THAT DRIVE ROUTING:
        # - Columbia (u): MUST use Gmail API (no SMTP access)
        # - Gmail/hackNY/etc (g,j,h,l,z): CAN use SMTP or API
        # - Attachments: Require either gmail-api-rw OR mutt wrapper with -a support
        # - .eml files: Must use -H flag for gmail-api-rw, direct path for mutt
        #
        # FUTURE CLAUDE NOTES:
        # - This could be consolidated to eliminate the send script entirely
        # - All routing logic from send script could move here
        # - Would need to preserve external compatibility (ejk, noemie aliases)
        # - Key insight: m now uses unified ~/.config/mail-tools/accounts.json
        #
        # MISUSE GUARD: `m send 1 fwd addr` / `m send 1 reply` etc.
        # The compose verb treats every positional as a recipient, so an index
        # plus a message-action word would be coined into junk recipients
        # (1@gmail.com, fwd@gmail.com) and nearly emailed to strangers. If the
        # args begin with <integer> <message-action>, the user meant the SENT
        # action (sfwd/sreply) or the per-message action, not compose. Refuse
        # loudly with the correct command instead of fabricating recipients.
        if (( ${#rest[@]} >= 2 )) \
           && [[ "${rest[0]}" =~ ^[0-9]+$ ]] \
           && [[ " reply reply-all fwd forward draft open trash archive thread read unread urls " == *" ${rest[1]} "* ]]; then
            _idx="${rest[0]}"; _act="${rest[1]}"; _tail=("${rest[@]:2}")
            case "$_act" in
                fwd|forward) _suggest="m sent ${_idx} fwd ${_tail[*]}  (or: m sfwd ${_idx} ${_tail[*]})" ;;
                reply)       _suggest="m sent ${_idx} reply  (or: m sreply ${_idx})" ;;
                reply-all)   _suggest="m sent ${_idx} reply-all  (or: m sreply-all ${_idx})" ;;
                *)           _suggest="m sent ${_idx} ${_act} ${_tail[*]}" ;;
            esac
            log_error "'send' composes a new message; '${_idx} ${_act}' is a message action, not a recipient."
            echo "   You typed:  m send ${rest[*]}" >&2
            echo "   To ${_act} message #${_idx}, use:" >&2
            echo "       ${_suggest}" >&2
            echo "   (Refusing rather than emailing '${_idx}@...'/'${_act}@...'.)" >&2
            exit 2
        fi
        if (( web )); then
            # Web mode: open Gmail compose in browser
            open_web compose "${rest[@]+"${rest[@]}"}"
        else
            # ============================================================
            # STEP 1: Detect if command needs advanced email features
            # ============================================================
            # These flags require gmail-api-rw because the send script's
            # SMTP path (via mutt) doesn't support them all consistently:
            # -a/--attach: Attachments (both backends support, but different syntax)
            # -c/--cc: CC headers (gmail-api-rw specific)
            # -b/--bcc: BCC headers (gmail-api-rw specific)
            # --summary/--draft: gmail-api-rw specific features
            # -H: Pre-built .eml file (both support, but different handling)
            # -t: Text preview (gmail-api-rw specific)
            #
            has_attachment_flags=0
            for arg in "${rest[@]+"${rest[@]}"}"; do
                case "$arg" in
                    -a|--attach|-c|--cc|-b|--bcc|--summary|--draft|-H|-t)
                        has_attachment_flags=1
                        break
                        ;;
                esac
            done

            if (( has_attachment_flags )); then
                # ====================================================
                # ADVANCED FEATURES PATH: Route to gmail-api-rw
                # ====================================================
                # WHY gmail-api-rw:
                # - Supports all advanced flags consistently
                # - Required for API-only accounts (Columbia)
                # - Handles attachments, CC/BCC, drafts, previews
                #
                # CRITICAL FLAGS:
                # - gmail_acct: Account selection (-e cu, -e hNY, etc.)
                # - --via-send: Bypasses gmail-api-rw's safety check
                #
                echo "m: send via ${gmail_flag:-default} with attachments/advanced features" >&2

                # ================================================
                # STEP 2-PRE: Resolve m-aliases for Cc/Bcc up front
                # ================================================
                # This advanced path execs gmail-api-rw directly, bypassing
                # direct_send (where the simple path resolves -c/-b through
                # ~/.config/m/aliases). Resolve them here too so `-c ah` ->
                # aya.horikoshi@gmail.com. A bare word that is NOT an m-alias is
                # left as-is and handed to gmail-api-rw, which tries the contacts
                # file and then refuses unresolved Cc/Bcc loudly (see
                # _resolve_address_list there) rather than bouncing at Gmail.
                resolved_rest=()
                ri=0
                while (( ri < ${#rest[@]} )); do
                    case "${rest[ri]}" in
                        -c|--cc|-b|--bcc)
                            resolved_rest+=("${rest[ri]}" \
                                "$(_resolve_alias "${rest[ri+1]}")")
                            ((ri+=2))
                            ;;
                        *)
                            resolved_rest+=("${rest[ri]}")
                            ((ri+=1))
                            ;;
                    esac
                done
                rest=("${resolved_rest[@]+"${resolved_rest[@]}"}")

                # ================================================
                # STEP 2A: Fix .eml file argument formatting
                # ================================================
                # PROBLEM: gmail-api-rw expects "-H file.eml", not bare "file.eml"
                # SOLUTION: Auto-detect .eml files and prepend -H flag
                # This allows users to write "m u send file.eml -a att.pdf"
                # instead of the more verbose "m u send -H file.eml -a att.pdf"
                #
                fixed_args=()
                fa_i=0
                while (( fa_i < ${#rest[@]} )); do
                    arg="${rest[fa_i]}"
                    if [[ "$arg" == -H ]]; then
                        # Explicit -H: its value must be a single .eml path, not
                        # another flag or a missing arg. -H -H file (doubled flag)
                        # or a trailing -H would otherwise feed "-H" to the backend
                        # as the .eml path and produce a cryptic
                        # "argument -H: expected one argument".
                        next="${rest[fa_i+1]-}"
                        if [[ -z "${rest[fa_i+1]+x}" || "$next" == -* ]]; then
                            if [[ "$next" == -H ]]; then
                                log_error "I think you put in -H -H. The -H flag needs a single .eml file right after it (e.g. -H draft.eml). Please fix and re-run."
                            else
                                log_error "-H needs a single .eml file right after it (e.g. -H draft.eml); it looks like the filename is missing. Please fix and re-run."
                            fi
                            exit 2
                        fi
                        # Pass -H and its file through together so the bare-.eml
                        # branch below does NOT prepend a second -H.
                        fixed_args+=(-H "$next")
                        ((fa_i+=2))
                    elif [[ "$arg" == -a || "$arg" == --attach ]]; then
                        # -a/--attach needs an attachment path, not another flag
                        # or a missing arg.
                        next="${rest[fa_i+1]-}"
                        if [[ -z "${rest[fa_i+1]+x}" || "$next" == -* ]]; then
                            log_error "-a needs an attachment path right after it (e.g. -a file.pdf); it looks like one is missing. Please fix and re-run."
                            exit 2
                        fi
                        fixed_args+=("$arg" "$next")
                        ((fa_i+=2))
                    elif [[ "$arg" =~ \.eml$ ]]; then
                        # Bare .eml file (no preceding -H): add the -H flag for the
                        # backend, which expects "-H file.eml" not bare "file.eml".
                        fixed_args+=(-H "$arg")
                        ((fa_i+=1))
                    else
                        # Regular argument, pass through unchanged
                        fixed_args+=("$arg")
                        ((fa_i+=1))
                    fi
                done

                if (( dry_run )); then
                    echo "DRY-RUN: gmail-api-rw ${gmail_acct[*]+${gmail_acct[*]}} send --via-send ${fixed_args[*]+${fixed_args[*]}}"
                    exit 0
                fi
                # Execute gmail-api-rw with fixed arguments
                # exec replaces current process (no return to m script)
                exec gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" send --via-send "${fixed_args[@]+"${fixed_args[@]}"}"
            else
                # ====================================================
                # SIMPLE SEND PATH: Direct routing (no external script)
                # ====================================================
                # WHY direct routing:
                # - All logic now consolidated in m script
                # - Handles account-specific routing (API vs SMTP per account)
                # - Supports both .eml files and compose mode
                # - No intermediate script calls or overhead
                #
                # FLOW: m → direct_send() → account routing → backend
                #
                dry_pass=()
                (( dry_run )) && dry_pass=(--dry-run)
                echo "m: send via ${gmail_flag:-default}$( (( dry_run )) && echo ' (dry-run)')" >&2
                direct_send ${gmail_flag:+-e "$gmail_flag"} "${dry_pass[@]+"${dry_pass[@]}"}" "${rest[@]+"${rest[@]}"}"
            fi
        fi
        ;;
    draft|reply|reply-all|fwd|open|trash|archive|thread|read|unread|sfwd|sreply|sreply-all)
        # Pass-through to gmail-api-rw
        # Special handling for reply/fwd actions: default to message #1 if no index provided
        if [[ "$action" =~ ^(reply|reply-all|fwd|sfwd|sreply|sreply-all)$ ]] && [[ ${#rest[@]} -eq 0 ]]; then
            log_warn "No message index provided, assuming message #1"
            exec gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" "$action" "1"
        else
            exec gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" "$action" "${rest[@]+"${rest[@]}"}"
        fi
        ;;
    urls)
        # Extract URLs from message
        exec gmail-api-rw "${gmail_acct[@]+"${gmail_acct[@]}"}" "$action" "${rest[@]+"${rest[@]}"}"
        ;;
    scheduled)
        # Manage scheduled sends
        case "${rest[0]:-list}" in
            list)
                _list_scheduled_sends
                ;;
            cancel)
                if [[ -z "${rest[1]:-}" ]]; then
                    log_error "cancel requires a draft ID"
                    echo "Usage: m scheduled cancel <draft_id>" >&2
                    exit 1
                fi
                _cancel_scheduled_send "${rest[1]}"
                ;;
            status)
                if [[ -z "${rest[1]:-}" ]]; then
                    log_error "status requires a draft ID"
                    echo "Usage: m scheduled status <draft_id>" >&2
                    exit 1
                fi
                _status_scheduled_send "${rest[1]}"
                ;;
            *)
                log_error "Unknown scheduled action: ${rest[0]}"
                echo "Usage: m scheduled [list|cancel|status]" >&2
                exit 1
                ;;
        esac
        ;;
    *)
        echo "m: unknown action '$action'" >&2
        exit 1
        ;;
esac
