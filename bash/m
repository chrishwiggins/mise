#!/opt/homebrew/bin/bash

# Set up helper script paths
SCRIPT_DIR="$(dirname "$(realpath "$0")")"
AUX_DIR="$(dirname "$SCRIPT_DIR")/aux/m"

# ============================================================================
# m - Multi-Account Email Dispatcher
# ============================================================================
#
# ARCHITECTURAL OVERVIEW FOR FUTURE CLAUDE INSTANCES:
#
# This is the central dispatcher for a multi-account email system. It provides
# a unified interface across 6+ email accounts while routing to appropriate
# backends (Gmail API vs SMTP) based on account configuration.
#
# KEY DESIGN PRINCIPLES:
# 1. **Account Abstraction**: Users think in account letters (g,j,u,l,h,n,z)
#    not email addresses. This script maps letters to emails via JSON config.
# 2. **Transport Agnostic**: Automatically routes to Gmail API or SMTP based
#    on account config (muttrc: "/dev/null" = API, real path = SMTP)
# 3. **Mode Consistency**: All actions support -save/-v/default(more) modes
# 4. **Web/CLI Duality**: Every action works in both web browser and CLI
# 5. **PII-Free**: No hardcoded email addresses; all config external
#
# CRITICAL EXTERNAL DEPENDENCIES:
# - ~/.config/mail-tools/accounts.json (account config, created by setup)
# - gmail-api-rw (Gmail API client, handles OAuth, caching, etc)
# - gmail-smtp-w / neomutt wrapper (SMTP sending for non-API accounts)
# - send script (smart routing layer that chooses API vs SMTP per account)

set -euo pipefail

# --- config ---
MAIL_TOOLS_CONFIG="${MAIL_TOOLS_CONFIG:-$HOME/.config/mail-tools/accounts.json}"
M_LIST_CACHE_TTL="${M_LIST_CACHE_TTL:-30}" # cache listings for 30s
M_QUIET_MODE="${M_QUIET_MODE:-0}"

# Source optional user config
if [[ -f "$HOME/.config/m/config" ]]; then
    source "$HOME/.config/m/config"
elif [[ -f "$AUX_DIR/m-config.bash" ]]; then
    source "$AUX_DIR/m-config.bash"
fi

# Initialize configuration
declare -A EMAILS=()
declare -A ACCTS=()
declare -A LABELS=()

# Function to load account configuration from external files
load_mail_config() {
# ========================================================================
# LOAD_MAIL_CONFIG: Dynamic account configuration system
# ========================================================================
#
# PURPOSE:
# - Load all account information from JSON config (PII-free code design)
# - Build associative arrays for runtime account resolution
# - Replace hardcoded account mappings with dynamic configuration
#
# WHY DYNAMIC CONFIG:
# - Keeps PII out of ~/mise/ (public) code
# - Allows users to add accounts without editing script
# - Single source of truth for account information
# - Supports multiple account types (SMTP, API, web)
#
# CONFIG FILE: ~/.config/mail-tools/accounts.json
# FORMAT:
# {
#   "accounts": {
#     "g": {
#       "email": "user@gmail.com",
#       "chrome_profile": "Default",
#       "label": "Personal",
#       "gmail_flag": ""  // Optional: backend routing flag
#     },
#     "u": {
#       "email": "user@columbia.edu",
#       "chrome_profile": "Profile 1",
#       "label": "Work",
#       "gmail_flag": "cu"
#     }
#   }
# }
#
# GLOBAL ARRAYS POPULATED:
# - EMAILS[alias] = email address (for display, validation)
# - LABELS[alias] = human-readable name (for UI, help)
# - ACCTS[alias] = "gmail_flag:chrome_profile" (for backend routing)
#
# ROUTING DECISION:
# - gmail_flag determines backend tool selection
# - chrome_profile determines web browser routing
# - Empty gmail_flag = default/primary gmail account
# - Non-empty gmail_flag = specific backend (-e flag for gmail-api-rw)
#
local config_file="$MAIL_TOOLS_CONFIG"

# ================================================
# STEP 1: Try new JSON config (preferred method)
# ================================================
if [[ -f "$config_file" ]] && command -v jq >/dev/null 2>&1; then
    local accounts
    # Extract account data: alias|email|chrome_profile|label|gmail_flag
    # The jq query safely handles missing optional fields (label, gmail_flag)
    accounts=$(jq -r '.accounts | to_entries[] | "\(.key)|\(.value.email)|\(.value.chrome_profile)|\(.value.label // "")|\(.value.gmail_flag // "")"' "$config_file" 2>/dev/null)

    if [[ -n "$accounts" ]]; then
        # ============================================
        # STEP 1A: Parse JSON data into arrays
        # ============================================
        while IFS='|' read -r alias email chrome_profile label gmail_flag; do
            # Basic account info
            EMAILS["$alias"]="$email"
            LABELS["$alias"]="${label:-$alias}"  # Default to alias if no label

            # ========================================
            # STEP 1B: Build backend routing string
            # ========================================
            # Format: "gmail_flag:chrome_profile"
            # - gmail_flag: Backend tool routing (-e flag for gmail-api-rw)
            # - chrome_profile: Browser profile for web interface
            #
            # Examples:
            # - "cu:Profile 1" = Columbia account, Profile 1 browser
            # - ":Default" = Default gmail, Default browser profile
            #
            if [[ -n "$gmail_flag" ]]; then
                # Explicit gmail_flag specified in config
                ACCTS["$alias"]="$gmail_flag:$chrome_profile"
            elif [[ "$alias" == "g" ]]; then
                # Special case: 'g' alias gets empty gmail_flag (default account)
                ACCTS["$alias"]=":$chrome_profile"
            else
                # ====================================
                # STEP 1C: Derive gmail_flag from alias
                # ====================================
                # Fallback for accounts without explicit gmail_flag
                local short_name="$alias"
                    # Preserve known legacy flags if possible or just use alias
                    case "$alias" in
                        j|joint) short_name="joint" ;;
                        u|cu)    short_name="cu" ;;
                        l|lake)  short_name="lake" ;;
                        h|hNY)   short_name="hNY" ;;
                    esac
                    ACCTS["$alias"]="$short_name:$chrome_profile"
                fi
            done <<< "$accounts"
            return 0
        fi
    fi

    # ERROR: Configuration required - no hardcoded fallback for PII-free operation
    echo "m: ERROR - No email configuration found!" >&2
    echo "m: Please create ~/.config/mail-tools/accounts.json" >&2
    echo "m: See SETUP.md for configuration instructions" >&2
    exit 1
}

load_mail_config

# ========================================================================
# ACCOUNT ROUTING FUNCTIONS (CONSOLIDATED FROM SEND SCRIPT)
# ========================================================================
# These functions handle the core routing decision: API vs SMTP
# Previously in separate send script, now integrated into m for simplicity

# Look up muttrc path for an account slug or email substring
# Reads ~/.config/gmails/accounts to find account configuration
# Returns muttrc path, or empty string if no match
_lookup_muttrc() {
    local needle
    needle=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
    local match_path=""
    local match_count=0
    local accounts_file="$HOME/.config/gmails/accounts"

    [[ ! -f "$accounts_file" ]] && return

    # First pass: find all partial matches
    while IFS=' ' read -r acct path; do
        [[ -z "$acct" || "$acct" == \#* ]] && continue
        local acct_lower
        acct_lower=$(printf '%s' "$acct" | tr '[:upper:]' '[:lower:]')
        if [[ "$acct_lower" == *"$needle"* ]]; then
            match_path="$path"
            ((match_count++))
        fi
    done < "$accounts_file"

    # If multiple matches, prefer exact match
    if (( match_count > 1 )); then
        while IFS=' ' read -r acct path; do
            [[ -z "$acct" || "$acct" == \#* ]] && continue
            local acct_lower
            acct_lower=$(printf '%s' "$acct" | tr '[:upper:]' '[:lower:]')
            if [[ "$acct_lower" == "$needle" ]]; then
                match_path="$path"
                break
            fi
        done < "$accounts_file"
    fi

    echo "$match_path"
}

# Get the default account's muttrc (first account with @ in name)
_default_muttrc() {
    local accounts_file="$HOME/.config/gmails/accounts"
    [[ ! -f "$accounts_file" ]] && return

    while IFS=' ' read -r acct path; do
        [[ -z "$acct" || "$acct" == \#* ]] && continue
        if [[ "$acct" == *@* ]]; then
            echo "$path"
            return
        fi
    done < "$accounts_file"
}

# CORE ROUTING DECISION: API vs SMTP
# This determines which backend to use based on account configuration
# API-only accounts (like Columbia) have muttrc="/dev/null"
# SMTP accounts have real muttrc files with credentials
_is_api_only() {
    local muttrc="$1"
    [[ "$muttrc" == "/dev/null"* || ! -f "$muttrc" ]]
}

# ========================================================================
# DIRECT SEND IMPLEMENTATION (REPLACES SEND SCRIPT)
# ========================================================================
# This function contains the core logic from the send script
# Handles file sending, attachment processing, and backend routing

direct_send() {
    local -a send_args=("$@")

    # Parse arguments (simplified version of send script's parsing)
    local account=""
    local done_flag=0
    local -a args=()
    local -a attachments=()

    local i=0
    while [[ $i -lt ${#send_args[@]} ]]; do
        case "${send_args[i]}" in
            -e)
                account="${send_args[i+1]}"
                ((i+=2))
                ;;
            -H)
                # Mutt compatibility: treat -H file as just the file
                args+=("${send_args[i+1]}")
                ((i+=2))
                ;;
            -a)
                attachments+=("${send_args[i+1]}")
                ((i+=2))
                ;;
            -d|--done)
                done_flag=1
                ((i++))
                ;;
            *)
                args+=("${send_args[i]}")
                ((i++))
                ;;
        esac
    done

    # Build attachment arguments
    local -a attach_args=()
    for att in "${attachments[@]+"${attachments[@]}"}"; do
        attach_args+=(-a "$att")
    done

    # Resolve muttrc for account
    local muttrc
    if [[ -n "$account" ]]; then
        muttrc=$(_lookup_muttrc "$account")
        if [[ -z "$muttrc" ]]; then
            echo "m: unknown account '$account'" >&2
            return 1
        fi
    else
        muttrc=$(_default_muttrc)
        if [[ -z "$muttrc" ]]; then
            echo "m: no default account configured in ~/.config/gmails/accounts" >&2
            return 1
        fi
    fi

    # Check if we have .eml files (file mode)
    local file_mode=0
    for arg in "${args[@]}"; do
        if [[ "$arg" == *.eml ]]; then
            file_mode=1
            break
        fi
    done

    # Route to appropriate backend
    if (( file_mode )); then
        # File send mode
        for arg in "${args[@]}"; do
            if [[ "$arg" == *.eml ]]; then
                if [[ ! -f "$arg" ]]; then
                    echo "m: file not found: $arg" >&2
                    return 1
                fi

                local abspath="$(cd "$(dirname "$arg")" && pwd)/$(basename "$arg")"

                if _is_api_only "$muttrc"; then
                    echo "m: ${account:-default} via gmail API" >&2
                    gmail-api-rw ${account:+-e "$account"} send --via-send -H "$abspath" "${attach_args[@]+"${attach_args[@]}"}"
                else
                    echo "m: ${account:-default} via mutt" >&2
                    echo | /Users/wiggins/gd/local/seiton/bash/mutt -F "$muttrc" -H "$abspath" "${attach_args[@]+"${attach_args[@]}"}"
                fi

                echo "$abspath sent"

                if (( done_flag )); then
                    local clip="/sent $abspath"
                    printf '%s' "$clip" | pbcopy
                    echo "Copied to clipboard: $clip" >&2
                fi
            fi
        done
    else
        # Compose mode
        if _is_api_only "$muttrc"; then
            echo "m: compose mode not supported for API-only accounts; write a .eml file instead" >&2
            return 1
        fi

        # Use mutt for compose mode
        /Users/wiggins/gd/local/seiton/bash/mutt -F "$muttrc" "${args[@]}" "${attach_args[@]+"${attach_args[@]}"}"
        echo "m: ${account:-default} via mutt" >&2
    fi
}

# Validate M_DEFAULT_ACCOUNT
if [[ -n "${M_DEFAULT_ACCOUNT:-}" ]]; then
    if [[ -z "${EMAILS[$M_DEFAULT_ACCOUNT]:-}" ]]; then
        valid_accts=$(printf '%s, ' "${!EMAILS[@]}" | sed 's/, $//')
        echo "m: invalid M_DEFAULT_ACCOUNT='${M_DEFAULT_ACCOUNT}'. Valid: $valid_accts" >&2
        exit 1
    fi
fi

if [[ "${M_RANGE_WARNING_LIMIT:-50}" -lt 1 ]]; then
    M_RANGE_WARNING_LIMIT=50
fi

# --- helper functions ---

log_info() { (( M_QUIET_MODE )) || echo -e "\033[0;34mℹ\033[0m $*" >&2; }
log_ok() { (( M_QUIET_MODE )) || echo -e "\033[0;32m✅\033[0m $*" >&2; }
log_warn() { echo -e "\033[0;33m⚠️\033[0m $*" >&2; }
log_error() { echo -e "\033[0;31m❌\033[0m $*" >&2; }

log_command() {
    if [[ -n "${M_ANALYTICS_ENABLED:-}" ]] && (( M_ANALYTICS_ENABLED )); then
        # Silent background logging if possible
        (echo "$(date '+%Y-%m-%d %H:%M:%S')|$account|$action|${rest[*]:-}" >> "$HOME/.cache/m/usage.log" 2>/dev/null || true) &
    fi
}

open_web() {
    local folder="$1"; shift
    local profile="$chrome_profile"
    log_info "Opening Gmail ($folder) in browser (profile $profile)..."
    log_command "$@"
    exec gmail_web "$profile" "$folder" "$@"
}

# smart_send() function removed - logic consolidated into direct_send()
# This eliminates the need for the external send script

ACTIONS_SHORT="i sent q d x urls"
ACTIONS_SEND="send c"
ACTIONS_PASSTHRU="draft reply reply-all fwd open trash archive thread read unread sfwd sreply sreply-all"

usage() {
    local topic="${1:-basic}"

    case "$topic" in
        basic|"")
            cat <<EOF
m - unified mail dispatcher

USAGE
    m [action] [account] [flags] [args...]
    m --help=TOPIC    Show detailed help for specific topic

BASIC ACTIONS
    m                 Default inbox (first 20 messages)
    m pp2             Page 2 inbox (messages 21-40)
    m sent            Sent messages
EOF
            local example_acct="${M_DEFAULT_ACCOUNT:-g}"
            if [[ -n "${EMAILS[$example_acct]:-}" ]]; then
                local lab="${LABELS[$example_acct]:-$example_acct}"
                echo "    m $example_acct               $lab inbox"
            fi
            cat <<'EOF'
    m q "from:alice"  Search messages
    m reply 3         Reply to message #3
    m fwd 3 user@ex   Forward message #3
    m m 3             Archive message #3 (removes from inbox)

FLAGS
    -w, --web         Force browser instead of CLI
    -N, --no-cache    Bypass listing cache; force fresh fetch
    --quiet           Suppress progress messages
    --dry-run         Preview destructive actions
    -h, --help        This help

HELP TOPICS
    --help=actions    All available actions
    --help=accounts   Account configuration
    --help=search     Advanced search syntax
    --help=config     Configuration options
EOF
            ;;
        actions)
            cat <<'EOF'
ACTIONS - Complete Reference

READING
    i         inbox (default)        List recent messages
    sent                             List sent messages
    q         search                 Search with Gmail query syntax
    d         drafts                 View drafts (web only)
    x         spam                   Check spam folder

COMPOSING
    send      Send .eml file or compose (routes to send script)
    c         Same as send (compose shorthand)
    draft     Save message to drafts

MESSAGE ACTIONS
    reply INDEX                      Reply to message
    reply-all INDEX                  Reply-all (includes To and Cc)
    fwd INDEX RECIPIENT             Forward message
    open INDEX                      Open in Gmail web UI
    trash INDEX                     Move to trash
    archive INDEX                   Archive message (removes from inbox)
    m INDEX                         Archive message (short syntax)
    read/unread INDEX               Mark read/unread

SENT MESSAGE ACTIONS
    sfwd INDEX RECIPIENT            Forward a SENT message
    sreply INDEX                    Reply to a SENT message
    sreply-all INDEX                Reply-all to a SENT message
EOF
            ;;
        accounts)
            echo "ACCOUNTS"
            echo ""
            echo "CONFIGURED ACCOUNTS"
            for acct in "${!EMAILS[@]}"; do
                email="${EMAILS[$acct]}"
                desc="${ACCTS[$acct]:-}"
                label="${LABELS[$acct]:-}"
                if [[ -n "$email" ]]; then
                    printf "    %-4s %-30s %-15s [%s]\n" "$acct" "$email" "($desc)" "$label"
                else
                    printf "    %-4s %-30s %-15s [%s]\n" "$acct" "(web-only)" "($desc)" "$label"
                fi
            done | sort
            echo ""
            echo "USAGE"
            echo "    m [action] [account]               Use specific account"
            local first_acct=$(printf '%s\n' "${!EMAILS[@]}" | sort | head -1)
            if [[ -n "$first_acct" ]]; then
                echo "    m i $first_acct                             ${LABELS[$first_acct]:-} inbox"
            fi
            ;;
        search)
