#!/opt/homebrew/bin/bash

# Set up helper script paths
SCRIPT_DIR="$(dirname "$(realpath "$0")")"
AUX_DIR="$(dirname "$SCRIPT_DIR")/aux/m"

# ============================================================================
# m — multi-account email dispatcher (bash frontend)
# ============================================================================
#
# READ THIS BEFORE EDITING. Future Claude / future Chris: this is the map.
#
# § MENTAL MODEL
#   m is the user-forgiving frontend. gmail-api-rw is the strict backend.
#   Foibles go in m: argument flexibility, missing-index defaults, cache
#   warming, comma-splitting recipients, auto-eml for API-only accounts.
#   Infra goes in gmail-api-rw: OAuth, MIME, the actual API calls.
#   Rule of thumb: if you find yourself writing "be nice about X" code,
#   it belongs here, not in gmail-api-rw.
#
# § PUBLIC API (do NOT break — colleagues' aliases call this)
#   Account aliases: g j u cu l h hNY n z (resolved via accounts.json)
#   Actions:         i sent q d x urls send c draft reply reply-all fwd
#                    open trash archive thread read unread sfwd sreply
#                    sreply-all peek
#   Flags:           -w/--web -N/--no-cache --quiet -h/--help --version
#                    --dry-run --urls --cal -p/--peek -v --meta -S -t -x
#                    -A --save-attachments-only -a -c -b -s -d/--done
#                    -H --outbox
#   Pagination:      ppN tokens (e.g. pp2 = page 2)
#   This file lives in ~/mise (public). NEVER reference seiton paths here.
#
# § SECTION MAP (anchor strings; grep for "§ <name>")
#   § DEPENDENCY CHECKS         — startup validation (jq, python3, .venv)
#   § CONFIG                    — load accounts.json into ACCTS/EMAILS/LABELS
#   § ROUTING HELPERS           — _lookup_muttrc, _is_api_only
#   § DIRECT SEND               — direct_send() unified send pipeline
#   § LOGGING                   — log_info/log_warn/log_error (emoji convention)
#   § PARSE_ACTION_ARGS         — shared arg-walker for inbox+sent handlers
#   § USAGE                     — help text
#   § PARSING & DISPATCH        — top-level argv → action+account+rest
#   § ACTION ROUTER             — case "$action" in i|q|sent|send|...
#
# § LANDMINES (things that have bitten us; tread carefully)
#   - The `${array[@]+"${array[@]}"}` idiom guards against unbound array
#     errors under `set -u`. Don't "simplify" it; bash's empty-array semantics
#     differ between releases.
#   - The m parser will eat any positional that matches an account alias.
#     New flags that take a value (like --outbox <alias>) MUST be recognized
#     in § PARSING & DISPATCH before the account-resolution branch, or their
#     value gets stolen as the account.
#   - Numeric arg after `q` is the QUERY, not an index.
#     `m q 31` searches for "31"; the q-skip-rest[0] rule lives in
#     parse_action_args. Keep it.
#   - `M_LIST_CACHE_TTL` is declared but currently unused. The cache-by-key
#     strategy in gmail-api-rw doesn't use TTL; this var is here for forward
#     compat. Don't rely on it expiring anything.
#   - Yellow ⚠️ via log_warn is the "I'm being forgiving" signal. Use it
#     when m fills in a missing arg or auto-corrects user input. Don't
#     silently fix things — always announce.
#
# § NON-GOALS (don't add these without asking)
#   - Tests. Real Gmail OAuth + state makes them either fake or fragile.
#   - Type-of-message filtering. Use Gmail search syntax via -q instead.
#   - Removing CLI flags. Public API; colleagues depend on them.

set -euo pipefail

# --- config ---
MAIL_TOOLS_CONFIG="${MAIL_TOOLS_CONFIG:-$HOME/.config/mail-tools/accounts.json}"
M_LIST_CACHE_TTL="${M_LIST_CACHE_TTL:-30}" # NOTE: declared, not yet used; gmail-api-rw caches by (count, query, account) without TTL
M_QUIET_MODE="${M_QUIET_MODE:-0}"

# Source optional user config
if [[ -f "$HOME/.config/m/config" ]]; then
    source "$HOME/.config/m/config"
elif [[ -f "$AUX_DIR/m-config.bash" ]]; then
    source "$AUX_DIR/m-config.bash"
fi

# ========================================================================
# § DEPENDENCY CHECKS — startup validation with actionable errors
# ========================================================================

check_dependencies() {
    local missing_deps=()
    local config_issues=()

    # Check for required commands
    if ! command -v jq >/dev/null 2>&1; then
        missing_deps+=("jq: Install with 'brew install jq' or 'apt-get install jq'")
    fi

    if ! command -v python3 >/dev/null 2>&1; then
        missing_deps+=("python3: Install Python 3 from python.org or your package manager")
    fi

    # Check for configuration file
    if [[ ! -f "$MAIL_TOOLS_CONFIG" ]]; then
        config_issues+=("Configuration file missing: $MAIL_TOOLS_CONFIG")
        config_issues+=("  Create with: mkdir -p \$(dirname '$MAIL_TOOLS_CONFIG')")
        config_issues+=("  See SETUP.md for configuration instructions")
    else
        # Validate JSON syntax
        if ! jq empty "$MAIL_TOOLS_CONFIG" 2>/dev/null; then
            config_issues+=("Invalid JSON in: $MAIL_TOOLS_CONFIG")
            config_issues+=("  Check syntax with: jq . '$MAIL_TOOLS_CONFIG'")
        fi
    fi

    # Check for gmail-api-rw executable
    local gmail_api_rw="/Users/wiggins/mise/py/gmail-api-rw"
    if [[ ! -x "$gmail_api_rw" ]]; then
        config_issues+=("Gmail API client not executable: $gmail_api_rw")
        config_issues+=("  Fix with: chmod +x '$gmail_api_rw'")
    fi

    # Check for .venv (needed for gmail-api-rw)
    local venv_python="/Users/wiggins/mise/py/.venv/bin/python3"
    if [[ ! -x "$venv_python" ]]; then
        config_issues+=("Python virtual environment missing: $venv_python")
        config_issues+=("  Setup with: cd /Users/wiggins/mise/py && python3 -m venv .venv")
        config_issues+=("  Install deps: .venv/bin/pip install google-api-python-client google-auth-oauthlib")
    fi

    # Report errors with clear action steps
    if (( ${#missing_deps[@]} > 0 || ${#config_issues[@]} > 0 )); then
        echo "⚠️  Email system dependency check failed:" >&2
        echo >&2

        if (( ${#missing_deps[@]} > 0 )); then
            echo "Missing required commands:" >&2
            printf "  %s\n" "${missing_deps[@]}" >&2
            echo >&2
        fi

        if (( ${#config_issues[@]} > 0 )); then
            echo "Configuration issues:" >&2
            printf "  %s\n" "${config_issues[@]}" >&2
            echo >&2
        fi

        echo "Fix the above issues and try again." >&2
        return 1
    fi

    return 0
}

# Check dependencies on startup (but allow override for testing)
if [[ "${M_SKIP_DEPENDENCY_CHECK:-0}" == "0" ]]; then
    check_dependencies || exit 1
fi

# Initialize configuration
declare -A EMAILS=()
declare -A ACCTS=()
declare -A LABELS=()

# Function to load account configuration from external files
load_mail_config() {
# ========================================================================
# § CONFIG — load accounts.json into ACCTS / EMAILS / LABELS
# ========================================================================
#
# PURPOSE:
# - Load all account information from JSON config (PII-free code design)
# - Build associative arrays for runtime account resolution
# - Replace hardcoded account mappings with dynamic configuration
#
# WHY DYNAMIC CONFIG:
# - Keeps PII out of ~/mise/ (public) code
# - Allows users to add accounts without editing script
# - Single source of truth for account information
# - Supports multiple account types (SMTP, API, web)
#
# CONFIG FILE: ~/.config/mail-tools/accounts.json
# FORMAT:
# {
#   "accounts": {
#     "g": {
#       "email": "user@gmail.com",
#       "chrome_profile": "Default",
#       "label": "Personal",
#       "gmail_flag": ""  // Optional: backend routing flag
#     },
#     "u": {
#       "email": "user@columbia.edu",
#       "chrome_profile": "Profile 1",
#       "label": "Work",
#       "gmail_flag": "cu"
#     }
#   }
# }
#
# GLOBAL ARRAYS POPULATED:
# - EMAILS[alias] = email address (for display, validation)
# - LABELS[alias] = human-readable name (for UI, help)
# - ACCTS[alias] = "gmail_flag:chrome_profile" (for backend routing)
#
# ROUTING DECISION:
# - gmail_flag determines backend tool selection
# - chrome_profile determines web browser routing
# - Empty gmail_flag = default/primary gmail account
# - Non-empty gmail_flag = specific backend (-e flag for gmail-api-rw)
#
local config_file="$MAIL_TOOLS_CONFIG"

# ================================================
# STEP 1: Try new JSON config (preferred method)
# ================================================
if [[ -f "$config_file" ]] && command -v jq >/dev/null 2>&1; then
    local accounts
    # Extract account data: alias|email|chrome_profile|label|gmail_flag
    # The jq query safely handles missing optional fields (label, gmail_flag)
    accounts=$(jq -r '.accounts | to_entries[] | "\(.key)|\(.value.email)|\(.value.chrome_profile)|\(.value.label // "")|\(.value.gmail_flag // "")"' "$config_file" 2>/dev/null)

    if [[ -n "$accounts" ]]; then
        # ============================================
        # STEP 1A: Parse JSON data into arrays
        # ============================================
        while IFS='|' read -r alias email chrome_profile label gmail_flag; do
            # Basic account info
            EMAILS["$alias"]="$email"
            LABELS["$alias"]="${label:-$alias}"  # Default to alias if no label

            # ========================================
            # STEP 1B: Build backend routing string
            # ========================================
            # Format: "gmail_flag:chrome_profile"
            # - gmail_flag: Backend tool routing (-e flag for gmail-api-rw)
            # - chrome_profile: Browser profile for web interface
            #
            # Examples:
            # - "cu:Profile 1" = Columbia account, Profile 1 browser
            # - ":Default" = Default gmail, Default browser profile
            #
            if [[ -n "$gmail_flag" ]]; then
                # Explicit gmail_flag specified in config
                ACCTS["$alias"]="$gmail_flag:$chrome_profile"
            elif [[ "$alias" == "g" ]]; then
                # Special case: 'g' alias gets empty gmail_flag (default account)
                ACCTS["$alias"]=":$chrome_profile"
            else
                # ====================================
                # STEP 1C: Derive gmail_flag from alias
                # ====================================
                # Fallback for accounts without explicit gmail_flag
                local short_name="$alias"
                    # Preserve known legacy flags if possible or just use alias
                    case "$alias" in
                        j|joint) short_name="joint" ;;
                        u|cu)    short_name="cu" ;;
                        l|lake)  short_name="lake" ;;
                        h|hNY)   short_name="hNY" ;;
                    esac
                    ACCTS["$alias"]="$short_name:$chrome_profile"
                fi
            done <<< "$accounts"
            return 0
        fi
    fi

    # ERROR: Configuration required - no hardcoded fallback for PII-free operation
    log_error "No email configuration found!"
    echo "m: Please create ~/.config/mail-tools/accounts.json" >&2
    echo "m: See SETUP.md for configuration instructions" >&2
    exit 1
}

load_mail_config

# ========================================================================
# § ROUTING HELPERS — core API-vs-SMTP decision
# ========================================================================
# An account is "API-only" iff its muttrc field is "/dev/null" or absent
# (or the file doesn't exist). Real muttrc path = SMTP. The `_is_api_only`
# helper centralizes this check; callers should never compare paths inline.

# Look up muttrc path for an account slug or email substring
# Uses the unified JSON config at ~/.config/mail-tools/accounts.json
# Returns muttrc path, or empty string if no match
_lookup_muttrc() {
    local needle="$1"

    # Check if we have this account in our loaded config
    if [[ -n "${EMAILS[$needle]}" ]]; then
        # Direct alias match - extract muttrc from JSON config
        jq -r ".accounts.\"$needle\".muttrc // empty" "$MAIL_TOOLS_CONFIG" 2>/dev/null
        return
    fi

    # Try partial matching on any field (alias, email)
    local needle_lower
    needle_lower=$(printf '%s' "$needle" | tr '[:upper:]' '[:lower:]')
    local match_alias=""

    # Search through all accounts for partial matches
    for alias in "${!EMAILS[@]}"; do
        local email="${EMAILS[$alias]}"
        local alias_lower email_lower
        alias_lower=$(printf '%s' "$alias" | tr '[:upper:]' '[:lower:]')
        email_lower=$(printf '%s' "$email" | tr '[:upper:]' '[:lower:]')

        if [[ "$alias_lower" == *"$needle_lower"* || "$email_lower" == *"$needle_lower"* ]]; then
            match_alias="$alias"
            break
        fi
    done

    if [[ -n "$match_alias" ]]; then
        jq -r ".accounts.\"$match_alias\".muttrc // empty" "$MAIL_TOOLS_CONFIG" 2>/dev/null
    fi
}

# Get the default account's muttrc from JSON config
_default_muttrc() {
    local default_alias
    default_alias=$(jq -r '.default_account // empty' "$MAIL_TOOLS_CONFIG" 2>/dev/null)

    if [[ -n "$default_alias" ]]; then
        jq -r ".accounts.\"$default_alias\".muttrc // empty" "$MAIL_TOOLS_CONFIG" 2>/dev/null
        return
    fi

    # Fall back to first account if no default specified
    local first_alias
    for alias in "${!EMAILS[@]}"; do
        first_alias="$alias"
        break
    done

    if [[ -n "$first_alias" ]]; then
        jq -r ".accounts.\"$first_alias\".muttrc // empty" "$MAIL_TOOLS_CONFIG" 2>/dev/null
    fi
}

# CORE ROUTING DECISION: API vs SMTP
# This determines which backend to use based on account configuration
# API-only accounts (like Columbia) have muttrc="/dev/null"
# SMTP accounts have real muttrc files with credentials
_is_api_only() {
    local muttrc="$1"
    [[ "$muttrc" == "/dev/null"* || ! -f "$muttrc" ]]
}

# ========================================================================
# § DIRECT SEND — unified send pipeline (file mode + compose mode)
# ========================================================================
# direct_send() decides between two paths based on whether any arg ends
# in .eml (file mode) or not (compose mode). For API-only accounts in
# compose mode, it auto-builds a .eml from stdin and ships via API.
# Handles file sending, attachment processing, and backend routing

direct_send() {
    local -a send_args=("$@")

    # Parse arguments (simplified version of send script's parsing)
    local account=""
    local done_flag=0
    local dry_run=0
    local subject=""
    local -a cc_addrs=()
    local -a bcc_addrs=()
    local -a args=()
    local -a attachments=()

    local i=0
    while [[ $i -lt ${#send_args[@]} ]]; do
        case "${send_args[i]}" in
            -e)
                account="${send_args[i+1]}"
                ((i+=2))
                ;;
            -H)
                # Mutt compatibility: treat -H file as just the file
                args+=("${send_args[i+1]}")
                ((i+=2))
                ;;
            -a)
                attachments+=("${send_args[i+1]}")
                ((i+=2))
                ;;
            -s|--subject)
                subject="${send_args[i+1]}"
                ((i+=2))
                ;;
            -c|--cc)
                cc_addrs+=("${send_args[i+1]}")
                ((i+=2))
                ;;
            -b|--bcc)
                bcc_addrs+=("${send_args[i+1]}")
                ((i+=2))
                ;;
            -d|--done)
                done_flag=1
                i=$((i+1))
                ;;
            -n|--dry-run)
                dry_run=1
                i=$((i+1))
                ;;
            *)
                # Check if this argument contains comma-separated recipients
                if [[ "${send_args[i]}" =~ .+@.+,.+@.+ ]]; then
                    # Split comma-separated recipients for separate emails
                    IFS=',' read -ra recipients <<< "${send_args[i]}"
                    # Add all recipients to args - we'll send separate emails to each
                    for recipient in "${recipients[@]}"; do
                        args+=("$recipient")
                    done
                else
                    args+=("${send_args[i]}")
                fi
                i=$((i+1))
                ;;
        esac
    done

    # Build attachment arguments
    local -a attach_args=()
    for att in "${attachments[@]+"${attachments[@]}"}"; do
        attach_args+=(-a "$att")
    done


    # Resolve muttrc for account
    local muttrc
    if [[ -n "$account" ]]; then
        muttrc=$(_lookup_muttrc "$account")
        if [[ -z "$muttrc" ]]; then
            echo "m: unknown account '$account'" >&2
            return 1
        fi
    else
        muttrc=$(_default_muttrc)
        if [[ -z "$muttrc" ]]; then
            echo "m: no default account configured in $MAIL_TOOLS_CONFIG" >&2
            return 1
        fi
    fi

    # Check if we have .eml files (file mode)
    local file_mode=0
    for arg in "${args[@]}"; do
        if [[ "$arg" == *.eml ]]; then
            file_mode=1
            break
        fi
    done

    # Route to appropriate backend
    if (( file_mode )); then
        # File send mode
        for arg in "${args[@]}"; do
            if [[ "$arg" == *.eml ]]; then
                if [[ ! -f "$arg" ]]; then
                    log_error "file not found: $arg"
                    return 1
                fi

                local abspath="$(cd "$(dirname "$arg")" && pwd)/$(basename "$arg")"

                local send_rc=0
                if (( dry_run )); then
                    if _is_api_only "$muttrc"; then
                        echo "DRY-RUN: gmail-api-rw ${account:+-e $account} send --via-send -H $abspath ${attach_args[*]+${attach_args[*]}}"
                    else
                        echo "DRY-RUN: echo | neomutt -e 'unset record' -F $muttrc -H $abspath ${attach_args[*]+${attach_args[*]}}"
                    fi
                elif _is_api_only "$muttrc"; then
                    echo "m: ${account:-default} via gmail API" >&2
                    gmail-api-rw ${account:+-e "$account"} send --via-send -H "$abspath" "${attach_args[@]+"${attach_args[@]}"}" || send_rc=$?
                else
                    echo "m: ${account:-default} via SMTP" >&2
                    # Direct neomutt call - optimize by removing process hop
                    echo | neomutt -e 'unset record' -F "$muttrc" -H "$abspath" "${attach_args[@]+"${attach_args[@]}"}" || send_rc=$?
                fi

                if (( send_rc != 0 )); then
                    echo "$abspath FAILED (exit $send_rc)" >&2
                    return $send_rc
                fi
                (( dry_run )) || echo "$abspath sent"

                if (( done_flag )); then
                    local clip="/sent $abspath"
                    printf '%s' "$clip" | pbcopy
                    echo "Copied to clipboard: $clip" >&2
                fi
            fi
        done
    else
        # Compose mode
        if _is_api_only "$muttrc"; then
            # API-only account (e.g. Columbia, hackNY): there's no SMTP
            # muttrc, so we can't open neomutt interactively. Build a .eml
            # from stdin + flags and ship it through gmail-api-rw send -H.
            #
            # Stdin contract: the body MUST be piped or redirected. Bare
            # `cat` waits silently for terminal input, which looks like the
            # command is hung. Refuse early with a clear message.
            if [[ -t 0 ]]; then
                log_error "send to API-only account needs a piped body or a .eml file"
                echo "  e.g.  echo 'hi' | m send $account user@example.com -s 'hello'" >&2
                echo "  or    m send $account file.eml" >&2
                return 1
            fi

            local datestr eml_path
            datestr=$(date +%Y%m%d-%H%M%S)
            eml_path="/tmp/m-send-via-eml-${datestr}.eml"

            # Collect recipients from args (anything containing @)
            local -a recipients=()
            for arg in "${args[@]}"; do
                if [[ "$arg" =~ @ ]]; then
                    recipients+=("$arg")
                fi
            done

            if [[ ${#recipients[@]} -eq 0 ]]; then
                echo "m: no recipient specified" >&2
                return 1
            fi

            # Build .eml file: To, Cc, Bcc, Subject headers, blank line, body from stdin
            {
                printf 'To: %s\n' "$(IFS=,; echo "${recipients[*]}")"
                if [[ ${#cc_addrs[@]} -gt 0 ]]; then
                    printf 'Cc: %s\n' "$(IFS=,; echo "${cc_addrs[*]}")"
                fi
                if [[ ${#bcc_addrs[@]} -gt 0 ]]; then
                    printf 'Bcc: %s\n' "$(IFS=,; echo "${bcc_addrs[*]}")"
                fi
                printf 'Subject: %s\n' "${subject:-(no subject)}"
                printf '\n'
                cat
            } > "$eml_path"

            echo "⚠️  m: API-only account; auto-created .eml at $eml_path" >&2
            if (( dry_run )); then
                echo "DRY-RUN: gmail-api-rw ${account:+-e $account} send --via-send -H $eml_path ${attach_args[*]+${attach_args[*]}}"
                return 0
            fi
            echo "m: ${account:-default} via gmail API" >&2
            gmail-api-rw ${account:+-e "$account"} send --via-send -H "$eml_path" "${attach_args[@]+"${attach_args[@]}"}"
            return $?
        fi

        # Handle multiple recipients by sending separate emails
        # Find email addresses in args (anything containing @)
        local -a recipients=()
        local -a other_args=()
        for arg in "${args[@]}"; do
            if [[ "$arg" =~ @ ]]; then
                recipients+=("$arg")
            else
                other_args+=("$arg")
            fi
        done

        if [[ ${#recipients[@]} -eq 0 ]]; then
            if (( dry_run )); then
                echo "DRY-RUN: neomutt -e 'unset record' -F $muttrc ${args[*]} ${attach_args[*]+${attach_args[*]}}"
                return 0
            fi
            # No recipients found, use neomutt in compose mode (user will enter recipient)
            echo "m: ${account:-default} via SMTP" >&2
            neomutt -e 'unset record' -F "$muttrc" "${args[@]}" "${attach_args[@]+"${attach_args[@]}"}"
        else
            # Send separate email to each recipient
            for recipient in "${recipients[@]}"; do
                if (( dry_run )); then
                    echo "DRY-RUN: neomutt -e 'unset record' -F $muttrc $recipient ${other_args[*]+${other_args[*]}} ${attach_args[*]+${attach_args[*]}}"
                    continue
                fi
                echo "m: sending to $recipient via ${account:-default} SMTP" >&2
                neomutt -e 'unset record' -F "$muttrc" "$recipient" "${other_args[@]}" "${attach_args[@]+"${attach_args[@]}"}"
            done
        fi
    fi
}

# Validate M_DEFAULT_ACCOUNT
if [[ -n "${M_DEFAULT_ACCOUNT:-}" ]]; then
    if [[ -z "${EMAILS[$M_DEFAULT_ACCOUNT]:-}" ]]; then
        valid_accts=$(printf '%s, ' "${!EMAILS[@]}" | sed 's/, $//')
        log_error "invalid M_DEFAULT_ACCOUNT='${M_DEFAULT_ACCOUNT}'. Valid: $valid_accts"
        exit 1
    fi
fi

if [[ "${M_RANGE_WARNING_LIMIT:-50}" -lt 1 ]]; then
    M_RANGE_WARNING_LIMIT=50
fi

# ========================================================================
# § LOGGING — emoji-tagged stderr (color signals intent)
# ========================================================================
# Convention: blue ℹ = info, green ✅ = ok, yellow ⚠️ = forgiving warning,
# red ❌ = real error. The yellow ⚠️ is the "m is being lenient about your
# input" signal (e.g. defaulting a missing index to 1). Use it any time m
# fills in or auto-corrects something — never silently fix things.
log_info() { (( M_QUIET_MODE )) || echo -e "\033[0;34mℹ\033[0m $*" >&2; }
log_ok() { (( M_QUIET_MODE )) || echo -e "\033[0;32m✅\033[0m $*" >&2; }
log_warn() { echo -e "\033[0;33m⚠️\033[0m $*" >&2; }
log_error() { echo -e "\033[0;31m❌\033[0m $*" >&2; }

log_command() {
    if [[ -n "${M_ANALYTICS_ENABLED:-}" ]] && (( M_ANALYTICS_ENABLED )); then
        # Silent background logging if possible
        (echo "$(date '+%Y-%m-%d %H:%M:%S')|$account|$action|${rest[*]:-}" >> "$HOME/.cache/m/usage.log" 2>/dev/null || true) &
    fi
}

open_web() {
    local folder="$1"; shift
    local profile="$chrome_profile"
    log_info "Opening Gmail ($folder) in browser (profile $profile)..."
    log_command "$@"
    exec gmail_web "$profile" "$folder" "$@"
}

# ========================================================================
# § PARSE_ACTION_ARGS — shared arg-walker for inbox/q/sent handlers
# ========================================================================
# Walks an array of positional args looking for an "action word" (reply,
# fwd, etc.), parses message-number indices before it, and collects
# everything after it. Centralizes the rules that used to be duplicated
# across the i|q and sent handlers.
#
# Why two query modes: the i|q action takes the query as a positional
# (`m q sophie 1 reply` — query is rest[0]), while the sent action takes
# the query via a literal `q <query>` pair (`m g sent q sophie 1 reply` —
# 'q' is a marker word, query is what follows). These reflect how users
# actually type the commands; don't try to unify them.
#
# Inputs:
#   $1: query mode -- "positional-q" (rest[0] is query if action=q),
#       "literal-q" (rest contains "q <query>" pair to extract), or "none"
#   $2: caller's $action (used by positional-q mode)
#   $3: space-separated list of action words to recognize (e.g.
#       "reply reply-all fwd draft open trash archive thread read unread urls")
#   $4+: the rest array (positional args after account/action stripped)
#
# Outputs (via global vars; arrays must be declared by caller):
#   PA_ACTION_WORD   - action word found, or ""
#   PA_QUERY         - parsed query string, or ""
#   PA_MESSAGE_NUMBERS - array of indices found before action word
#   PA_TRAILING_ARGS   - array of args after the action word
#   PA_REMAINING       - array equal to input rest minus consumed query tokens
parse_action_args() {
    local query_mode="$1"; shift
    local caller_action="$1"; shift
    local allowed_actions="$1"; shift
    local -a input=("$@")

    PA_ACTION_WORD=""
    PA_QUERY=""
    PA_MESSAGE_NUMBERS=()
    PA_TRAILING_ARGS=()
    PA_REMAINING=()

    # Step 1: query extraction
    if [[ "$query_mode" == "literal-q" ]]; then
        # Drop "q <query>" pair from input, write rest into PA_REMAINING
        local _qi=0
        while (( _qi < ${#input[@]} )); do
            if [[ "${input[_qi]}" == "q" && $((_qi + 1)) -lt ${#input[@]} ]]; then
                PA_QUERY="${input[_qi+1]}"
                _qi=$((_qi + 2))
                continue
            fi
            PA_REMAINING+=("${input[_qi]}")
            _qi=$((_qi + 1))
        done
    else
        # positional-q or none: rest is unchanged
        PA_REMAINING=("${input[@]+"${input[@]}"}")
        if [[ "$query_mode" == "positional-q" && "$caller_action" == "q" ]]; then
            PA_QUERY="${PA_REMAINING[0]:-}"
        fi
    fi

    # Step 2: find the action word
    # Match against the caller-supplied list — different handlers (i|q vs sent)
    # support different sets of actions, so we don't hardcode a union.
    local action_word_index=-1
    local i
    for i in "${!PA_REMAINING[@]}"; do
        if [[ " $allowed_actions " == *" ${PA_REMAINING[i]} "* ]]; then
            PA_ACTION_WORD="${PA_REMAINING[i]}"
            action_word_index=$i
            break
        fi
    done

    # Step 3: parse message numbers before action word, collect trailing args after
    if [[ -n "$PA_ACTION_WORD" ]]; then
        for ((i=0; i<action_word_index; i++)); do
            local arg="${PA_REMAINING[i]}"
            case "$arg" in
                [0-9]|[0-9][0-9]|[0-9][0-9][0-9])
                    # Skip query string for positional-q mode (rest[0] is query)
                    if [[ "$query_mode" == "positional-q" && "$caller_action" == "q" && "$i" == "0" ]]; then
                        continue
                    fi
                    PA_MESSAGE_NUMBERS+=("$arg")
                    ;;
                [0-9]-[0-9]|[0-9]-[0-9][0-9]|[0-9][0-9]-[0-9][0-9])
                    if [[ "$query_mode" == "positional-q" && "$caller_action" == "q" && "$i" == "0" ]]; then
                        continue
                    fi
                    PA_MESSAGE_NUMBERS+=("$arg")
                    ;;
            esac
        done
        for ((i=action_word_index+1; i<${#PA_REMAINING[@]}; i++)); do
            PA_TRAILING_ARGS+=("${PA_REMAINING[i]}")
        done

        # m is the user-forgiving layer: default missing index to 1 for actions that need one
        if [[ ${#PA_MESSAGE_NUMBERS[@]} -eq 0 ]]; then
            case "$PA_ACTION_WORD" in
                reply|reply-all|fwd|sfwd|sreply|sreply-all|draft|open|thread|urls)
                    log_warn "no index given for '$PA_ACTION_WORD'; assuming message #1"
                    PA_MESSAGE_NUMBERS=("1")
                    ;;
            esac
        fi
    fi
}

# smart_send() function removed - logic consolidated into direct_send()
# This eliminates the need for the external send script

ACTIONS_SHORT="i sent q d x urls"
ACTIONS_SEND="send c"
ACTIONS_PASSTHRU="draft reply reply-all fwd open trash archive thread read unread sfwd sreply sreply-all"

usage() {
