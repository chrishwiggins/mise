#!/opt/homebrew/bin/bash

# ============================================================================
# m - Multi-Account Email Dispatcher
# ============================================================================
#
# ARCHITECTURAL OVERVIEW FOR FUTURE CLAUDE INSTANCES:
#
# This is the central dispatcher for a multi-account email system. It provides
# a unified interface across 6+ email accounts while routing to appropriate
# backends (Gmail API vs SMTP) based on account configuration.
#
# KEY DESIGN PRINCIPLES:
# 1. **Account Abstraction**: Users think in account letters (g,j,u,l,h,n,z)
#    not email addresses. This script maps letters to emails via JSON config.
# 2. **Transport Agnostic**: Automatically routes to Gmail API or SMTP based
#    on account config (muttrc: "/dev/null" = API, real path = SMTP)
# 3. **Mode Consistency**: All actions support -save/-v/default(more) modes
# 4. **Web/CLI Duality**: Every action works in both web browser and CLI
# 5. **PII-Free**: No hardcoded email addresses; all config external
#
# CRITICAL EXTERNAL DEPENDENCIES:
# - ~/.config/mail-tools/accounts.json (account config, created by setup)
# - gmails / gmail-api-rw (Gmail API client, handles OAuth, caching, etc)
# - gmail-smtp-w / mutt wrapper (SMTP sending for non-API accounts)
# - send script (smart routing layer that chooses API vs SMTP per account)
#
# DATA FLOW ARCHITECTURE:
#   User Input → Argument Parser → Account Resolution → Action Router
#       ↓
#   [WEB PATH]           [CLI PATH]
#   gmail_web browser ←→ gmails/gmail-api-rw (with caching)
#       ↓                    ↓
#   Gmail Web UI        Local .eml files + more pager
#
# ARGUMENT PARSING STRATEGY:
# The parser is designed for email workflow ergonomics:
# - Position-independent: "m j i" = "m i j" (account + action in any order)
# - Smart defaults: "m" = "m i g" (inbox, default account)
# - Query shortcuts: "m -q term" = "m q -q term" (search syntax sugar)
# - Action chaining: "m -q term reply" = search then reply to msg #1
#
# ACCOUNT CONFIGURATION SYSTEM:
# Accounts map single letters to full email configs:
# {
#   "accounts": {
#     "g": {"email": "user@gmail.com", "muttrc": "/path/to/muttrc"},
#     "u": {"email": "user@columbia.edu", "muttrc": "/dev/null"}  ← API-only
#   },
#   "default_account": "g"
# }
#
# CACHING AND PERFORMANCE:
# - gmails has 30s TTL cache for message listings (prevents API thrashing)
# - Cache files in /tmp/spool/*.txt keyed by account email slug
# - Cache bypass via -N flag for force refresh
#
# ERROR HANDLING PHILOSOPHY:
# - Fast-fail validation: catch obvious user errors before calling gmails
# - Health check integration: m-doctor provides recovery suggestions
# - Graceful degradation: CLI fallbacks when web fails, etc.
# - User-friendly messages: "Did you mean 'm q term'?" not raw errors
#
# SECURITY MODEL:
# - No PII in code: all emails/names in external config only
# - OAuth tokens managed by gmails, not exposed here
# - Web URLs use authuser= param for multi-account Google switching
#
# Usage: m [action] [account] [-w] [extra args...]
#
# Core Actions:
#   i (inbox)     List recent messages (default action)
#   sent          List sent messages
#   q (search)    Search messages with query
#   d (drafts)    List draft messages
#   x (spam)      List spam messages
#   send/c        Compose and send (routes through 'send' script)
#   urls          Extract/open URLs from messages
#
# Interactive Actions (pass-through to gmails):
#   reply, reply-all, fwd, draft, open, trash, archive
#   These default to message #1 if no number specified
#
# Accounts (configured in ~/.config/mail-tools/accounts.json):
#   Mapped dynamically from config - no hardcoded emails
#
# Modes:
#   -w/--web      Force web interface (opens Gmail in browser)
#   -save         Download message to .eml file
#   -v            Show full content without paging
#   (default)     Display with 'more' pager
#
# Examples:
#   m                          Default account inbox, CLI
#   m u                        Columbia account inbox
#   m -q Ahmad reply           Search "Ahmad", reply to first result
#   m sent 4                   Read sent message #4 (with paging)
#   m sent 4 -save             Download sent message #4 to file
#   m j urls 3                 Read msg #3 from joint account, extract URLs
#   m j 1 -save                save message #1 to file without displaying
#   m sent l                   lake sent, CLI
#   m q g "from:alice"         search gmail, CLI
#   m q g "from:alice" 2       read message #2 with more paging (NEW DEFAULT)
#   m q g "from:alice" 2 -save save message #2 to file without displaying
#   m q g "from:alice" 2 -v    show message #2 full content without paging
#   m send u file.eml          send from columbia (routes via send script)
#   m send l -s "hi" user@x    compose and send from lake
#   m reply g 3                reply to msg #3 on gmail
#   m c h                      compose on hackny
#   m -w                       gmail inbox, web
#   m ?                        show this help
#
# Reading routes to gmails; sending routes to send; web routes to gmail_web.

set -euo pipefail

# Load user configuration if available
if [[ -f "$HOME/.config/m/config" ]]; then
    source "$HOME/.config/m/config"
elif [[ -f "$(dirname "$0")/m-config.bash" ]]; then
    source "$(dirname "$0")/m-config.bash"
fi

# Validate configuration
if [[ -n "${M_DEFAULT_ACCOUNT:-}" ]]; then
    case "${M_DEFAULT_ACCOUNT}" in
        g|j|u|l|h|n|z) ;;
        *)
            echo "m: invalid M_DEFAULT_ACCOUNT='${M_DEFAULT_ACCOUNT}'. Valid: g,j,u,l,h,n,z" >&2
            exit 1
            ;;
    esac
fi

if [[ "${M_RANGE_WARNING_LIMIT:-50}" -lt 1 ]]; then
    echo "m: M_RANGE_WARNING_LIMIT must be positive, got '${M_RANGE_WARNING_LIMIT}'" >&2
    exit 1
fi

if [[ "${M_RANGE_HARD_LIMIT:-100}" -lt "${M_RANGE_WARNING_LIMIT:-50}" ]]; then
    echo "m: M_RANGE_HARD_LIMIT (${M_RANGE_HARD_LIMIT}) must be >= M_RANGE_WARNING_LIMIT (${M_RANGE_WARNING_LIMIT})" >&2
    exit 1
fi

if [[ "${M_QUIET_MODE:-0}" != "0" && "${M_QUIET_MODE:-0}" != "1" ]]; then
    echo "m: M_QUIET_MODE must be 0 or 1, got '${M_QUIET_MODE}'" >&2
    exit 1
fi

# Check for completion availability (only in interactive shells)
if [[ $- == *i* ]] && [[ ${M_QUIET_MODE:-0} -eq 0 ]]; then
    if ! complete -p m &>/dev/null && [[ -f "$(dirname "$0")/m-completion.bash" ]]; then
        if [[ ${M_COMPLETION_HINT_SHOWN:-0} -eq 0 ]]; then
            echo "Hint: Enable tab completion with: source $(dirname "$0")/m-completion.bash" >&2
            export M_COMPLETION_HINT_SHOWN=1
        fi
    fi
fi

# Logging functions for user feedback
log_warn() { echo -e "\033[0;33m⚠️\033[0m $*" >&2; }
log_ok() { echo -e "\033[0;32m✅\033[0m $*" >&2; }
log_error() { echo -e "\033[0;31m❌\033[0m $*" >&2; }
log_info() { echo -e "\033[0;34mℹ\033[0m $*" >&2; }

# Millisecond epoch helper: BSD date on macOS has no %N, so use gdate if present.
# Falls back to seconds*1000, which is fine for coarse timing.
_ms_epoch() {
    if command -v gdate >/dev/null 2>&1; then
        gdate +%s%3N
    else
        echo $(( $(date +%s) * 1000 ))
    fi
}

# Analytics logging function
log_command() {
    # Only log if analytics is available and enabled
    if command -v m-analytics >/dev/null 2>&1; then
        local start_time="${M_COMMAND_START:-$(_ms_epoch)}"
        local end_time=$(_ms_epoch)
        local duration=$((end_time - start_time))
        local full_cmd="m $*"

        # Log in background to avoid slowing down the command
        (m-analytics log "$full_cmd" "$duration" &) 2>/dev/null || true
    fi
}

# Record command start time for performance tracking
M_COMMAND_START=$(_ms_epoch)

# Health check and recovery suggestions
check_health_and_suggest_fixes() {
    local operation="$1"
    local exit_code="${2:-1}"

    # Only run health checks if tools are available
    if ! command -v m-doctor >/dev/null 2>&1; then
        return 0
    fi

    # Quick health check for common issues
    log_warn "$operation failed, checking system health..."

    # Run quick diagnostic
    if ! m-doctor --quick >/dev/null 2>&1; then
        log_info "Health issues detected. Suggested fixes:"

        # Check for specific common problems
        local retry_state="$HOME/.cache/m/retry-state.json"
        if [[ -f "$retry_state" ]]; then
            local cb_state=$(jq -r '.circuit_breaker.state // "closed"' "$retry_state" 2>/dev/null || echo "closed")
            if [[ "$cb_state" == "open" ]]; then
                echo "  • Circuit breaker is open - run: m-reset circuit-breaker"
            fi
        fi

        # Check authentication
        if ! gcloud auth application-default print-access-token >/dev/null 2>&1; then
            echo "  • Authentication expired - run: gcloud auth application-default login"
        fi

        # Check network connectivity
        if ! curl -s --max-time 3 "https://gmail.googleapis.com/" >/dev/null 2>&1; then
            echo "  • Network/API issues - check connection or try: m-fallback check"
        fi

        echo
        log_info "For complete diagnostics run: m-doctor"
        log_info "For automatic fixes run: m-doctor --fix"
    fi
}

# Smart send function with queue fallback
smart_send() {
    local send_args=("$@")

    # Try to send normally first
    if send "${send_args[@]}"; then
        # Success - no queueing needed
        return 0
    else
        local send_exit=$?

        # Check if queue system is available
        if command -v m-queue >/dev/null 2>&1; then
            log_warn "Send failed, attempting to queue message for later delivery"

            # Extract recipient and subject from args for queueing
            local recipient=""
            local subject=""
            local email_file=""
            local body=""
            local account="${account:-g}"

            # Parse send arguments
            local i=0
            while [[ $i -lt ${#send_args[@]} ]]; do
                case "${send_args[$i]}" in
                    -e)
                        # Skip gmails flag
                        i=$((i + 2))
                        ;;
                    -s)
                        # Subject flag
                        i=$((i + 1))
                        if [[ $i -lt ${#send_args[@]} ]]; then
                            subject="${send_args[$i]}"
                            i=$((i + 1))
                        fi
                        ;;
                    -H)
                        # Email file flag
                        i=$((i + 1))
                        if [[ $i -lt ${#send_args[@]} ]]; then
                            email_file="${send_args[$i]}"
                            i=$((i + 1))
                        fi
                        ;;
                    -*)
                        # Skip other flags
                        i=$((i + 1))
                        ;;
                    *)
                        # First non-flag argument is usually the recipient
                        if [[ -z "$recipient" ]]; then
                            recipient="${send_args[$i]}"
                        elif [[ -z "$body" ]]; then
                            body="${send_args[$i]}"
                        fi
                        i=$((i + 1))
                        ;;
                esac
            done

            # Queue the message
            if [[ -n "$email_file" ]]; then
                # Queue from email file
                if m-queue add "$email_file" --account "$account"; then
                    log_ok "Message queued for delivery when network/API is available"
                    log_info "Check queue status with: m-queue status"
                    return 0
                fi
            elif [[ -n "$recipient" ]]; then
                # Queue constructed message
                local queue_subject="${subject:-"(No subject)"}"
                local queue_body="${body:-"(No body)"}"

                if m-queue send "$recipient" "$queue_subject" "$queue_body" --account "$account"; then
                    log_ok "Message queued for delivery when network/API is available"
                    log_info "Check queue status with: m-queue status"
                    return 0
                fi
            fi

            log_error "Send failed and could not queue message"
        else
            log_error "Send failed and queue system not available"
        fi

        # Run health diagnostics to suggest fixes
        check_health_and_suggest_fixes "send" $send_exit

        return $send_exit
    fi
}

# --- accounts table: slug -> gmails_flag:chrome_profile ---
# gmails_flag empty = default account; "!" = web-only (no CLI)
declare -A ACCTS=()

# ============================================================================
# ACCOUNT CONFIGURATION SYSTEM
# ============================================================================
#
# CONFIGURATION ARCHITECTURE FOR FUTURE CLAUDE INSTANCES:
#
# This system loads account mappings from external JSON config to keep PII
# out of the codebase. The config supports:
#
# 1. **Multi-format Support**: JSON (preferred) + legacy format compatibility
# 2. **Account Mapping**: Single letters (g,j,u) → full email addresses
# 3. **Transport Routing**: muttrc paths determine API vs SMTP routing
# 4. **Chrome Profiles**: Multi-account browser session management
# 5. **Web Integration**: authuser params for Gmail web interface
#
# CRITICAL DATA STRUCTURES POPULATED:
# - EMAILS[]: Maps account letter to email address (g → chris.wiggins@gmail.com)
# - ACCTS[]: Maps account letter to gmails flags (g → ":Default", u → "cu:CU")
#
# CONFIGURATION FILE FORMAT (~/.config/mail-tools/accounts.json):
# {
#   "accounts": {
#     "g": {
#       "email": "user@gmail.com",
#       "muttrc": "/path/to/muttrc",
#       "chrome_profile": "Default"
#     },
#     "u": {
#       "email": "user@university.edu",
#       "muttrc": "/dev/null",    ← Signals API-only account
#       "chrome_profile": "Work"
#     }
#   },
#   "default_account": "g"
# }
#
# WHY THIS DESIGN:
# - PII Isolation: Email addresses only in config files, never in code
# - Transport Abstraction: muttrc path determines routing without hardcoding
# - Profile Management: Chrome profiles enable clean multi-account switching
# - Scalability: Easy to add new accounts without code changes
#
# Function to load account configuration from external files
load_mail_config() {
    local config_file="${MAIL_TOOLS_CONFIG:-$HOME/.config/mail-tools/accounts.json}"
    local legacy_file="$HOME/.config/gmails/accounts"

    # Try new JSON config first
    if [[ -f "$config_file" ]] && command -v jq >/dev/null 2>&1; then
        local accounts
        accounts=$(jq -r '.accounts | to_entries[] | "\(.key)|\(.value.email)|\(.value.chrome_profile)"' "$config_file" 2>/dev/null)
        if [[ -n "$accounts" ]]; then
            while IFS='|' read -r alias email chrome_profile; do
                EMAILS["$alias"]="$email"
                # Format chrome_profile for ACCTS (gmails_flag:chrome_profile)
                if [[ "$alias" == "g" ]]; then
                    ACCTS["$alias"]=":$chrome_profile"
                else
                    # Extract short name for gmails_flag from email domain or alias
                    local short_name
                    case "$alias" in
                        j) short_name="joint" ;;
                        u) short_name="cu" ;;
                        l) short_name="lake" ;;
                        h) short_name="hNY" ;;
                        n) short_name="!" ;;
                        z) short_name="z" ;;
                        *) short_name="$alias" ;;
                    esac
                    ACCTS["$alias"]="$short_name:$chrome_profile"
                fi
            done <<< "$accounts"
            return 0
        fi
    fi

    # ERROR: Configuration required - no hardcoded fallback for PII-free operation
    echo "m: ERROR - No email configuration found!" >&2
    echo "m: Please create ~/.config/mail-tools/accounts.json or ~/.config/gmails/accounts" >&2
    echo "m: See SETUP.md for configuration instructions" >&2
    exit 1
}

# Initialize configuration
declare -A EMAILS=()
load_mail_config

