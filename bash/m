            # Show example using first configured account
            first_acct=$(printf '%s\n' "${!EMAILS[@]}" | sort | head -1)
            if [[ -n "$first_acct" ]]; then
                echo "    m i $first_acct                             ${ACCTS[$first_acct]:-} inbox"
            fi
    m sent j                          Joint sent messages
