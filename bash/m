#!/opt/homebrew/bin/bash

# Set up helper script paths
SCRIPT_DIR="$(dirname "$(realpath "$0")")"
AUX_DIR="$(dirname "$SCRIPT_DIR")/aux/m"

# ============================================================================
# m — multi-account email dispatcher (bash frontend)
# ============================================================================
#
# READ THIS BEFORE EDITING. Future Claude / future Chris: this is the map.
#
# § MENTAL MODEL
#   m is the user-forgiving frontend. gmail-api-rw is the strict backend.
#   Foibles go in m: argument flexibility, missing-index defaults, cache
#   warming, comma-splitting recipients, auto-eml for API-only accounts.
#   Infra goes in gmail-api-rw: OAuth, MIME, the actual API calls.
#   Rule of thumb: if you find yourself writing "be nice about X" code,
#   it belongs here, not in gmail-api-rw.
#
# § PUBLIC API (do NOT break — colleagues' aliases call this)
#   Account aliases: g j u cu l h hNY n z (resolved via accounts.json)
#   Actions:         i sent q d x urls send c draft reply reply-all fwd
#                    open trash archive thread read unread sfwd sreply
#                    sreply-all peek
#   Flags:           -w/--web -N/--no-cache -i/--important --quiet -h/--help --version
#                    --dry-run --urls -p/--peek -v --meta -S -t -x
#                    -A --save-attachments-only -a -c -b -s -d/--done
#                    -H --outbox
#   Pagination:      ppN tokens (e.g. pp2 = page 2)
#   This file lives in ~/mise (public). NEVER reference seiton paths here.
#
# § SECTION MAP (anchor strings; grep for "§ <name>")
#   § DEPENDENCY CHECKS         — startup validation (jq, python3, .venv)
#   § CONFIG                    — load accounts.json into ACCTS/EMAILS/LABELS
#   § ROUTING HELPERS           — _lookup_muttrc, _is_api_only
#   § DIRECT SEND               — direct_send() unified send pipeline
#   § LOGGING                   — log_info/log_warn/log_error (emoji convention)
#   § PARSE_ACTION_ARGS         — shared arg-walker for inbox+sent handlers
#   § USAGE                     — help text
#   § PARSING & DISPATCH        — top-level argv → action+account+rest
#   § ACTION ROUTER             — case "$action" in i|q|sent|send|...
#
# § LANDMINES (things that have bitten us; tread carefully)
#   - The `${array[@]+"${array[@]}"}` idiom guards against unbound array
#     errors under `set -u`. Don't "simplify" it; bash's empty-array semantics
#     differ between releases.
#   - The m parser will eat any positional that matches an account alias.
#     New flags that take a value (like --outbox <alias>) MUST be recognized
#     in § PARSING & DISPATCH before the account-resolution branch, or their
#     value gets stolen as the account.
#   - Numeric arg after `q` is the QUERY, not an index.
#     `m q 31` searches for "31"; the q-skip-rest[0] rule lives in
#     parse_action_args. Keep it.
#   - `M_LIST_CACHE_TTL` is declared but currently unused. The cache-by-key
#     strategy in gmail-api-rw doesn't use TTL; this var is here for forward
#     compat. Don't rely on it expiring anything.
#   - Yellow ⚠️ via log_warn is the "I'm being forgiving" signal. Use it
#     when m fills in a missing arg or auto-corrects user input. Don't
#     silently fix things — always announce.
#
# § NON-GOALS (don't add these without asking)
#   - Tests. Real Gmail OAuth + state makes them either fake or fragile.
#   - Type-of-message filtering. Use Gmail search syntax via -q instead.
#   - Removing CLI flags. Public API; colleagues depend on them.

set -euo pipefail

# --- config ---
MAIL_TOOLS_CONFIG="${MAIL_TOOLS_CONFIG:-$HOME/.config/mail-tools/accounts.json}"
M_LIST_CACHE_TTL="${M_LIST_CACHE_TTL:-30}" # NOTE: declared, not yet used; gmail-api-rw caches by (count, query, account) without TTL
M_QUIET_MODE="${M_QUIET_MODE:-0}"

# Source optional user config
if [[ -f "$HOME/.config/m/config" ]]; then
    source "$HOME/.config/m/config"
elif [[ -f "$AUX_DIR/m-config.bash" ]]; then
    source "$AUX_DIR/m-config.bash"
fi

# ========================================================================
# § DEPENDENCY CHECKS — startup validation with actionable errors
# ========================================================================

check_dependencies() {
    local missing_deps=()
    local config_issues=()

    # Check for required commands
    if ! command -v jq >/dev/null 2>&1; then
        missing_deps+=("jq: Install with 'brew install jq' or 'apt-get install jq'")
    fi

    if ! command -v python3 >/dev/null 2>&1; then
        missing_deps+=("python3: Install Python 3 from python.org or your package manager")
    fi

    # Check for configuration file
    if [[ ! -f "$MAIL_TOOLS_CONFIG" ]]; then
        config_issues+=("Configuration file missing: $MAIL_TOOLS_CONFIG")
        config_issues+=("  Create with: mkdir -p \$(dirname '$MAIL_TOOLS_CONFIG')")
        config_issues+=("  See SETUP.md for configuration instructions")
    else
        # Validate JSON syntax
        if ! jq empty "$MAIL_TOOLS_CONFIG" 2>/dev/null; then
            config_issues+=("Invalid JSON in: $MAIL_TOOLS_CONFIG")
            config_issues+=("  Check syntax with: jq . '$MAIL_TOOLS_CONFIG'")
        fi
    fi

    # Check for gmail-api-rw executable
    local gmail_api_rw="/Users/wiggins/mise/py/gmail-api-rw"
    if [[ ! -x "$gmail_api_rw" ]]; then
        config_issues+=("Gmail API client not executable: $gmail_api_rw")
        config_issues+=("  Fix with: chmod +x '$gmail_api_rw'")
    fi

    # Check for .venv (needed for gmail-api-rw)
    local venv_python="/Users/wiggins/mise/py/.venv/bin/python3"
    if [[ ! -x "$venv_python" ]]; then
        config_issues+=("Python virtual environment missing: $venv_python")
        config_issues+=("  Setup with: cd /Users/wiggins/mise/py && python3 -m venv .venv")
        config_issues+=("  Install deps: .venv/bin/pip install google-api-python-client google-auth-oauthlib")
    fi

    # Report errors with clear action steps
    if (( ${#missing_deps[@]} > 0 || ${#config_issues[@]} > 0 )); then
        echo "⚠️  Email system dependency check failed:" >&2
        echo >&2

        if (( ${#missing_deps[@]} > 0 )); then
            echo "Missing required commands:" >&2
            printf "  %s\n" "${missing_deps[@]}" >&2
            echo >&2
        fi

        if (( ${#config_issues[@]} > 0 )); then
            echo "Configuration issues:" >&2
            printf "  %s\n" "${config_issues[@]}" >&2
            echo >&2
        fi

        echo "Fix the above issues and try again." >&2
        return 1
    fi

    return 0
}

# Check dependencies on startup (but allow override for testing)
if [[ "${M_SKIP_DEPENDENCY_CHECK:-0}" == "0" ]]; then
    check_dependencies || exit 1
fi

# Initialize configuration
declare -A EMAILS=()
declare -A ACCTS=()
declare -A LABELS=()

# Function to load account configuration from external files
load_mail_config() {
# ========================================================================
# § CONFIG — load accounts.json into ACCTS / EMAILS / LABELS
# ========================================================================
#
# PURPOSE:
# - Load all account information from JSON config (PII-free code design)
# - Build associative arrays for runtime account resolution
# - Replace hardcoded account mappings with dynamic configuration
#
# WHY DYNAMIC CONFIG:
# - Keeps PII out of ~/mise/ (public) code
# - Allows users to add accounts without editing script
# - Single source of truth for account information
# - Supports multiple account types (SMTP, API, web)
#
# CONFIG FILE: ~/.config/mail-tools/accounts.json
# FORMAT:
# {
#   "accounts": {
#     "g": {
#       "email": "user@gmail.com",
#       "chrome_profile": "Default",
#       "label": "Personal",
#       "gmail_flag": ""  // Optional: backend routing flag
#     },
#     "u": {
#       "email": "user@columbia.edu",
#       "chrome_profile": "Profile 1",
#       "label": "Work",
#       "gmail_flag": "cu"
#     }
#   }
# }
#
# GLOBAL ARRAYS POPULATED:
# - EMAILS[alias] = email address (for display, validation)
# - LABELS[alias] = human-readable name (for UI, help)
# - ACCTS[alias] = "gmail_flag:chrome_profile" (for backend routing)
#
# ROUTING DECISION:
# - gmail_flag determines backend tool selection
# - chrome_profile determines web browser routing
# - Empty gmail_flag = default/primary gmail account
# - Non-empty gmail_flag = specific backend (-e flag for gmail-api-rw)
#
local config_file="$MAIL_TOOLS_CONFIG"

# ================================================
# STEP 1: Try new JSON config (preferred method)
# ================================================
if [[ -f "$config_file" ]] && command -v jq >/dev/null 2>&1; then
    local accounts
    # Extract account data: alias|email|chrome_profile|label|gmail_flag
    # The jq query safely handles missing optional fields (label, gmail_flag)
    accounts=$(jq -r '.accounts | to_entries[] | "\(.key)|\(.value.email)|\(.value.chrome_profile)|\(.value.label // "")|\(.value.gmail_flag // "")"' "$config_file" 2>/dev/null)

    if [[ -n "$accounts" ]]; then
        # ============================================
        # STEP 1A: Parse JSON data into arrays
        # ============================================
        while IFS='|' read -r alias email chrome_profile label gmail_flag; do
            # Basic account info
            EMAILS["$alias"]="$email"
            LABELS["$alias"]="${label:-$alias}"  # Default to alias if no label

            # ========================================
            # STEP 1B: Build backend routing string
            # ========================================
            # Format: "gmail_flag:chrome_profile"
            # - gmail_flag: Backend tool routing (-e flag for gmail-api-rw)
            # - chrome_profile: Browser profile for web interface
            #
            # Examples:
            # - "cu:Profile 1" = Columbia account, Profile 1 browser
            # - ":Default" = Default gmail, Default browser profile
            #
            if [[ -n "$gmail_flag" ]]; then
                # Explicit gmail_flag specified in config
                ACCTS["$alias"]="$gmail_flag:$chrome_profile"
            elif [[ "$alias" == "g" ]]; then
                # Special case: 'g' alias gets empty gmail_flag (default account)
                ACCTS["$alias"]=":$chrome_profile"
            else
                # ====================================
                # STEP 1C: Derive gmail_flag from alias
                # ====================================
                # Fallback for accounts without explicit gmail_flag
                local short_name="$alias"
                    # Preserve known legacy flags if possible or just use alias
                    case "$alias" in
                        j|joint) short_name="joint" ;;
                        u|cu)    short_name="cu" ;;
                        l|lake)  short_name="lake" ;;
                        h|hNY)   short_name="hNY" ;;
                    esac
                    ACCTS["$alias"]="$short_name:$chrome_profile"
                fi
            done <<< "$accounts"
            return 0
        fi
    fi

    # ERROR: Configuration required - no hardcoded fallback for PII-free operation
    log_error "No email configuration found!"
    echo "m: Please create ~/.config/mail-tools/accounts.json" >&2
    echo "m: See SETUP.md for configuration instructions" >&2
    exit 1
}

load_mail_config

# ========================================================================
# § ROUTING HELPERS — core API-vs-SMTP decision
# ========================================================================
# An account is "API-only" iff its muttrc field is "/dev/null" or absent
# (or the file doesn't exist). Real muttrc path = SMTP. The `_is_api_only`
# helper centralizes this check; callers should never compare paths inline.

# Look up muttrc path for an account slug or email substring
# Uses the unified JSON config at ~/.config/mail-tools/accounts.json
# Returns muttrc path, or empty string if no match
_lookup_muttrc() {
    local needle="$1"

    # Check if we have this account in our loaded config
    if [[ -n "${EMAILS[$needle]}" ]]; then
        # Direct alias match - extract muttrc from JSON config
        jq -r ".accounts.\"$needle\".muttrc // empty" "$MAIL_TOOLS_CONFIG" 2>/dev/null
        return
    fi

    # Try partial matching on any field (alias, email)
    local needle_lower
    needle_lower=$(printf '%s' "$needle" | tr '[:upper:]' '[:lower:]')
    local match_alias=""

    # Search through all accounts for partial matches
    for alias in "${!EMAILS[@]}"; do
        local email="${EMAILS[$alias]}"
        local alias_lower email_lower
        alias_lower=$(printf '%s' "$alias" | tr '[:upper:]' '[:lower:]')
        email_lower=$(printf '%s' "$email" | tr '[:upper:]' '[:lower:]')

        if [[ "$alias_lower" == *"$needle_lower"* || "$email_lower" == *"$needle_lower"* ]]; then
            match_alias="$alias"
            break
        fi
    done

    if [[ -n "$match_alias" ]]; then
        jq -r ".accounts.\"$match_alias\".muttrc // empty" "$MAIL_TOOLS_CONFIG" 2>/dev/null
    fi
}

# Get the default account's muttrc from JSON config
_default_muttrc() {
    local default_alias
    default_alias=$(jq -r '.default_account // empty' "$MAIL_TOOLS_CONFIG" 2>/dev/null)

    if [[ -n "$default_alias" ]]; then
        jq -r ".accounts.\"$default_alias\".muttrc // empty" "$MAIL_TOOLS_CONFIG" 2>/dev/null
        return
    fi

    # Fall back to first account if no default specified
    local first_alias
    for alias in "${!EMAILS[@]}"; do
        first_alias="$alias"
        break
    done

    if [[ -n "$first_alias" ]]; then
        jq -r ".accounts.\"$first_alias\".muttrc // empty" "$MAIL_TOOLS_CONFIG" 2>/dev/null
    fi
}

# CORE ROUTING DECISION: API vs SMTP
# This determines which backend to use based on account configuration
# API-only accounts (like Columbia) have muttrc="/dev/null"
# SMTP accounts have real muttrc files with credentials
_is_api_only() {
    local muttrc="$1"
    [[ "$muttrc" == "/dev/null"* || ! -f "$muttrc" ]]
}

# Return a non-colliding path: if PATH exists, try PATH-v2, PATH-v3, ... This
# mirrors the backend's versioned_path so decoded -S saves don't silently
# clobber an existing file the way the --raw path already avoids.
_versioned_path() {
    local p="$1"
    [[ -e "$p" ]] || { printf '%s\n' "$p"; return; }
    local n=2
    while [[ -e "${p}-v${n}" ]]; do
        n=$((n + 1))
    done
    printf '%s\n' "${p}-v${n}"
}

# Open the most-recently-extracted attachment. Used by the `-A open` paths in
# both the inbox and sent handlers (the backend drops attachments into
# /tmp/spool/attachments/; the freshest by mtime is the one just saved).
_open_newest_attachment() {
    log_info "🔍 Finding most recent attachment to open..."
    if [[ ! -d "/tmp/spool/attachments" ]]; then
        log_warn "⚠️ Attachments directory doesn't exist"
        return
    fi
    local latest_file
    latest_file=$(ls -t "/tmp/spool/attachments/"* 2>/dev/null | head -1 || true)
    if [[ -n "$latest_file" ]]; then
        log_info "📂 Opening: $(basename "$latest_file")"
        /Users/wiggins/mise/bash/open "$latest_file"
    else
        log_warn "⚠️ No attachments found in /tmp/spool/attachments/"
    fi
}

# LOUD-FAILURE GUARD: an SMTP muttrc with no smtp_url makes neomutt fall back
# to local /usr/sbin/sendmail, which on macOS SILENTLY DROPS the message —
# neomutt still exits 0, so the wrapper prints "sent" and nothing leaves the
# box. This bit the joint account on 2026-05-29 (two real emails lost). Call
# this before every neomutt send: if the muttrc is SMTP-routed but lacks an
# smtp_url, abort loudly instead of pretending to send.
_assert_smtp_capable() {
    local muttrc="$1"
    local account="${2:-?}"
    # API-routed accounts don't use this path; nothing to check.
    _is_api_only "$muttrc" && return 0
    if ! grep -q "^[[:space:]]*set[[:space:]]\+smtp_url" "$muttrc" 2>/dev/null; then
        log_error "Account '$account' is SMTP-routed but its muttrc has no smtp_url."
        log_error "  muttrc: $muttrc"
        log_error "  Without smtp_url, neomutt would silently drop this message."
        log_error "  Fix: add a working 'set smtp_url=...' block to that muttrc,"
        log_error "       or route this account via the Gmail API by setting its"
        log_error "       muttrc to /dev/null in $MAIL_TOOLS_CONFIG."
        return 1
    fi
    return 0
}

# ========================================================================
# § SCHEDULED SEND — scheduled email delivery via launchd
# ========================================================================

# Parse time specification and return Unix timestamp
_parse_after_time() {
    local time_spec="$1"
    local now
    now=$(date +%s)
    local target_time

    # Handle relative times
    if [[ "$time_spec" =~ ^[0-9]+[mhdw]$ ]]; then
        local num="${time_spec%[mhdw]}"
        local unit="${time_spec: -1}"
        local seconds=0

        case "$unit" in
            m) seconds=$((num * 60)) ;;
            h) seconds=$((num * 3600)) ;;
            d) seconds=$((num * 86400)) ;;
            w) seconds=$((num * 604800)) ;;
            *)
                log_error "Invalid time unit in '$time_spec'. Use: 5m, 2h, 1d, 1w"
                return 1
                ;;
        esac
        target_time=$((now + seconds))
    else
        # Try to parse with date command
        # BSD date (macOS) approach: try common patterns first
        if target_time=$(date -j -f "%Y-%m-%d %H:%M:%S" "$time_spec" +%s 2>/dev/null); then
            : # parsed successfully
        elif target_time=$(date -j -f "%H:%M" "$time_spec" +%s 2>/dev/null); then
            : # parsed as time today
        elif target_time=$(date -j -f "%Y-%m-%d %H:%M" "$time_spec" +%s 2>/dev/null); then
            : # parsed as date and time
        else
            # Try natural language patterns by converting to specific formats
            local converted_time=""
            case "$time_spec" in
                "9am"|"9 am")
                    converted_time="09:00"
                    ;;
                "10am"|"10 am")
                    converted_time="10:00"
                    ;;
                "11am"|"11 am")
                    converted_time="11:00"
                    ;;
                "12pm"|"12 pm"|"noon")
                    converted_time="12:00"
                    ;;
                "1pm"|"1 pm")
                    converted_time="13:00"
                    ;;
                "2pm"|"2 pm")
                    converted_time="14:00"
                    ;;
                "3pm"|"3 pm")
                    converted_time="15:00"
                    ;;
                "4pm"|"4 pm")
                    converted_time="16:00"
                    ;;
                "5pm"|"5 pm")
                    converted_time="17:00"
                    ;;
                "6pm"|"6 pm")
                    converted_time="18:00"
                    ;;
                "7pm"|"7 pm")
                    converted_time="19:00"
                    ;;
                "8pm"|"8 pm")
                    converted_time="20:00"
                    ;;
                "9pm"|"9 pm")
                    converted_time="21:00"
                    ;;
                "today 9am"|"today 9 am")
                    converted_time="09:00"
                    ;;
                "today 10am"|"today 10 am")
                    converted_time="10:00"
                    ;;
                "today "*)
                    # Extract time part after "today "
                    local time_part="${time_spec#today }"
                    case "$time_part" in
                        *"am"|*" am")
                            local time_clean="${time_part%am}"
                            time_clean="${time_clean% am}"
                            time_clean="${time_clean% }"
                            if [[ "$time_clean" =~ ^[0-9]+:[0-9]+$ ]]; then
                                # Handle HH:MM format
                                local hour="${time_clean%:*}"
                                local minute="${time_clean#*:}"
                                if [[ $hour -ge 1 && $hour -le 12 ]] && [[ $minute -ge 0 && $minute -le 59 ]]; then
                                    if [[ $hour -eq 12 ]]; then
                                        converted_time=$(printf "00:%02d" "$minute")
                                    else
                                        converted_time=$(printf "%02d:%02d" "$hour" "$minute")
                                    fi
                                fi
                            elif [[ "$time_clean" =~ ^[0-9]+$ ]] && [[ $time_clean -ge 1 && $time_clean -le 12 ]]; then
                                # Handle H format
                                if [[ $time_clean -eq 12 ]]; then
                                    converted_time="00:00"
                                else
                                    converted_time=$(printf "%02d:00" "$time_clean")
                                fi
                            fi
                            ;;
                        *"pm"|*" pm")
                            local time_clean="${time_part%pm}"
                            time_clean="${time_clean% pm}"
                            time_clean="${time_clean% }"
                            if [[ "$time_clean" =~ ^[0-9]+:[0-9]+$ ]]; then
                                # Handle HH:MM format
                                local hour="${time_clean%:*}"
                                local minute="${time_clean#*:}"
                                if [[ $hour -ge 1 && $hour -le 12 ]] && [[ $minute -ge 0 && $minute -le 59 ]]; then
                                    if [[ $hour -eq 12 ]]; then
                                        converted_time=$(printf "12:%02d" "$minute")
                                    else
                                        converted_time=$(printf "%02d:%02d" $((hour + 12)) "$minute")
                                    fi
                                fi
                            elif [[ "$time_clean" =~ ^[0-9]+$ ]] && [[ $time_clean -ge 1 && $time_clean -le 12 ]]; then
                                # Handle H format
                                if [[ $time_clean -eq 12 ]]; then
                                    converted_time="12:00"
                                else
                                    converted_time=$(printf "%02d:00" $((time_clean + 12)))
                                fi
                            fi
                            ;;
                    esac
                    ;;
                "tomorrow "*)
                    # For tomorrow times, we'll compute tomorrow's date and parse time
                    local time_part="${time_spec#tomorrow }"
                    local tomorrow_date
                    tomorrow_date=$(date -v+1d "+%Y-%m-%d")
                    case "$time_part" in
                        *"am"|*" am")
                            local time_clean="${time_part%am}"
                            time_clean="${time_clean% am}"
                            time_clean="${time_clean% }"
                            if [[ "$time_clean" =~ ^[0-9]+:[0-9]+$ ]]; then
                                # Handle HH:MM format
                                local hour="${time_clean%:*}"
                                local minute="${time_clean#*:}"
                                if [[ $hour -ge 1 && $hour -le 12 ]] && [[ $minute -ge 0 && $minute -le 59 ]]; then
                                    if [[ $hour -eq 12 ]]; then
                                        converted_time="${tomorrow_date} $(printf "00:%02d" "$minute")"
                                    else
                                        converted_time="${tomorrow_date} $(printf "%02d:%02d" "$hour" "$minute")"
                                    fi
                                fi
                            elif [[ "$time_clean" =~ ^[0-9]+$ ]] && [[ $time_clean -ge 1 && $time_clean -le 12 ]]; then
                                # Handle H format
                                if [[ $time_clean -eq 12 ]]; then
                                    converted_time="${tomorrow_date} 00:00"
                                else
                                    converted_time="${tomorrow_date} $(printf "%02d:00" "$time_clean")"
                                fi
                            fi
                            ;;
                        *"pm"|*" pm")
                            local time_clean="${time_part%pm}"
                            time_clean="${time_clean% pm}"
                            time_clean="${time_clean% }"
                            if [[ "$time_clean" =~ ^[0-9]+:[0-9]+$ ]]; then
                                # Handle HH:MM format
                                local hour="${time_clean%:*}"
                                local minute="${time_clean#*:}"
                                if [[ $hour -ge 1 && $hour -le 12 ]] && [[ $minute -ge 0 && $minute -le 59 ]]; then
                                    if [[ $hour -eq 12 ]]; then
                                        converted_time="${tomorrow_date} $(printf "12:%02d" "$minute")"
                                    else
                                        converted_time="${tomorrow_date} $(printf "%02d:%02d" $((hour + 12)) "$minute")"
                                    fi
                                fi
                            elif [[ "$time_clean" =~ ^[0-9]+$ ]] && [[ $time_clean -ge 1 && $time_clean -le 12 ]]; then
                                # Handle H format
                                if [[ $time_clean -eq 12 ]]; then
                                    converted_time="${tomorrow_date} 12:00"
                                else
                                    converted_time="${tomorrow_date} $(printf "%02d:00" $((time_clean + 12)))"
                                fi
                            fi
                            ;;
                    esac
                    ;;
                *"am"|*" am")
                    # Handle standalone HH:MMam format (only if not already handled above)
                    if [[ ! "$time_spec" =~ ^today ]] && [[ ! "$time_spec" =~ ^tomorrow ]]; then
                        local time_clean="${time_spec%am}"
                        time_clean="${time_clean% am}"
                        time_clean="${time_clean% }"
                        if [[ "$time_clean" =~ ^[0-9]+:[0-9]+$ ]]; then
                            local hour="${time_clean%:*}"
                            local minute="${time_clean#*:}"
                            if [[ $hour -ge 1 && $hour -le 12 ]] && [[ $minute -ge 0 && $minute -le 59 ]]; then
                                if [[ $hour -eq 12 ]]; then
                                    converted_time=$(printf "00:%02d" "$minute")
                                else
                                    converted_time=$(printf "%02d:%02d" "$hour" "$minute")
                                fi
                            fi
                        fi
                    fi
                    ;;
                *"pm"|*" pm")
                    # Handle standalone HH:MMpm format (only if not already handled above)
                    if [[ ! "$time_spec" =~ ^today ]] && [[ ! "$time_spec" =~ ^tomorrow ]]; then
                        local time_clean="${time_spec%pm}"
                        time_clean="${time_clean% pm}"
                        time_clean="${time_clean% }"
                        if [[ "$time_clean" =~ ^[0-9]+:[0-9]+$ ]]; then
                            local hour="${time_clean%:*}"
                            local minute="${time_clean#*:}"
                            if [[ $hour -ge 1 && $hour -le 12 ]] && [[ $minute -ge 0 && $minute -le 59 ]]; then
                                if [[ $hour -eq 12 ]]; then
                                    converted_time=$(printf "12:%02d" "$minute")
                                else
                                    converted_time=$(printf "%02d:%02d" $((hour + 12)) "$minute")
                                fi
                            fi
                        fi
                    fi
                    ;;
            esac

            # Try parsing the converted time
            if [[ -n "$converted_time" ]]; then
                if target_time=$(date -j -f "%H:%M" "$converted_time" +%s 2>/dev/null); then
                    : # parsed successfully
                elif target_time=$(date -j -f "%Y-%m-%d %H:%M" "$converted_time" +%s 2>/dev/null); then
                    : # parsed successfully with date
                else
                    log_error "Could not parse converted time '$converted_time'"
                    echo "Examples: '5m', '2h', '9am', '11:30am', 'today 2pm', 'tomorrow 9am', '14:30'" >&2
                    return 1
                fi
            else
                log_error "Could not parse time '$time_spec'"
                echo "Examples: '5m', '2h', '9am', '11:30am', 'today 2pm', 'tomorrow 9am', '14:30'" >&2
                return 1
            fi
        fi
    fi

    # Ensure time is in the future
    if [[ $target_time -le $now ]]; then
        log_error "Scheduled time must be in the future"
        echo "Parsed time: $(date -r "$target_time" 2>/dev/null || echo "invalid")" >&2
        echo "Current time: $(date -r "$now")" >&2
        return 1
    fi

    echo "$target_time"
}

# Create draft and schedule its sending
_schedule_send() {
    local after_time="$1"
    shift

    # Parse time
    local scheduled_timestamp
    if ! scheduled_timestamp=$(_parse_after_time "$after_time"); then
        return 1
    fi

    # All remaining args are already formatted for gmail-api-rw draft
    local -a draft_args=("$@")

    # Check if this is a dry run - don't actually create drafts or schedule
    if (( dry_run )); then
        echo "✓ [DRY RUN] Would create draft and schedule for $(date -r "$scheduled_timestamp")"
        echo " Would create .eml file with stdin body and headers"
        echo " Command would be: gmail-api-rw draft -H temporary.eml"
        echo " Would create launchd job to send at scheduled time"
        return 0
    fi

    # Handle stdin body - create temporary .eml file for draft creation
    local temp_eml
    temp_eml=$(mktemp /tmp/m-scheduled-XXXXXX.eml)

    # Build .eml file with headers and body from stdin
    {
        # Extract recipient from draft_args (last argument that doesn't start with -)
        local recipient=""
        for arg in "${draft_args[@]}"; do
            if [[ "$arg" != -* ]]; then
                recipient="$arg"
            fi
        done

        [[ -n "$recipient" ]] && printf 'To: %s\n' "$recipient"

        # Extract subject from draft_args
        local i=0
        while [[ $i -lt ${#draft_args[@]} ]]; do
            if [[ "${draft_args[i]}" == "-s" && $((i + 1)) -lt ${#draft_args[@]} ]]; then
                printf 'Subject: %s\n' "${draft_args[i+1]}"
                break
            fi
            i=$((i + 1))
        done

        printf '\n'
        cat  # Body from stdin
    } > "$temp_eml"

    # Create draft using the .eml file
    local draft_output
    if ! draft_output=$(timeout 30s gmail-api-rw draft -H "$temp_eml" 2>&1); then
        log_error "Failed to create draft (may have timed out after 30s)"
        echo "$draft_output" >&2
        rm -f "$temp_eml"
        return 1
    fi

    # Clean up temp file
    rm -f "$temp_eml"

    # Extract draft ID from output
    local draft_id
    if ! draft_id=$(echo "$draft_output" | grep -o 'id=[^[:space:]]*' | cut -d= -f2); then
        log_error "Could not extract draft ID from output"
        echo "$draft_output" >&2
        return 1
    fi

    # Extract account from draft_args for metadata
    local account=""
    local i=0
    while [[ $i -lt ${#draft_args[@]} ]]; do
        if [[ "${draft_args[i]}" == "-e" && $((i + 1)) -lt ${#draft_args[@]} ]]; then
            account="${draft_args[i+1]}"
            break
        fi
        i=$((i + 1))
    done

    # Store metadata and create launchd job
    if ! _create_scheduled_metadata "$draft_id" "$scheduled_timestamp" "$account" "${draft_args[@]}"; then
        return 1
    fi

    if ! _create_launchd_job "$draft_id" "$scheduled_timestamp"; then
        # Clean up metadata on launchd failure
        rm -f "$HOME/.config/mail-tools/scheduled/$draft_id.json"
        return 1
    fi

    local scheduled_date
    scheduled_date=$(date -r "$scheduled_timestamp" "+%Y-%m-%d %H:%M:%S")

    echo "✓ Draft created and scheduled for $scheduled_date"
    echo "  Will send when laptop available after that time"
    echo "  Cancel with: m scheduled cancel $draft_id"
}

# Create metadata file for scheduled send
_create_scheduled_metadata() {
    local draft_id="$1"
    local scheduled_timestamp="$2"
    local account="$3"
    shift 3
    local original_command="m send --after [time] $*"

    local metadata_file="$HOME/.config/mail-tools/scheduled/$draft_id.json"

    # Ensure the directory exists
    mkdir -p "$(dirname "$metadata_file")"

    local created_at
    created_at=$(date +%s)
    local scheduled_human
    scheduled_human=$(date -r "$scheduled_timestamp" "+%Y-%m-%d %H:%M:%S")

    cat > "$metadata_file" << EOF
{
    "draft_id": "$draft_id",
    "scheduled_time": $scheduled_timestamp,
    "scheduled_time_human": "$scheduled_human",
    "account": "${account:-default}",
    "original_command": "$original_command",
    "created_at": $created_at
}
EOF

    if [[ ! -f "$metadata_file" ]]; then
        log_error "Failed to create metadata file: $metadata_file"
        return 1
    fi
}

# Create launchd plist for scheduled execution
_create_launchd_job() {
    local draft_id="$1"
    local scheduled_timestamp="$2"

    # Convert timestamp to calendar components
    local year month day hour minute
    year=$(date -r "$scheduled_timestamp" +%Y)
    month=$(date -r "$scheduled_timestamp" +%m)
    day=$(date -r "$scheduled_timestamp" +%d)
    hour=$(date -r "$scheduled_timestamp" +%H)
    minute=$(date -r "$scheduled_timestamp" +%M)

    # Remove leading zeros
    month=$((10#$month))
    day=$((10#$day))
    hour=$((10#$hour))
    minute=$((10#$minute))

    local plist_file="$HOME/Library/LaunchAgents/com.mise.scheduled-send.$draft_id.plist"

    cat > "$plist_file" << EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mise.scheduled-send.$draft_id</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/wiggins/mise/bash/m-scheduled-send-wrapper</string>
        <string>$draft_id</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Year</key>
        <integer>$year</integer>
        <key>Month</key>
        <integer>$month</integer>
        <key>Day</key>
        <integer>$day</integer>
        <key>Hour</key>
        <integer>$hour</integer>
        <key>Minute</key>
        <integer>$minute</integer>
    </dict>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
EOF

    if [[ ! -f "$plist_file" ]]; then
        log_error "Failed to create launchd plist: $plist_file"
        return 1
    fi

    # Load the job with timeout
    if ! timeout 10s launchctl load "$plist_file" 2>/dev/null; then
        log_error "Failed to load launchd job: $plist_file"
        rm -f "$plist_file"
        return 1
    fi
}

# List scheduled sends
_list_scheduled_sends() {
    local scheduled_dir="$HOME/.config/mail-tools/scheduled"
    if [[ ! -d "$scheduled_dir" ]]; then
        echo "No scheduled sends found."
        return 0
    fi

    local count=0
    local now
    now=$(date +%s)

    echo "Scheduled sends:"
    for metadata_file in "$scheduled_dir"/*.json; do
        [[ -f "$metadata_file" ]] || continue
        count=$((count + 1))

        local draft_id scheduled_time account original_command
        draft_id=$(jq -r '.draft_id // "unknown"' "$metadata_file" 2>/dev/null)
        scheduled_time=$(jq -r '.scheduled_time // 0' "$metadata_file" 2>/dev/null)
        account=$(jq -r '.account // "default"' "$metadata_file" 2>/dev/null)
        original_command=$(jq -r '.original_command // "unknown"' "$metadata_file" 2>/dev/null)

        if [[ "$scheduled_time" =~ ^[0-9]+$ ]] && [[ "$scheduled_time" -gt 0 ]]; then
            local scheduled_date
            scheduled_date=$(date -r "$scheduled_time" "+%Y-%m-%d %H:%M" 2>/dev/null)
            local time_diff=$((scheduled_time - now))
            local time_desc=""

            if [[ $time_diff -gt 0 ]]; then
                local hours=$((time_diff / 3600))
                local minutes=$(((time_diff % 3600) / 60))
                if [[ $hours -gt 0 ]]; then
                    time_desc=" (in ${hours}h ${minutes}m)"
                else
                    time_desc=" (in ${minutes}m)"
                fi
            else
                time_desc=" (overdue)"
            fi

            echo "  $scheduled_date → $account $draft_id$time_desc"
        else
            echo "  [invalid time] → $account $draft_id"
        fi
    done

    if [[ $count -eq 0 ]]; then
        echo "No scheduled sends found."
    fi
}

# Cancel a scheduled send
_cancel_scheduled_send() {
    local draft_id="$1"
    local metadata_file="$HOME/.config/mail-tools/scheduled/$draft_id.json"
    local plist_file="$HOME/Library/LaunchAgents/com.mise.scheduled-send.$draft_id.plist"

    if [[ ! -f "$metadata_file" ]]; then
        log_error "Scheduled send not found: $draft_id"
        return 1
    fi

    # Read original command for confirmation
    local original_command
    original_command=$(jq -r '.original_command // "unknown"' "$metadata_file" 2>/dev/null)

    # Unload and remove launchd job
    if [[ -f "$plist_file" ]]; then
        launchctl unload "$plist_file" 2>/dev/null || true
        rm -f "$plist_file"
    fi

    # Remove metadata
    rm -f "$metadata_file"

    echo "✓ Canceled scheduled send: $draft_id"
    echo "  Original command: $original_command"
    echo "  Draft remains in Gmail for manual sending"
}

# Show status of a scheduled send
_status_scheduled_send() {
    local draft_id="$1"
    local metadata_file="$HOME/.config/mail-tools/scheduled/$draft_id.json"
    local plist_file="$HOME/Library/LaunchAgents/com.mise.scheduled-send.$draft_id.plist"

    if [[ ! -f "$metadata_file" ]]; then
        log_error "Scheduled send not found: $draft_id"
        return 1
    fi

    echo "Scheduled send status: $draft_id"

    # Parse metadata
    local scheduled_time account original_command created_at
    scheduled_time=$(jq -r '.scheduled_time // 0' "$metadata_file" 2>/dev/null)
    account=$(jq -r '.account // "default"' "$metadata_file" 2>/dev/null)
    original_command=$(jq -r '.original_command // "unknown"' "$metadata_file" 2>/dev/null)
    created_at=$(jq -r '.created_at // 0' "$metadata_file" 2>/dev/null)

    echo "  Account: $account"
    echo "  Original command: $original_command"

    if [[ "$created_at" =~ ^[0-9]+$ ]] && [[ "$created_at" -gt 0 ]]; then
        echo "  Created: $(date -r "$created_at" "+%Y-%m-%d %H:%M:%S")"
    fi

    if [[ "$scheduled_time" =~ ^[0-9]+$ ]] && [[ "$scheduled_time" -gt 0 ]]; then
        local now
        now=$(date +%s)
        echo "  Scheduled: $(date -r "$scheduled_time" "+%Y-%m-%d %H:%M:%S")"
        local time_diff=$((scheduled_time - now))

        if [[ $time_diff -gt 0 ]]; then
            local hours=$((time_diff / 3600))
            local minutes=$(((time_diff % 3600) / 60))
            echo "  Status: Pending (in ${hours}h ${minutes}m)"
        else
            echo "  Status: Overdue (check logs for execution status)"
        fi
    fi

    # Check launchd job status
    if [[ -f "$plist_file" ]]; then
        echo "  launchd: Job file exists"
        if launchctl list | grep -q "com.mise.scheduled-send.$draft_id"; then
            echo "  launchd: Job loaded and active"
        else
            echo "  launchd: Job file exists but not loaded"
        fi
    else
        echo "  launchd: Job file missing"
    fi

    # Check if metadata file exists
    echo "  Metadata: $(ls -la "$metadata_file" 2>/dev/null | awk '{print $5 " bytes, " $6 " " $7 " " $8}')"
}

# ========================================================================
# § ALIAS RESOLUTION — resolve email aliases for cc/bcc addresses
# ========================================================================

# Resolve an email alias to full email address
# Reads from ~/.config/m/aliases (case-insensitive lookup)
# Returns original input if not found in aliases file
_resolve_alias() {
    local input="$1"
    local aliases_file="$HOME/.config/m/aliases"

    # Return input unchanged if no aliases file
    if [[ ! -f "$aliases_file" ]]; then
        echo "$input"
        return
    fi

    # Case-insensitive lookup in aliases file
    # Format: "alias key email@domain.com"
    local resolved
    resolved=$(grep -i "^alias ${input}[[:space:]]" "$aliases_file" 2>/dev/null | head -1 | awk '{print $3}')

    if [[ -n "$resolved" ]]; then
        echo "$resolved"
    else
        echo "$input"
    fi
}

# Build the view-filter exclusion string for -i/--important. Reads one Gmail
# exclusion per line from ~/.config/m/view-filter.txt (blank lines and lines
# starting with '#' ignored), joined with spaces. Falls back to a built-in
# default and notes it on stderr once if the file is absent. View-only: these
# are just `-from:` query terms; nothing is muted or modified.
_view_filter_excludes() {
    local f="$HOME/.config/m/view-filter.txt"
    if [[ -f "$f" ]]; then
        grep -vE '^[[:space:]]*(#|$)' "$f" | tr '\n' ' ' | sed 's/[[:space:]]*$//'
    else
        echo "-from:qustodio -from:googleplay"
        echo "m: ~/.config/m/view-filter.txt not found; using built-in default (-from:qustodio -from:googleplay)" >&2
    fi
}

# Cc/Bcc rejection of unresolvable addresses lives in the Python backend
# (gmail-api-rw:_assert_valid_header_addrs), which is the single source of
# truth on every send path and also knows the contacts file (nfile.asc). The
# bash side only resolves m-aliases via _resolve_alias above; it must NOT
# reject bare words, since a bare name may be a valid contact.

# ========================================================================
# § ATTACHMENT PROMPT — interactive add/delete/edit before send
# ========================================================================
# Mutates the named array in place. Returns 0 to proceed, 1 to cancel.
# Skipped (returns 0) on non-tty so scripted callers send silently.
_attachment_prompt() {
    local arr_name="$1"
    local context="${2:-}"

    if [[ ! -t 0 || ! -t 1 ]]; then
        return 0
    fi

    local -n _atts="$arr_name"

    while true; do
        echo >&2
        if [[ -n "$context" ]]; then
            echo "$context" >&2
        fi
        if (( ${#_atts[@]} == 0 )); then
            echo "Attachments: (none)" >&2
        else
            echo "Attachments:" >&2
            local idx=1
            for a in "${_atts[@]}"; do
                printf "  %d. %s\n" "$idx" "$a" >&2
                idx=$((idx+1))
            done
        fi

        local reply
        printf "[a]dd  [d]elete N  [e]dit list  [y]send  [n]cancel > " >&2
        if ! IFS= read -r reply; then
            echo >&2
            return 1
        fi

        local cmd="${reply%% *}"
        local rest="${reply#"$cmd"}"
        rest="${rest# }"

        case "$cmd" in
            ""|y|Y|yes)
                return 0
                ;;
            n|N|no|q|Q)
                echo "send cancelled" >&2
                return 1
                ;;
            a|A|add)
                local path="$rest"
                if [[ -z "$path" ]]; then
                    printf "  path > " >&2
                    IFS= read -r -e path || continue
                fi
                path="${path/#~/$HOME}"
                if [[ -z "$path" ]]; then
                    continue
                fi
                if [[ ! -e "$path" ]]; then
                    echo "  not found: $path" >&2
                    continue
                fi
                _atts+=("$path")
                ;;
            d|D|del|delete|rm)
                local n="$rest"
                if [[ -z "$n" ]]; then
                    printf "  number > " >&2
                    IFS= read -r n || continue
                fi
                if ! [[ "$n" =~ ^[0-9]+$ ]] || (( n < 1 || n > ${#_atts[@]} )); then
                    echo "  not a valid index: $n" >&2
                    continue
                fi
                local -a _new=()
                local i=0
                for a in "${_atts[@]}"; do
                    i=$((i+1))
                    [[ $i -eq $n ]] && continue
                    _new+=("$a")
                done
                _atts=("${_new[@]+"${_new[@]}"}")
                ;;
            e|E|edit)
                local tmp
                tmp=$(mktemp -t m-attach.XXXXXX)
                {
                    echo "# One attachment path per line. Lines starting with # are ignored."
                    echo "# Save and quit to apply; quit without saving to keep current list."
                    for a in "${_atts[@]+"${_atts[@]}"}"; do
                        echo "$a"
                    done
                } > "$tmp"
                "${EDITOR:-vi}" "$tmp" </dev/tty >/dev/tty 2>&1 || { rm -f "$tmp"; continue; }
                local -a _edited=()
                while IFS= read -r line; do
                    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
                    line="${line/#~/$HOME}"
                    if [[ ! -e "$line" ]]; then
                        echo "  warning: not found, skipping: $line" >&2
                        continue
                    fi
                    _edited+=("$line")
                done < "$tmp"
                rm -f "$tmp"
                _atts=("${_edited[@]+"${_edited[@]}"}")
                ;;
            *)
                echo "  unknown command: $cmd" >&2
                ;;
        esac
    done
}

# ========================================================================
# § DIRECT SEND — unified send pipeline (file mode + compose mode)
# ========================================================================
# direct_send() decides between two paths based on whether any arg ends
# in .eml (file mode) or not (compose mode). For API-only accounts in
# compose mode, it auto-builds a .eml from stdin and ships via API.
# Handles file sending, attachment processing, and backend routing

# With edit_headers set, neomutt's compose buffer is a 9-line header block
# (From/To/Cc/Bcc/Reply-To/Subject/...) followed by a blank line, so the body
# starts on line 10. Land the cursor there in insert mode so composing takes
# zero keystrokes. cursor() clamps to the last line on short buffers, and
# startinsert is a no-op if the buffer is empty. gmail-smtp-w does the same;
# direct_send calls neomutt directly (no wrapper), so it needs its own copy.
M_NEOMUTT_EDITOR="set editor=\"vim -c 'call cursor(10,1)' -c startinsert\""

direct_send() {
    local -a send_args=("$@")

    # Parse arguments (simplified version of send script's parsing)
    local account=""
    local done_flag=0
    local dry_run=0
    local subject=""
    local after_time=""
    local -a cc_addrs=()
    local -a bcc_addrs=()
    local -a args=()
    local -a attachments=()

    local i=0
    while [[ $i -lt ${#send_args[@]} ]]; do
        case "${send_args[i]}" in
            -e)
                account="${send_args[i+1]}"
                ((i+=2))
                ;;
            -H)
                # Mutt compatibility: treat -H file as just the file.
                # Guard: if -H is followed by another flag (e.g. -H -H file) or
                # nothing, the user doubled the flag or dropped the filename.
                # Blindly taking the next token would feed "-H" downstream as the
                # .eml path and produce a cryptic "argument -H: expected one
                # argument" from the backend. Stop with a clear hint instead.
                if [[ -z "${send_args[i+1]+x}" || "${send_args[i+1]}" == -* ]]; then
                    log_error "I think you put in -H -H. The -H flag needs a single .eml file right after it (e.g. -H draft.eml). Please fix and re-run."
                    return 2
                fi
                args+=("${send_args[i+1]}")
                ((i+=2))
                ;;
            -a)
                # Guard: -a with no path (or a flag where the path should be).
                if [[ -z "${send_args[i+1]+x}" || "${send_args[i+1]}" == -* ]]; then
                    log_error "-a needs an attachment path right after it (e.g. -a file.pdf). It looks like one is missing. Please fix and re-run."
                    return 2
                fi
                attachments+=("${send_args[i+1]}")
                ((i+=2))
                ;;
            -s|--subject)
                subject="${send_args[i+1]}"
                ((i+=2))
                ;;
            -c|--cc)
                # Resolve m-aliases only; do NOT reject bare words here. A bare
                # name may be a real contact (nfile.asc), which only the Python
                # backend knows about. gmail-api-rw's _assert_valid_header_addrs
                # is the single source of truth for rejecting unresolvable Cc/Bcc.
                cc_addrs+=("$(_resolve_alias "${send_args[i+1]}")")
                ((i+=2))
                ;;
            -b|--bcc)
                bcc_addrs+=("$(_resolve_alias "${send_args[i+1]}")")
                ((i+=2))
                ;;
            -d|--done)
                done_flag=1
                i=$((i+1))
                ;;
            -n|--dry-run)
                dry_run=1
                i=$((i+1))
                ;;
            --after)
                after_time="${send_args[i+1]}"
                ((i+=2))
                ;;
            *)
                # Pass comma-separated recipients as-is (both neomutt and Gmail API handle multiple recipients)
                args+=("${send_args[i]}")
                i=$((i+1))
                ;;
        esac
    done

    # Build attachment arguments
    local -a attach_args=()
    for att in "${attachments[@]+"${attachments[@]}"}"; do
        attach_args+=(-a "$att")
    done


    # Resolve muttrc for account
    local muttrc
    if [[ -n "$account" ]]; then
        muttrc=$(_lookup_muttrc "$account")
        if [[ -z "$muttrc" ]]; then
            echo "m: unknown account '$account'" >&2
            return 1
        fi
    else
        muttrc=$(_default_muttrc)
        if [[ -z "$muttrc" ]]; then
            echo "m: no default account configured in $MAIL_TOOLS_CONFIG" >&2
            return 1
        fi
    fi

    # Check if we have .eml files (file mode)
    local file_mode=0
    for arg in "${args[@]}"; do
        if [[ "$arg" == *.eml ]]; then
            file_mode=1
            break
        fi
    done

    # Route to appropriate backend
    if (( file_mode )); then
        # File send mode
        for arg in "${args[@]}"; do
            if [[ "$arg" == *.eml ]]; then
                if [[ ! -f "$arg" ]]; then
                    log_error "file not found: $arg"
                    return 1
                fi

                local abspath="$(cd "$(dirname "$arg")" && pwd)/$(basename "$arg")"

                local send_rc=0
                if (( ! dry_run )); then
                    local _transport="SMTP"
                    _is_api_only "$muttrc" && _transport="gmail API"
                    if ! _attachment_prompt attachments "Sending $abspath via ${account:-default} ($_transport)"; then
                        return 1
                    fi
                    attach_args=()
                    for att in "${attachments[@]+"${attachments[@]}"}"; do
                        attach_args+=(-a "$att")
                    done
                fi

                if (( dry_run )); then
                    if _is_api_only "$muttrc"; then
                        echo "DRY-RUN: gmail-api-rw ${account:+-e $account} send --via-send -H $abspath ${attach_args[*]+${attach_args[*]}}"
                    else
                        echo "DRY-RUN: echo | neomutt -e 'unset record' -e '$M_NEOMUTT_EDITOR' -F $muttrc -H $abspath ${attach_args[*]+${attach_args[*]}}"
                    fi
                elif _is_api_only "$muttrc"; then
                    echo "m: ${account:-default} via gmail API" >&2
                    gmail-api-rw ${account:+-e "$account"} send --via-send -H "$abspath" "${attach_args[@]+"${attach_args[@]}"}" || send_rc=$?
                else
                    _assert_smtp_capable "$muttrc" "${account:-default}" || return 1
                    echo "m: ${account:-default} via SMTP" >&2
                    # Direct neomutt call - optimize by removing process hop
                    echo | neomutt -e 'unset record' -e "$M_NEOMUTT_EDITOR" -F "$muttrc" -H "$abspath" "${attach_args[@]+"${attach_args[@]}"}" || send_rc=$?
                fi

                if (( send_rc != 0 )); then
                    echo "$abspath FAILED (exit $send_rc)" >&2
                    return $send_rc
                fi
                (( dry_run )) || echo "$abspath sent"

                if (( done_flag )); then
                    local clip="/sent $abspath"
                    printf '%s' "$clip" | pbcopy
                    echo "Copied to clipboard: $clip" >&2
                fi
            fi
        done
    else
        # Compose mode
        # Check for scheduled send first, before routing decision
        if [[ -n "$after_time" ]]; then
            # Build draft arguments for scheduled send
            local -a draft_args=()
            [[ -n "$account" ]] && draft_args+=(-e "$account")
            [[ -n "$subject" ]] && draft_args+=(-s "$subject")

            # Add CC addresses
            for cc in "${cc_addrs[@]+"${cc_addrs[@]}"}"; do
                draft_args+=(-c "$cc")
            done

            # Add BCC addresses
            for bcc in "${bcc_addrs[@]+"${bcc_addrs[@]}"}"; do
                draft_args+=(-b "$bcc")
            done

            # Add attachment arguments
            draft_args+=("${attach_args[@]+"${attach_args[@]}"}")

            # Add recipients and other args
            draft_args+=("${args[@]}")

            # Route to scheduled send workflow
            _schedule_send "$after_time" "${draft_args[@]}"
            return $?
        fi

        if _is_api_only "$muttrc"; then
            # API-only account (e.g. Columbia, hackNY): there's no SMTP
            # muttrc, so we can't open neomutt interactively. Build a .eml
            # from stdin + flags and ship it through gmail-api-rw send -H.
            #
            # Stdin contract: the body MUST be piped or redirected. Bare
            # `cat` waits silently for terminal input, which looks like the
            # command is hung. Refuse early with a clear message.
            if [[ -t 0 ]]; then
                # Interactive mode: route to gmail-api-rw for editor integration
                echo "m: ${account:-default} via gmail API (interactive)" >&2

                # Collect recipients from args (anything containing @)
                local -a recipients=()
                for arg in "${args[@]}"; do
                    if [[ "$arg" =~ @ ]]; then
                        if [[ "$arg" =~ , ]]; then
                            # Split comma-separated recipients
                            IFS=',' read -ra split_recipients <<< "$arg"
                            for recipient in "${split_recipients[@]}"; do
                                recipients+=("${recipient// /}")  # trim spaces
                            done
                        else
                            recipients+=("$arg")
                        fi
                    fi
                done

                if [[ ${#recipients[@]} -eq 0 ]]; then
                    echo "m: recipient required for interactive send" >&2
                    return 1
                fi

                # Build recipient - use first one for primary
                local primary_recipient="${recipients[0]}"

                # Warn about multiple recipients (use first, ignore others)
                if [[ ${#recipients[@]} -gt 1 ]]; then
                    echo "Warning: Multiple recipients specified. Using first: $primary_recipient" >&2
                    echo " Others ignored: ${recipients[*]:1}" >&2
                    echo " Use separate commands for multiple recipients." >&2
                fi

                # Build gmail-api-rw command without -H flag to trigger interactive mode
                local -a gmail_cmd=(gmail-api-rw)
                [[ -n "$account" ]] && gmail_cmd+=(-e "$account")
                gmail_cmd+=(send --via-send "$primary_recipient")
                [[ -n "$subject" ]] && gmail_cmd+=(-s "$subject")

                # Add CC addresses
                for cc in "${cc_addrs[@]+"${cc_addrs[@]}"}"; do
                    gmail_cmd+=(-c "$cc")
                done

                # Add BCC addresses
                for bcc in "${bcc_addrs[@]+"${bcc_addrs[@]}"}"; do
                    gmail_cmd+=(-b "$bcc")
                done

                # Add attachments
                gmail_cmd+=("${attach_args[@]+"${attach_args[@]}"}")

                # Execute interactive send
                "${gmail_cmd[@]}"
                return $?
            fi

            local datestr eml_path
            datestr=$(date +%Y%m%d-%H%M%S)
            eml_path="/tmp/m-send-via-eml-${datestr}.eml"

            # Collect recipients from args (anything containing @)
            # Handle comma-separated recipients by splitting them
            local -a recipients=()
            for arg in "${args[@]}"; do
                if [[ "$arg" =~ @ ]]; then
                    if [[ "$arg" =~ , ]]; then
                        # Split comma-separated recipients
                        IFS=',' read -ra split_recipients <<< "$arg"
                        for recipient in "${split_recipients[@]}"; do
                            recipients+=("$recipient")
                        done
                    else
                        recipients+=("$arg")
                    fi
                fi
            done

            if [[ ${#recipients[@]} -eq 0 ]]; then
                echo "m: no recipient specified" >&2
                return 1
            fi

            # Build .eml file: To, Cc, Bcc, Subject headers, blank line, body from stdin
            {
                printf 'To: %s\n' "$(IFS=,; echo "${recipients[*]}")"
                if [[ ${#cc_addrs[@]} -gt 0 ]]; then
                    printf 'Cc: %s\n' "$(IFS=,; echo "${cc_addrs[*]}")"
                fi
                if [[ ${#bcc_addrs[@]} -gt 0 ]]; then
                    printf 'Bcc: %s\n' "$(IFS=,; echo "${bcc_addrs[*]}")"
                fi
                printf 'Subject: %s\n' "${subject:-(no subject)}"
                printf '\n'
                cat
            } > "$eml_path"

            echo "⚠️  m: API-only account; auto-created .eml at $eml_path" >&2
            if (( dry_run )); then
                echo "DRY-RUN: gmail-api-rw ${account:+-e $account} send --via-send -H $eml_path ${attach_args[*]+${attach_args[*]}}"
                return 0
            fi
            echo "m: ${account:-default} via gmail API" >&2
            gmail-api-rw ${account:+-e "$account"} send --via-send -H "$eml_path" "${attach_args[@]+"${attach_args[@]}"}"
            return $?
        fi

        # SMTP-only path below. Guard against a muttrc with no smtp_url, which
        # would make neomutt silently drop the message via local sendmail.
        # (Skip the check on dry-run so previews still work for inspection.)
        if (( ! dry_run )); then
            _assert_smtp_capable "$muttrc" "${account:-default}" || return 1
        fi

        # ------------------------------------------------------------------
        # Subject prompt for bare compose sends (e.g. the `momo`/`mail`
        # aliases: `m g send <addr>` with no -s). Without this you land
        # straight in neomutt's editor with an empty Subject header. Ask for
        # the subject at the shell first, then pass it through as -s so it is
        # pre-filled. Guards:
        #   - only when no -s was given ($subject empty)
        #   - only interactively (stdin is a tty); piped/scripted sends skip
        #   - not on dry-run
        # Empty input just falls through (neomutt's abort_nosubject still
        # applies), so hitting Return changes nothing about the old flow.
        local -a subject_args=()
        if [[ -n "$subject" ]]; then
            subject_args=(-s "$subject")
        elif (( ! dry_run )) && [[ -t 0 && -t 2 ]]; then
            local _prompt_subject=""
            read -r -e -p "Subject: " _prompt_subject </dev/tty
            [[ -n "$_prompt_subject" ]] && subject_args=(-s "$_prompt_subject")
        fi

        # Check if we have any recipients (arguments containing @)
        local has_recipients=0
        for arg in "${args[@]}"; do
            if [[ "$arg" =~ @ ]]; then
                has_recipients=1
                break
            fi
        done

        if (( ! has_recipients )); then
            if (( dry_run )); then
                echo "DRY-RUN: neomutt -e 'unset record' -e '$M_NEOMUTT_EDITOR' -F $muttrc ${subject_args[*]+${subject_args[*]}} ${args[*]} ${attach_args[*]+${attach_args[*]}}"
                return 0
            fi
            # No recipients found, use neomutt in compose mode (user will enter recipient)
            echo "m: ${account:-default} via SMTP" >&2
            neomutt -e 'unset record' -e "$M_NEOMUTT_EDITOR" -F "$muttrc" "${subject_args[@]+"${subject_args[@]}"}" "${args[@]}" "${attach_args[@]+"${attach_args[@]}"}"
        else
            # Send single email with all arguments (neomutt handles comma-separated recipients)
            if (( dry_run )); then
                echo "DRY-RUN: neomutt -e 'unset record' -e '$M_NEOMUTT_EDITOR' -F $muttrc ${subject_args[*]+${subject_args[*]}} ${args[*]} ${attach_args[*]+${attach_args[*]}}"
                return 0
            fi
            echo "m: ${account:-default} via SMTP" >&2
            neomutt -e 'unset record' -e "$M_NEOMUTT_EDITOR" -F "$muttrc" "${subject_args[@]+"${subject_args[@]}"}" "${args[@]}" "${attach_args[@]+"${attach_args[@]}"}"
        fi
    fi
}

