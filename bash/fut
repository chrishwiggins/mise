#!/bin/bash

if [ $# -lt 2 ]; then
    echo "Usage: fut <timespec> <message>" >&2
    exit 1
fi

timespec="$1"
shift
message="$*"

# Use the modern `m send` dispatcher; the old mutt wrapper warned on every
# run because the body arrives piped rather than on a tty.
echo "$message" | "$(dirname "$(realpath "$0")")/m" send -s "$message" "${timespec}@followupthen.com"
