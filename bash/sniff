#!/bin/bash
# WiFi network scanner - replacement for deprecated 'airport -s'
# macOS 15+ redacts SSID names in system_profiler output unless the app has
# Location Services permission. If a CoreWLAN helper named 'wifi-scan' is on
# PATH, use it (it shows real SSIDs once Location Services is granted).
# Otherwise fall back to parsing system_profiler (names may be <redacted>).

if command -v wifi-scan >/dev/null 2>&1; then
    exec wifi-scan "$@"
fi

printf "%-40s %8s\n" "SSID" "RSSI"
print_line() { printf '%.0s-' {1..66}; echo; }
print_line

system_profiler SPAirPortDataType 2>/dev/null | \
awk '
/Other Local Wi-Fi Networks:/ { in_other=1; next }
in_other && /^[[:space:]]*$/ { next }
in_other && /:$/ {
    gsub(/^[[:space:]]+/, "")
    gsub(/:$/, "")
    ssid=$0
    getline
    while ($0 ~ /^[[:space:]]/ && $0 !~ /:$/) {
        if ($0 ~ /Signal \/ Noise:/) {
            split($0, parts, ":")
            signal = parts[2]
            gsub(/^[[:space:]]+/, "", signal)
            split(signal, sig_parts, "/")
            sig = sig_parts[1]
            gsub(/[[:space:]].*$/, "", sig)
            print ssid "\t" sig
            break
        }
        getline
    }
}
' | sort -t$'\t' -k2 -rn | \
while IFS=$'\t' read -r ssid signal; do
    printf "%-40s %4s dBm\n" "$ssid" "$signal"
done
