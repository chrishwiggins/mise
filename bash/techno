#!/bin/bash
# techno : turn ANY phrase in ANY language into a phat-beat techno banger,
#          in the spirit of DJ Strong Bad's "The System Is Down."
#
#   techno LANG PHRASE [options]
#
# Self-contained: needs only `say`, `sox`, `ffmpeg`, and python3+numpy+scipy.
# All intermediates go to a temp dir; the finished track is written to $PWD
# (or wherever -o points). No project directory required.
#
# LANG : a `say` locale (en_US, de_DE, ja_JP ...), a 2-letter code (en, de, ja),
#        a language name (italian, japanese), la/latin (-> Italian vowels),
#        or a specific voice name (Alice).
#
# PHRASE is the main hook. Real techno drops 2-3 phrases strategically, not one,
# so you can add a breakdown line and a climax line with -2 and -3:
#   -1 = main hook   (intro / build / main / drop)   [same as the positional]
#   -2 = breakdown   (the contrast line in the break section)
#   -3 = climax      (layered on top in the drop)
# Phrases fall back to the main hook if not given, so old one-phrase calls work.
#
# Examples:
#   techno en "the system is down"
#   techno en "the system is down" -2 "everybody to the limit" -3 "come on"
#   techno de "wir sind die roboter" --style hardtechno --bpm 128
#   techno ja "konnichiwa sekai" --bpm 140
#   techno la "favere" --style house --bpm 126
#
# Options:
#   -2 PHRASE      breakdown phrase (played in the break section)
#   -3 PHRASE      climax phrase (layered into the drop)
#   --bpm N        tempo (default 128)
#   --bars N       length in bars (default 32)
#   --style NAME   house | techno | hardtechno | strongbad (default strongbad)
#   --rate N       say speaking rate (default 150)
#   -v VOICE       force a specific say voice
#   -o PATH        output basename/path (default: ./<phrase-slug>)
#   --no-play      don't auto-play when finished
set -e

# ---------- args ----------
if [ $# -lt 2 ]; then
  sed -n '2,38p' "$0" | sed 's/^# \{0,1\}//'
  exit 1
fi
LANG_ARG="$1"; shift
PHRASE="$1"; shift

BPM=128; BARS=32; STYLE=strongbad; RATE=150; VOICE=""; OUTPATH=""; PLAY=1
PHRASE2=""; PHRASE3=""
while [ $# -gt 0 ]; do
  case "$1" in
    -1) PHRASE="$2"; shift 2;;
    -2) PHRASE2="$2"; shift 2;;
    -3) PHRASE3="$2"; shift 2;;
    --bpm) BPM="$2"; shift 2;;
    --bars) BARS="$2"; shift 2;;
    --style) STYLE="$2"; shift 2;;
    --rate) RATE="$2"; shift 2;;
    -v) VOICE="$2"; shift 2;;
    -o) OUTPATH="$2"; shift 2;;
    --no-play) PLAY=0; shift;;
    *) echo "techno: unknown option: $1" >&2; exit 1;;
  esac
done

# phrases 2 and 3 fall back to the main hook if not supplied
[ -z "$PHRASE2" ] && PHRASE2="$PHRASE"
[ -z "$PHRASE3" ] && PHRASE3="$PHRASE"

for need in say sox ffmpeg python3; do
  command -v "$need" >/dev/null || { echo "techno: missing dependency: $need" >&2; exit 1; }
done

# ---------- temp workspace ----------
DAT="$(mktemp -d "${TMPDIR:-/tmp}/techno.XXXXXX")"
trap 'rm -rf "$DAT"' EXIT
SR=44100

# ---------- resolve voice ----------
VOICES="$DAT/voices.tsv"
say -v '?' | sed -E 's/^(.+[^ ]) +([a-z]{2}_[A-Z0-9]{2,3}|[a-z]{2}_[0-9]{3}) +#.*/\1\t\2/' > "$VOICES"

norm_lang () {
  case "$(echo "$1" | tr '[:upper:]' '[:lower:]')" in
    la|latin)               echo it ;;
    en|english)             echo en ;;
    it|italian)             echo it ;;
    de|german|deutsch)      echo de ;;
    fr|french|francais)     echo fr ;;
    es|spanish|espanol)     echo es ;;
    pt|portuguese)          echo pt ;;
    ja|jp|japanese)         echo ja ;;
    zh|cn|chinese|mandarin) echo zh ;;
    ko|korean)              echo ko ;;
    ru|russian)             echo ru ;;
    ar|arabic)              echo ar ;;
    he|hebrew)              echo he ;;
    hi|hindi)               echo hi ;;
    nl|dutch)               echo nl ;;
    sv|swedish)             echo sv ;;
    pl|polish)              echo pl ;;
    tr|turkish)             echo tr ;;
    el|greek)               echo el ;;
    th|thai)                echo th ;;
    vi|vietnamese)          echo vi ;;
    *)                      echo "$1" ;;
  esac
}

# first installed voice matching a name (case-insensitive, ignores trailing
# qualifiers like " (Premium)"); echoes the full voice name or nothing
pick_voice () {
  for want in "$@"; do
    awk -F'\t' -v w="$want" 'BEGIN{w=tolower(w)}
      {n=$1; sub(/ *\(.*/,"",n); if(tolower(n)==w){print $1; exit}}' "$VOICES" && return 0
  done
}

if [ -n "$VOICE" ]; then
  :
elif echo "$LANG_ARG" | grep -qE '^[a-z]{2}_[A-Z0-9]{2,3}$'; then
  VOICE="$(awk -F'\t' -v l="$LANG_ARG" '$2==l{print $1; exit}' "$VOICES")"
else
  KEY="$(norm_lang "$LANG_ARG")"
  # for English, prefer a clean natural voice over whatever sorts first
  # (which is the novelty voice "Albert"); fall through to what's installed
  if [ "$KEY" = en ]; then
    VOICE="$(pick_voice 'Ava' 'Samantha' 'Allison' 'Serena' 'Tom' 'Evan' 'Daniel')"
  fi
  [ -z "$VOICE" ] && VOICE="$(awk -F'\t' -v k="$KEY" 'tolower($1)==tolower(k){print $1; exit}' "$VOICES")"
  [ -z "$VOICE" ] && VOICE="$(awk -F'\t' -v p="$KEY" 'index($2, p"_")==1{print $1; exit}' "$VOICES")"
fi
[ -z "$VOICE" ] && VOICE="Samantha"
echo "voice: $VOICE   style: $STYLE   ${BPM}bpm x ${BARS}bars"
echo "  hook(-1):      \"$PHRASE\""
echo "  breakdown(-2): \"$PHRASE2\""
echo "  climax(-3):    \"$PHRASE3\""

# ---------- vocal synth ----------
# Render each phrase into the same family of chops, prefixed p1_/p2_/p3_.
mkvoc () {
  local pfx="$1" txt="$2"
  say -v "$VOICE" -r "$RATE" -o "$DAT/${pfx}_raw.aiff" "$txt"
  sox "$DAT/${pfx}_raw.aiff" -r $SR -c 1 "$DAT/${pfx}.wav" \
      silence 1 0.01 0.1% reverse silence 1 0.01 0.1% reverse gain -n -3
  sox "$DAT/${pfx}.wav" "$DAT/${pfx}_low.wav" speed 0.84 gain -n -4
  sox "$DAT/${pfx}.wav" "$DAT/${pfx}_hi.wav"  speed 1.18 gain -n -5
  sox "$DAT/${pfx}.wav" "$DAT/${pfx}_robot.wav" overdrive 8 5 lowpass 3000 gain -n -4 2>/dev/null \
      || cp "$DAT/${pfx}.wav" "$DAT/${pfx}_robot.wav"
}
mkvoc p1 "$PHRASE"
mkvoc p2 "$PHRASE2"
mkvoc p3 "$PHRASE3"

# ---------- drum + bass one-shots ----------
case "$STYLE" in
  hardtechno|strongbad) KICKHZ="150-45"; KICKLEN=0.34; DRIVE=1 ;;
  techno)               KICKHZ="130-48"; KICKLEN=0.30; DRIVE=0 ;;
  *)                    KICKHZ="120-50"; KICKLEN=0.30; DRIVE=0 ;;
esac
sox -n "$DAT/kick.wav" synth $KICKLEN sine $KICKHZ fade h 0.001 $KICKLEN $(python3 -c "print($KICKLEN*0.92)") gain -n -1 lowpass 220
sox -n "$DAT/click.wav" synth 0.012 sine 1900 fade h 0 0.012 0.011 gain -n -9
sox -m "$DAT/kick.wav" "$DAT/click.wav" "$DAT/kk.wav" gain -n -1
if [ "$DRIVE" = 1 ]; then sox "$DAT/kk.wav" "$DAT/kick.wav" overdrive 6 4 gain -n -1; else mv "$DAT/kk.wav" "$DAT/kick.wav"; fi

sox -n "$DAT/clap.wav" synth 0.14 noise fade h 0 0.14 0.13 bandpass 1200 800 gain -n -6
sox -n "$DAT/hat.wav"  synth 0.05 noise fade h 0 0.05 0.045 highpass 8000 gain -n -12
sox -n "$DAT/ohat.wav" synth 0.18 noise fade h 0 0.18 0.16 highpass 7000 gain -n -14

mkbass () {
  Ln=$(python3 -c "print(60/$BPM/4*2)")
  sox -n "$2" synth $Ln pluck $1 fade h 0.002 $Ln $(python3 -c "print($Ln*0.8)") lowpass 500 gain -n -3 2>/dev/null \
    || sox -n "$2" synth $Ln sine $1 fade h 0.002 $Ln $(python3 -c "print($Ln*0.8)") lowpass 500 gain -n -3
  if [ "$STYLE" = hardtechno ] || [ "$STYLE" = strongbad ]; then
    sox "$2" "${2%.wav}_d.wav" overdrive 10 6 lowpass 600 gain -n -2 && mv "${2%.wav}_d.wav" "$2"
  fi
}
mkbass 55 "$DAT/bass_A.wav"
mkbass 65 "$DAT/bass_C.wav"
mkbass 49 "$DAT/bass_G.wav"
mkbass 82 "$DAT/bass_E.wav"
sox -n "$DAT/stab.wav" synth 0.25 sine 220 sine 277 sine 330 fade h 0.005 0.25 0.22 gain -n -8

# ---------- output path ----------
if [ -z "$OUTPATH" ]; then
  SLUG="$(echo "$PHRASE" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-//;s/-$//' | cut -c1-40)"
  [ -z "$SLUG" ] && SLUG="track"
  OUTPATH="./$SLUG"
fi
OUTPATH="${OUTPATH%.wav}"; OUTPATH="${OUTPATH%.mp3}"
OUTDIR="$(dirname "$OUTPATH")"; mkdir -p "$OUTDIR"

# ---------- sequence (inlined python) ----------
python3 - "$DAT" "$SR" "$BPM" "$BARS" "$STYLE" "$OUTPATH.wav" <<'PYEOF'
import sys, os
import numpy as np
from scipy.io import wavfile

dat, sr, bpm, bars, style, out_wav = sys.argv[1:7]
sr=int(sr); bpm=float(bpm); bars=int(bars)

def load(name):
    p=os.path.join(dat,name)
    r,x=wavfile.read(p)
    if x.dtype==np.int16: x=x.astype(np.float32)/32768.0
    elif x.dtype==np.int32: x=x.astype(np.float32)/2147483648.0
    else: x=x.astype(np.float32)
    if x.ndim>1: x=x.mean(axis=1)
    if r!=sr:
        n=int(len(x)*sr/r)
        x=np.interp(np.linspace(0,len(x),n,endpoint=False),np.arange(len(x)),x)
    return x

beat=60.0/bpm; bar=4*beat; half=beat/2
total=bar*bars; N=int(total*sr)+int(sr*0.5)
def s(t): return int(t*sr)

kick,clap,hat,ohat=load("kick.wav"),load("clap.wav"),load("hat.wav"),load("ohat.wav")
stab=load("stab.wav")
# three phrase families: p1=main hook, p2=breakdown, p3=climax
P={p:{ "plain":load(f"{p}.wav"),
       "low":  load(f"{p}_low.wav"),
       "hi":   load(f"{p}_hi.wav"),
       "robot":load(f"{p}_robot.wav") } for p in ("p1","p2","p3")}
bass={k:load(f"bass_{k}.wav") for k in "ACGE"}

bed=np.zeros(N,dtype=np.float32)
def add(clip,at,g=1.0):
    a=int(at); b=a+len(clip)
    if a>=len(bed) or a<0: return
    if b>len(bed): clip=clip[:len(bed)-a]; b=len(bed)
    bed[a:b]+=clip*g

hard = style in ("hardtechno","strongbad")
def chop(p): return P[p]["robot"] if hard else P[p]["plain"]
bass_seq=["A","A","C","A","G","G","E","G"]
def section_of(b):
    f=b/max(bars,1)
    if f<0.125: return "intro"
    if f<0.25: return "build"
    if f<0.5: return "main"
    if f<0.625: return "break"
    return "drop"

for barn in range(bars):
    t0=barn*bar; sec=section_of(barn)
    if sec in ("intro","build","main","drop"):
        density=16 if sec!="intro" else 8
        for i in range(density):
            t=t0+i*(bar/density)
            add(hat,s(t),0.9 if i%4==2 else 0.6)
        for off in (1,3):
            add(ohat,s(t0+off*beat+half),0.7)
    if sec in ("build","main","drop") or (sec=="break" and barn==int(bars*0.625)-1):
        kg=0.85 if sec=="break" else 1.0
        for b in range(4): add(kick,s(t0+b*beat),kg)
    if sec in ("main","drop"):
        add(clap,s(t0+beat),0.8); add(clap,s(t0+3*beat),0.8)
    if sec in ("main","drop","break"):
        root=bass_seq[barn%len(bass_seq)]
        for slot in range(8):
            if slot%2==1: add(bass[root],s(t0+slot*half),0.9)
    # phrase placement by section role:
    #   intro/build/main -> p1 (main hook)
    #   break            -> p2 (breakdown line)
    #   drop             -> p1 hook + p3 climax layered on top
    if sec=="intro":
        if barn%2==1: add(chop("p1"),s(t0),0.8)
    elif sec=="build":
        add(chop("p1"),s(t0),0.85)
    elif sec=="main":
        add(chop("p1"),s(t0),0.95)
        if barn%2==1: add(P["p1"]["hi"],s(t0+2*beat),0.5)
    elif sec=="break":
        add(P["p2"]["low"],s(t0),0.9)
        if barn%2==1: add(chop("p2"),s(t0+2*beat),0.7)
    elif sec=="drop":
        add(chop("p1"),s(t0),1.0); add(chop("p3"),s(t0+2*beat),0.9)
        if barn%4==3: add(P["p3"]["hi"],s(t0+3*beat),0.6)
    if sec=="break" and barn==int(bars*0.625)-1:
        for i in range(8): add(stab,s(t0+i*half),0.3+0.07*i)

bed=bed/(np.max(np.abs(bed))+1e-9)*0.97
drive=1.6 if hard else 1.4
bed=np.tanh(bed*drive)/np.tanh(drive)
bed=bed/(np.max(np.abs(bed))+1e-9)*0.97
wavfile.write(out_wav,sr,(bed*32767).astype(np.int16))
print(f"wrote {out_wav}  ({total:.1f}s, {bpm:g} BPM, {style})")
PYEOF

ffmpeg -y -loglevel error -i "$OUTPATH.wav" -codec:a libmp3lame -b:a 192k "$OUTPATH.mp3"
echo "-> $OUTPATH.wav  /  $OUTPATH.mp3"
if [ "$PLAY" = 1 ]; then killall afplay 2>/dev/null || true; afplay "$OUTPATH.mp3" & echo "(playing)"; fi
