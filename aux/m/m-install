#!/bin/bash
set -e

# m-install - One-time setup script for the 'm' multi-account email dispatcher
#
# This script sets up all necessary configuration files in ~/.config
# for a CS professor or technical user to get started with 'm'.

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

print_header() {
    echo -e "${BOLD}=== m Email Dispatcher Setup ===${NC}"
    echo "Setting up multi-account email system in ~/.config"
    echo
}

print_step() {
    echo -e "${YELLOW}▶${NC} $1"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

check_dependencies() {
    print_step "Checking dependencies..."

    local missing=()

    if ! command -v jq >/dev/null 2>&1; then
        missing+=("jq")
    fi

    if ! command -v neomutt >/dev/null 2>&1; then
        missing+=("neomutt")
    fi

    if [[ ${#missing[@]} -gt 0 ]]; then
        print_error "Missing required dependencies: ${missing[*]}"
        echo "Please install:"
        for dep in "${missing[@]}"; do
            case "$dep" in
                jq)
                    echo "  macOS: brew install jq"
                    echo "  Ubuntu: sudo apt install jq"
                    ;;
                neomutt)
                    echo "  macOS: brew install neomutt"
                    echo "  Ubuntu: sudo apt install neomutt"
                    ;;
            esac
        done
        exit 1
    fi

    print_success "All dependencies found"
}

create_config_dirs() {
    print_step "Creating configuration directories..."

    mkdir -p ~/.config/mail-tools
    mkdir -p ~/.config/mutt
    mkdir -p ~/.config/google

    print_success "Configuration directories created"
}

create_sample_accounts() {
    print_step "Creating sample accounts configuration..."

    local config_file="$HOME/.config/mail-tools/accounts.json"

    if [[ -f "$config_file" ]]; then
        print_warning "Configuration already exists at $config_file"
        echo -n "Overwrite? [y/N] "
        read -r response
        if [[ ! "$response" =~ ^[Yy]$ ]]; then
            print_success "Keeping existing configuration"
            return 0
        fi
    fi

    cat > "$config_file" << 'EOF'
{
  "accounts": {
    "g": {
      "email": "your.personal@gmail.com",
      "muttrc": "~/.config/mutt/personal.muttrc",
      "chrome_profile": "Default"
    },
    "w": {
      "email": "work@university.edu",
      "muttrc": "/dev/null",
      "chrome_profile": "Work"
    }
  },
  "default_account": "g"
}
EOF

    print_success "Sample configuration created at $config_file"
    print_warning "You MUST edit this file to add your actual email addresses"
}

create_sample_muttrc() {
    print_step "Creating sample neomutt configuration..."

    local muttrc_file="$HOME/.config/mutt/personal.muttrc"

    if [[ -f "$muttrc_file" ]]; then
        print_warning "Mutt config already exists at $muttrc_file"
        return 0
    fi

    cat > "$muttrc_file" << 'EOF'
# Sample neomutt configuration for Gmail SMTP
# Copy this file and customize for each SMTP account

set from = "your.personal@gmail.com"
set realname = "Your Full Name"

# Gmail SMTP settings
set smtp_url = "smtps://your.personal@gmail.com@smtp.gmail.com:465/"
set smtp_pass = "your-gmail-app-password"

# IMAP settings (optional, for sent folder sync)
set folder = "imaps://imap.gmail.com:993"
set spoolfile = "+INBOX"
set record = "+[Gmail]/Sent Mail"
set postponed = "+[Gmail]/Drafts"

# Basic mutt settings
set ssl_starttls = yes
set ssl_force_tls = yes
set imap_user = "your.personal@gmail.com"
set imap_pass = "your-gmail-app-password"

# Disable local mail storage (we're using remote only)
unset record
EOF

    print_success "Sample mutt config created at $muttrc_file"
    print_warning "You MUST edit this file with your actual credentials"
}

create_gmail_api_placeholder() {
    print_step "Creating Gmail API credentials placeholder..."

    local creds_file="$HOME/.config/google/credentials.json"

    if [[ -f "$creds_file" ]]; then
        print_warning "Google credentials already exist at $creds_file"
        return 0
    fi

    cat > "$creds_file" << 'EOF'
{
  "_comment": "PLACEHOLDER - Replace with actual Google Cloud credentials",
  "_instructions": [
    "1. Go to https://console.cloud.google.com/",
    "2. Create a new project or select existing",
    "3. Enable Gmail API",
    "4. Create OAuth 2.0 credentials (Desktop application)",
    "5. Download the JSON file and replace this placeholder"
  ],
  "client_id": "your-client-id.googleusercontent.com",
  "client_secret": "your-client-secret",
  "redirect_uris": ["http://localhost"]
}
EOF

    print_success "Gmail API placeholder created at $creds_file"
    print_warning "Replace with actual Google Cloud credentials for Gmail API accounts"
}

install_symlink() {
    print_step "Installing 'm' command..."

    local script_path="$(cd "$(dirname "$0")" && pwd)/m"
    local install_dir

    # Try to find a good place to install
    if [[ -d "/usr/local/bin" ]] && [[ -w "/usr/local/bin" ]]; then
        install_dir="/usr/local/bin"
    elif [[ ":$PATH:" == *":$HOME/bin:"* ]] && mkdir -p "$HOME/bin" 2>/dev/null; then
        install_dir="$HOME/bin"
    else
        print_warning "Could not find writable directory in PATH"
        echo "Please manually add to PATH: export PATH=\"$(dirname "$script_path"):\$PATH\""
        echo "Or create symlink: ln -s \"$script_path\" /usr/local/bin/m"
        return 0
    fi

    if [[ -e "$install_dir/m" ]]; then
        print_warning "Command 'm' already exists at $install_dir/m"
        echo -n "Overwrite? [y/N] "
        read -r response
        if [[ ! "$response" =~ ^[Yy]$ ]]; then
            print_success "Keeping existing 'm' command"
            return 0
        fi
        rm -f "$install_dir/m"
    fi

    ln -s "$script_path" "$install_dir/m"
    print_success "Installed 'm' command at $install_dir/m"
}

print_next_steps() {
    echo
    echo -e "${BOLD}=== Next Steps ===${NC}"
    echo
    echo "1. ${YELLOW}Edit account configuration:${NC}"
    echo "   \$EDITOR ~/.config/mail-tools/accounts.json"
    echo "   - Replace sample email addresses with your actual addresses"
    echo "   - For Gmail API accounts: set muttrc to \"/dev/null\""
    echo "   - For SMTP accounts: set muttrc to path of config file"
    echo
    echo "2. ${YELLOW}Set up SMTP accounts:${NC}"
    echo "   \$EDITOR ~/.config/mutt/personal.muttrc"
    echo "   - Add your actual email and app password"
    echo "   - Create separate .muttrc files for each SMTP account"
    echo
    echo "3. ${YELLOW}Set up Gmail API accounts (if any):${NC}"
    echo "   - Go to https://console.cloud.google.com/"
    echo "   - Enable Gmail API and create OAuth credentials"
    echo "   - Replace ~/.config/google/credentials.json"
    echo "   - Install: pip3 install google-auth google-auth-oauthlib google-auth-httplib2 google-api-python-client"
    echo
    echo "4. ${YELLOW}Test the installation:${NC}"
    echo "   m --help"
    echo "   m --help=accounts"
    echo
    echo "5. ${YELLOW}Read the manual:${NC}"
    echo "   cat ~/mise/man/m.md"
    echo
    echo -e "${GREEN}Setup complete!${NC} Edit the config files and you're ready to go."
}

print_troubleshooting() {
    echo
    echo -e "${BOLD}=== Troubleshooting ===${NC}"
    echo
    echo "• ${YELLOW}Config file issues:${NC}"
    echo "  jq '.' ~/.config/mail-tools/accounts.json  # Test JSON validity"
    echo
    echo "• ${YELLOW}SMTP authentication:${NC}"
    echo "  neomutt -F ~/.config/mutt/personal.muttrc -s Test yourself@example.com"
    echo
    echo "• ${YELLOW}Gmail API setup:${NC}"
    echo "  python3 -c 'import google.auth; print(\"Google libraries installed\")'"
    echo
    echo "• ${YELLOW}Command not found:${NC}"
    echo "  echo \$PATH  # Check if install directory is in PATH"
    echo "  which m     # Find where 'm' is installed"
}

main() {
    print_header

    check_dependencies
    create_config_dirs
    create_sample_accounts
    create_sample_muttrc
    create_gmail_api_placeholder
    install_symlink

    print_next_steps
    print_troubleshooting
}

# Run with confirmation unless --yes flag
if [[ "$1" == "--yes" ]]; then
    main
else
    echo "This will set up the 'm' multi-account email dispatcher."
    echo "Configuration files will be created in ~/.config/"
    echo
    echo -n "Continue? [Y/n] "
    read -r response
    if [[ "$response" =~ ^[Nn]$ ]]; then
        echo "Setup cancelled."
        exit 0
    fi
    main
fi